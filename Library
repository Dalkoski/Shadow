--==============================================================
-- UTILS
--==============================================================
local function tween(obj, time, props, style, dir)
	local t = TweenService:Create(obj, TweenInfo.new(time, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out), props)
	t:Play()
	return t
end

local function newInst(class, props, parent)
	local i = Instance.new(class)
	for k, v in pairs(props or {}) do i[k] = v end
	if parent then i.Parent = parent end
	return i
end

local function corner(parent, r)
	return newInst("UICorner", {CornerRadius = UDim.new(0, r or CORNER_RADIUS)}, parent)
end

local function stroke(parent, color, transparency, thickness)
	return newInst("UIStroke", {
		Color = color or THEME.Border,
		Transparency = transparency or 0.5,
		Thickness = thickness or 1,
	}, parent)
end

local function padding(parent, t, r, b, l)
	return newInst("UIPadding", {
		PaddingTop    = UDim.new(0, t or 0),
		PaddingRight  = UDim.new(0, r or 0),
		PaddingBottom = UDim.new(0, b or 0),
		PaddingLeft   = UDim.new(0, l or 0),
	}, parent)
end

local function listLayout(parent, pad, dir)
	return newInst("UIListLayout", {
		Padding = UDim.new(0, pad or 0),
		FillDirection = dir or Enum.FillDirection.Vertical,
		SortOrder = Enum.SortOrder.LayoutOrder,
	}, parent)
end

--==============================================================
-- 2. PUBLIC API
--==============================================================
function VaenHub:CreateWindow(config)
	config = config or {}

	local win = setmetatable({
		_config = config,
		_tabs = {},
		_elements = {},
		_connections = {},
		_unloadHooks = {},
		_hidden = false,
		_minimised = false,
		_keybinds = config.Keybinds or {Toggle = "K"},
		_protect = config.Protect or {},
		_configSave = config.Config or {},
		_name = config.Name or "VaenHub",
		_version = config.Version or "v2.2",
		_currentTab = nil,
	}, {__index = Window})

	-- Key system
	if config.KeySystem and config.KeySystem.Enabled then
		local ok = self:_RunKeySystem(win, config.KeySystem)
		if not ok then return nil end
	end

	self:_BuildWindow(win)

	if win._protect then win:Protect(win._protect) end

	if win._configSave.Enabled then
		task.delay(0.5, function() win:LoadConfig() end)
	end

	table.insert(self.Windows, win)
	return win
end

function VaenHub:Notify(d)
	d = d or {}
	self:_QueueNotif({
		Title = d.Title or "Notification",
		Content = d.Content or "",
		Duration = d.Duration or 5,
		Type = d.Type or "default",
	})
end

function VaenHub:Get(flag) return self.Flags[flag] end

function VaenHub:Destroy()
	for _, w in ipairs(self.Windows) do pcall(function() w:Destroy() end) end
	self.Windows = {}
	self.Flags = {}
end

--==============================================================
-- 3. WINDOW METHODS
--==============================================================
function Window:Tab(name)
	local t = setmetatable({
		_name = name,
		_window = self,
		_elements = {},
	}, {__index = Tab})
	VaenHub:_BuildTab(self, t)
	table.insert(self._tabs, t)
	if #self._tabs == 1 then self:_SelectTab(t) end
	return t
end

function Window:Protect(opts)
	opts = opts or {}
	if opts.HideUI     then VaenHub:_HideFromCoreGui(self) end
	if opts.AntiAFK    then VaenHub:_AntiAFK(self) end
	if opts.AntiKick   then VaenHub:_AntiKick(self) end
	if opts.AntiLag    then VaenHub:_AntiLag(self) end
	if opts.AutoRejoin then VaenHub:_AutoRejoin(self) end
	if opts.ServerHop and opts.ServerHop.Enabled then
		VaenHub:_ServerHop(self, opts.ServerHop)
	end
end

function Window:OnUnload(cb) table.insert(self._unloadHooks, cb) end
function Window:SaveConfig(p) VaenHub:_SaveConfig(self, p or "default") end
function Window:LoadConfig(p) VaenHub:_LoadConfig(self, p or "default") end

function Window:Hide()
	self._hidden = true
	tween(self._main, 0.3, {Size = UDim2.fromOffset(WINDOW_SIZE.X, 0)}, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
end

function Window:Show()
	self._hidden = false
	tween(self._main, 0.4, {Size = UDim2.fromOffset(WINDOW_SIZE.X, WINDOW_SIZE.Y)})
end

function Window:Toggle()
	if self._hidden then self:Show() else self:Hide() end
end

function Window:Minimise()
	self._minimised = not self._minimised
	if self._minimised then
		self._content.Visible = false
		self._tabBar.Visible = false
		tween(self._main, 0.3, {Size = UDim2.fromOffset(WINDOW_SIZE.X, TOPBAR_HEIGHT)})
	else
		tween(self._main, 0.3, {Size = UDim2.fromOffset(WINDOW_SIZE.X, WINDOW_SIZE.Y)})
		task.wait(0.2)
		self._content.Visible = true
		self._tabBar.Visible = true
	end
end

function Window:Destroy()
	for _, h in ipairs(self._unloadHooks) do pcall(h) end
	for _, c in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
	if self._gui then pcall(function() self._gui:Destroy() end) end
end

function Window:_SelectTab(tab)
	for _, t in ipairs(self._tabs) do
		local selected = (t == tab)
		t._page.Visible = selected
		if selected then
			tween(t._button, 0.2, {BackgroundColor3 = THEME.Accent, BackgroundTransparency = 0})
			tween(t._buttonLabel, 0.2, {TextColor3 = THEME.Text})
			tween(t._activeDot, 0.2, {BackgroundTransparency = 0})
		else
			tween(t._button, 0.2, {BackgroundColor3 = THEME.ElementBg, BackgroundTransparency = 1})
			tween(t._buttonLabel, 0.2, {TextColor3 = THEME.TextDim})
			tween(t._activeDot, 0.2, {BackgroundTransparency = 1})
		end
	end
	self._currentTab = tab
end

