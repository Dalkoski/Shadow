function VaenHub:_BuildWindow(win)
	-- GUI
	local gui = newInst("ScreenGui", {
		Name = "VaenHub_"..HttpService:GenerateGUID(false):sub(1,6),
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		ResetOnSpawn = false,
		DisplayOrder = 100,
	})
	win._gui = gui
	if not (win._protect and win._protect.HideUI) then
		gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	end

	-- Main container
	local main = newInst("Frame", {
		Name = "Main",
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromOffset(WINDOW_SIZE.X, WINDOW_SIZE.Y),
		BackgroundColor3 = THEME.Background,
		BorderSizePixel = 0,
		ClipsDescendants = true,
	}, gui)
	corner(main, 12)
	stroke(main, Color3.fromRGB(255,255,255), 0.9)
	win._main = main

	-- Phantom V watermark
	newInst("TextLabel", {
		Size = UDim2.fromOffset(280, 280),
		AnchorPoint = Vector2.new(1, 1),
		Position = UDim2.new(1, 30, 1, 30),
		BackgroundTransparency = 1,
		Text = "V",
		Font = Enum.Font.GothamBold,
		TextSize = 280,
		TextColor3 = Color3.fromRGB(255,255,255),
		TextTransparency = 0.96,
		TextXAlignment = Enum.TextXAlignment.Right,
		TextYAlignment = Enum.TextYAlignment.Bottom,
