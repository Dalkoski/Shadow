function Phantom:CreateWindow(opts)
    opts = opts or {}
    local Window = {}
    local theme = self.Themes[opts.Theme or "Dark"] or self.Themes.Dark
    Window._theme = theme
    Window._connections = {}
    Window._themeListeners = {}
    Phantom._activeWindow = Window

    local function track(c)
        if c then table.insert(Window._connections, c) end
        return c
    end
    local function onTheme(fn)
        table.insert(Window._themeListeners, fn)
    end

    --------------------------------------------------------
    -- ScreenGui
    --------------------------------------------------------
    local gui = Instance.new("ScreenGui")
    gui.Name = "Phantom_" .. HttpService:GenerateGUID(false):sub(1, 8)
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.DisplayOrder = 100
    safeParent(gui)
    Window._gui = gui

    --------------------------------------------------------
    -- Main frame
    --------------------------------------------------------
    local Main = Instance.new("Frame")
    Main.Name = "Main"
    Main.Size = UDim2.new(0, 540, 0, 420)
    Main.Position = UDim2.new(0.5, -270, 0.5, -210)
    Main.BackgroundColor3 = theme.Background
    Main.BorderSizePixel = 0
    Main.ClipsDescendants = true
    Main.Parent = gui
    corner(Main, UDim.new(0, 10))
    local mainStroke = stroke(Main, theme.Stroke)

    --------------------------------------------------------
    -- Topbar
    --------------------------------------------------------
    local Topbar = Instance.new("Frame")
    Topbar.Name = "Topbar"
    Topbar.Size = UDim2.new(1, 0, 0, 50)
    Topbar.BackgroundColor3 = theme.Topbar
    Topbar.BorderSizePixel = 0
    Topbar.Parent = Main
    corner(Topbar, UDim.new(0, 10))

    local TopbarCover = Instance.new("Frame")
    TopbarCover.Position = UDim2.new(0, 0, 1, -10)
    TopbarCover.Size = UDim2.new(1, 0, 0, 10)
    TopbarCover.BackgroundColor3 = theme.Topbar
    TopbarCover.BorderSizePixel = 0
    TopbarCover.Parent = Topbar

    local TopbarDivider = Instance.new("Frame")
    TopbarDivider.Position = UDim2.new(0, 0, 1, 0)
    TopbarDivider.Size = UDim2.new(1, 0, 0, 1)
    TopbarDivider.BackgroundColor3 = theme.Stroke
    TopbarDivider.BackgroundTransparency = 0.3
    TopbarDivider.BorderSizePixel = 0
    TopbarDivider.Parent = Topbar

    local TitleHolder = Instance.new("Frame")
    TitleHolder.Position = UDim2.new(0, 14, 0, 0)
    TitleHolder.Size = UDim2.new(0.5, 0, 1, 0)
    TitleHolder.BackgroundTransparency = 1
    TitleHolder.Parent = Topbar

    local TitleText = Instance.new("TextLabel")
    TitleText.Position = UDim2.new(0, 0, 0, 8)
    TitleText.Size = UDim2.new(1, 0, 0, 18)
    TitleText.BackgroundTransparency = 1
    TitleText.Font = FONT_BOLD
    TitleText.Text = opts.Name or "Phantom"
    TitleText.TextSize = 15
    TitleText.TextColor3 = theme.Text
    TitleText.TextXAlignment = Enum.TextXAlignment.Left
    TitleText.Parent = TitleHolder

    local SubtitleText = Instance.new("TextLabel")
    SubtitleText.Position = UDim2.new(0, 0, 0, 26)
    SubtitleText.Size = UDim2.new(1, 0, 0, 14)
    SubtitleText.BackgroundTransparency = 1
    SubtitleText.Font = FONT_REG
    SubtitleText.Text = opts.Subtitle or ""
    SubtitleText.TextSize = 12
    SubtitleText.TextColor3 = theme.SubText
    SubtitleText.TextXAlignment = Enum.TextXAlignment.Left
    SubtitleText.Parent = TitleHolder

    local BtnHolder = Instance.new("Frame")
    BtnHolder.AnchorPoint = Vector2.new(1, 0.5)
    BtnHolder.Position = UDim2.new(1, -10, 0.5, 0)
    BtnHolder.Size = UDim2.new(0, 70, 1, 0)
    BtnHolder.BackgroundTransparency = 1
    BtnHolder.Parent = Topbar
    local bl = listLayout(BtnHolder, Enum.FillDirection.Horizontal, 4)
    bl.HorizontalAlignment = Enum.HorizontalAlignment.Right
    bl.VerticalAlignment = Enum.VerticalAlignment.Center

    local function topBtn(symbol, cb)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(0, 28, 0, 28)
        b.BackgroundColor3 = theme.Element
        b.BackgroundTransparency = 0.4
        b.BorderSizePixel = 0
        b.Font = FONT_BOLD
        b.Text = symbol
        b.TextSize = 14
        b.TextColor3 = theme.Text
        b.AutoButtonColor = false
        b.Parent = BtnHolder
        corner(b, UDim.new(0, 6))
        track(b.MouseEnter:Connect(function()
            tween(b, TWEEN_FAST, { BackgroundTransparency = 0 })
        end))
        track(b.MouseLeave:Connect(function()
            tween(b, TWEEN_FAST, { BackgroundTransparency = 0.4 })
        end))
        track(b.MouseButton1Click:Connect(cb))
        return b
    end

    local minimized = false
    local origSize = Main.Size
    local MinBtn, CloseBtn
    MinBtn = topBtn("–", function()
        minimized = not minimized
        if minimized then
            tween(Main, TWEEN_MED, { Size = UDim2.new(origSize.X.Scale, origSize.X.Offset, 0, 50) })
        else
            tween(Main, TWEEN_MED, { Size = origSize })
        end
    end)
    CloseBtn = topBtn("✕", function() Window:Destroy() end)

    --------------------------------------------------------
    -- Dragging
    --------------------------------------------------------
    do
        local dragging, startPos, startInput
        track(Topbar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                startPos = Main.Position
                startInput = input.Position
            end
        end))
        track(UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            if input.UserInputType ~= Enum.UserInputType.MouseMovement
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
            local delta = input.Position - startInput
            Main.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end))
        track(UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end))
    end

    --------------------------------------------------------
    -- Tab bar
    --------------------------------------------------------
    local TabBar = Instance.new("Frame")
    TabBar.Position = UDim2.new(0, 0, 0, 50)
    TabBar.Size = UDim2.new(1, 0, 0, 42)
    TabBar.BackgroundColor3 = theme.Background
    TabBar.BorderSizePixel = 0
    TabBar.Parent = Main

    local TabScroll = Instance.new("ScrollingFrame")
    TabScroll.Size = UDim2.new(1, 0, 1, 0)
    TabScroll.BackgroundTransparency = 1
    TabScroll.BorderSizePixel = 0
    TabScroll.ScrollBarThickness = 0
    TabScroll.ScrollingDirection = Enum.ScrollingDirection.X
    TabScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabScroll.AutomaticCanvasSize = Enum.AutomaticSize.X
    TabScroll.ClipsDescendants = true
    TabScroll.Parent = TabBar
    local tabLayout = listLayout(TabScroll, Enum.FillDirection.Horizontal, 6)
    tabLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    padding(TabScroll, 6, 6, 12, 12)

    local TabDivider = Instance.new("Frame")
    TabDivider.Position = UDim2.new(0, 0, 1, 0)
    TabDivider.Size = UDim2.new(1, 0, 0, 1)
    TabDivider.BackgroundColor3 = theme.Stroke
    TabDivider.BackgroundTransparency = 0.4
    TabDivider.BorderSizePixel = 0
    TabDivider.Parent = TabBar

    --------------------------------------------------------
    -- Content
    --------------------------------------------------------
    local Content = Instance.new("Frame")
    Content.Position = UDim2.new(0, 0, 0, 92)
    Content.Size = UDim2.new(1, 0, 1, -92)
    Content.BackgroundTransparency = 1
    Content.ClipsDescendants = true
    Content.Parent = Main

    Window._tabs = {}
    Window._activeTab = nil

    --------------------------------------------------------
    -- Theme apply
    --------------------------------------------------------
    local function applyTheme(t)
        Window._theme = t
        theme = t
        Main.BackgroundColor3 = t.Background
        mainStroke.Color = t.Stroke
        Topbar.BackgroundColor3 = t.Topbar
        TopbarCover.BackgroundColor3 = t.Topbar
        TopbarDivider.BackgroundColor3 = t.Stroke
        TitleText.TextColor3 = t.Text
        SubtitleText.TextColor3 = t.SubText
        TabBar.BackgroundColor3 = t.Background
        TabDivider.BackgroundColor3 = t.Stroke
        MinBtn.BackgroundColor3 = t.Element
        MinBtn.TextColor3 = t.Text
        CloseBtn.BackgroundColor3 = t.Element
        CloseBtn.TextColor3 = t.Text
        for _, fn in ipairs(Window._themeListeners) do
            task.spawn(fn, t)
        end
    end

    function Window:SetTheme(name)
        local t = type(name) == "string" and Phantom.Themes[name] or (type(name) == "table" and name)
        if t then applyTheme(t) end
    end

    --------------------------------------------------------
    -- Show/hide
    --------------------------------------------------------
    local hidden = false
    local function setHidden(state)
        hidden = state
        Main.Visible = not state
    end
    local toggleKeyCode = Enum.KeyCode[opts.Keybind or "K"] or Enum.KeyCode.K
    track(UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == toggleKeyCode then
            setHidden(not hidden)
        end
    end))
    function Window:SetVisible(v) setHidden(not v) end
    function Window:Toggle()      setHidden(not hidden) end
    function Window:IsVisible()   return not hidden end

    --------------------------------------------------------
    -- Tabs
    --------------------------------------------------------
    function Window:CreateTab(name, icon)
        local Tab = {}

        local tabBtn = Instance.new("TextButton")
        tabBtn.AutomaticSize = Enum.AutomaticSize.X
        tabBtn.Size = UDim2.new(0, 0, 0, 30)
        tabBtn.BackgroundColor3 = theme.TabBackground
        tabBtn.BackgroundTransparency = 0.3
        tabBtn.BorderSizePixel = 0
        tabBtn.Text = ""
        tabBtn.AutoButtonColor = false
        tabBtn.Parent = TabScroll
        corner(tabBtn, UDim.new(0, 6))
        local tabStroke = stroke(tabBtn, theme.ElementStroke, 1, 0.5)
        padding(tabBtn, 0, 0, 12, 12)
        local tabBtnLayout = listLayout(tabBtn, Enum.FillDirection.Horizontal, 6)
        tabBtnLayout.VerticalAlignment = Enum.VerticalAlignment.Center

        local tabIcon
        if icon and icon ~= "" and icon ~= 0 then
            tabIcon = Instance.new("ImageLabel")
            tabIcon.Size = UDim2.new(0, 16, 0, 16)
            tabIcon.BackgroundTransparency = 1
            tabIcon.Image = tostring(icon)
            tabIcon.ImageColor3 = theme.SubText
            tabIcon.LayoutOrder = 1
            tabIcon.Parent = tabBtn
        end

        local tabLabel = Instance.new("TextLabel")
        tabLabel.AutomaticSize = Enum.AutomaticSize.X
        tabLabel.Size = UDim2.new(0, 0, 1, 0)
        tabLabel.BackgroundTransparency = 1
        tabLabel.Font = FONT
        tabLabel.Text = name or "Tab"
        tabLabel.TextSize = 13
        tabLabel.TextColor3 = theme.SubText
        tabLabel.LayoutOrder = 2
        tabLabel.Parent = tabBtn

        local page = Instance.new("ScrollingFrame")
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.BorderSizePixel = 0
        page.CanvasSize = UDim2.new(0, 0, 0, 0)
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        page.ScrollBarThickness = 3
        page.ScrollBarImageColor3 = theme.SubText
        page.ScrollBarImageTransparency = 0.6
        page.Visible = false
        page.Parent = Content
        listLayout(page, Enum.FillDirection.Vertical, 6)
        padding(page, 10, 14, 14, 14)

        local function select()
            for _, t in ipairs(Window._tabs) do
                t._btn.BackgroundColor3 = theme.TabBackground
                t._btn.BackgroundTransparency = 0.3
                t._label.TextColor3 = theme.SubText
                if t._icon then t._icon.ImageColor3 = theme.SubText end
                t._page.Visible = false
                t._stroke.Transparency = 0.5
            end
            tabBtn.BackgroundColor3 = theme.TabSelected
            tabBtn.BackgroundTransparency = 0
            tabLabel.TextColor3 = theme.Text
            if tabIcon then tabIcon.ImageColor3 = theme.Text end
            page.Visible = true
            tabStroke.Transparency = 0.2
            Window._activeTab = Tab
        end
        track(tabBtn.MouseButton1Click:Connect(select))

        Tab._btn    = tabBtn
        Tab._page   = page
        Tab._label  = tabLabel
        Tab._icon   = tabIcon
        Tab._stroke = tabStroke
        table.insert(Window._tabs, Tab)
        if #Window._tabs == 1 then select() end

        onTheme(function(nt)
            tabStroke.Color = nt.ElementStroke
            page.ScrollBarImageColor3 = nt.SubText
            if Window._activeTab == Tab then
                tabBtn.BackgroundColor3 = nt.TabSelected
                tabLabel.TextColor3 = nt.Text
                if tabIcon then tabIcon.ImageColor3 = nt.Text end
            else
                tabBtn.BackgroundColor3 = nt.TabBackground
                tabLabel.TextColor3 = nt.SubText
                if tabIcon then tabIcon.ImageColor3 = nt.SubText end
            end
        end)

        ----------------------------------------------------
        -- Row helper (hover row used by most elements)
        ----------------------------------------------------
        local function makeRow(height)
            local f = Instance.new("Frame")
            f.Size = UDim2.new(1, 0, 0, height or 38)
            f.BackgroundColor3 = Window._theme.Element
            f.BorderSizePixel = 0
            f.Parent = page
            corner(f, UDim.new(0, 6))
            local s = stroke(f, Window._theme.ElementStroke, 1, 0.4)
            track(f.MouseEnter:Connect(function()
                tween(f, TWEEN_FAST, { BackgroundColor3 = Window._theme.ElementHover })
            end))
            track(f.MouseLeave:Connect(function()
                tween(f, TWEEN_FAST, { BackgroundColor3 = Window._theme.Element })
            end))
