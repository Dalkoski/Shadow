		Color3.fromRGB(244, 114, 182),
	}
	local cIdx = 1

	button.MouseButton1Click:Connect(function()
		cIdx = cIdx % #presetColors + 1
		elem._current = presetColors[cIdx]
		swatch.BackgroundColor3 = elem._current
		if elem._callback then
			task.spawn(pcall, elem._callback, elem._current)
		end
		if elem._flag and window._configSave.Enabled then
			window:SaveConfig()
		end
	end)

	elem._frame = frame
	elem._update = function(value)
		elem._current = value
		swatch.BackgroundColor3 = value
	end
end

VaenHub._ElementBuilders.SectionToggle = function(self, elem)
	-- A section header with a master toggle
	local theme = elem._window._theme

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1, 0, 0, 30)
	frame.BackgroundTransparency = 1
	frame.Parent = elem._tab._page

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -44, 1, 0)
	label.Position = UDim2.fromOffset(4, 0)
	label.BackgroundTransparency = 1
	label.Text = elem._name
	label.Font = Enum.Font.GothamBold
	label.TextSize = 11
	label.TextColor3 = theme.TextDim
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = frame

	local switch = Instance.new("Frame")
	switch.Size = UDim2.fromOffset(28, 14)
	switch.Position = UDim2.new(1, -32, 0.5, -7)
	switch.BackgroundColor3 = theme.ElementHover
	switch.BorderSizePixel = 0
	switch.Parent = frame

	makeCorner(switch, 7)

	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.fromOffset(10, 10)
	thumb.Position = UDim2.new(0, 2, 0.5, -5)
	thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	thumb.BorderSizePixel = 0
	thumb.Parent = switch

	makeCorner(thumb, 5)

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.fromScale(1, 1)
	btn.BackgroundTransparency = 1
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.Parent = frame

	btn.MouseButton1Click:Connect(function()
		elem._current = not elem._current
		tween(thumb, 0.25, {Position = elem._current and UDim2.new(0, 16, 0.5, -5) or UDim2.new(0, 2, 0.5, -5)})
		switch.BackgroundColor3 = elem._current and theme.Accent[1] or theme.ElementHover
		if elem._callback then
			task.spawn(pcall, elem._callback, elem._current)
		end
	end)

	elem._frame = frame
end

function VaenHub:_UpdateElement(elem, value)
	if elem._update then elem._update(value) end
end

function VaenHub:_SetElementEnabled(elem, enabled)
	if elem._frame then
		for _, descendant in ipairs(elem._frame:GetDescendants()) do
			if descendant:IsA("TextLabel") or descendant:IsA("TextBox") or descendant:IsA("TextButton") then
				descendant.TextTransparency = enabled and 0 or 0.6
			end
		end
	end
end


--==============================================================
-- NOTIFICATIONS
--==============================================================
VaenHub._notifQueue = {}
VaenHub._notifActive = 0
VaenHub._notifContainer = nil

function VaenHub:_QueueNotification(data)
	if not self._notifContainer then self:_CreateNotifContainer() end
	if self._notifActive >= 4 then
		table.insert(self._notifQueue, data)
		return
	end
	self:_ShowNotification(data)
end

function VaenHub:_CreateNotifContainer()
	local gui = Instance.new("ScreenGui")
	gui.Name = "VaenHubNotifs_" .. HttpService:GenerateGUID(false):sub(1, 6)
	gui.IgnoreGuiInset = true
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.DisplayOrder = 200

	if gethui then
		gui.Parent = gethui()
	else
		gui.Parent = CoreGui
	end

	local container = Instance.new("Frame")
	container.AnchorPoint = Vector2.new(1, 1)
	container.Position = UDim2.new(1, -20, 1, -20)
	container.Size = UDim2.fromOffset(320, 400)
	container.BackgroundTransparency = 1
	container.Parent = gui

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 8)
	layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Right
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = container

	self._notifContainer = container
end

function VaenHub:_ShowNotification(data)
	self._notifActive = self._notifActive + 1
	local theme = self.Presets.Phantom -- notifications use default theme

	local notif = Instance.new("Frame")
	notif.Size = UDim2.new(1, 0, 0, 60)
	notif.BackgroundColor3 = theme.ElementBg
	notif.BackgroundTransparency = 0
	notif.BorderSizePixel = 0
	notif.Parent = self._notifContainer

	makeCorner(notif, 10)
	makeGradientStroke(notif, theme, 0.85)

	-- Accent stripe
	local stripe = Instance.new("Frame")
	stripe.Size = UDim2.fromOffset(3, 24)
	stripe.Position = UDim2.fromOffset(0, 18)
	stripe.BorderSizePixel = 0
	if data.Type == "success" then stripe.BackgroundColor3 = theme.Success
	elseif data.Type == "warning" then stripe.BackgroundColor3 = theme.Warning
	elseif data.Type == "error" then stripe.BackgroundColor3 = theme.Danger
	else stripe.BackgroundColor3 = theme.Accent[1] end
	stripe.Parent = notif
	makeCorner(stripe, 2)

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -24, 0, 18)
	title.Position = UDim2.fromOffset(14, 8)
	title.BackgroundTransparency = 1
	title.Text = data.Title
	title.Font = Enum.Font.GothamMedium
	title.TextSize = 12
	title.TextColor3 = theme.Text
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = notif

	local content = Instance.new("TextLabel")
	content.Size = UDim2.new(1, -24, 0, 30)
	content.Position = UDim2.fromOffset(14, 26)
	content.BackgroundTransparency = 1
	content.Text = data.Content
	content.Font = Enum.Font.Gotham
	content.TextSize = 11
	content.TextColor3 = theme.TextDim
	content.TextXAlignment = Enum.TextXAlignment.Left
	content.TextYAlignment = Enum.TextYAlignment.Top
	content.TextWrapped = true
	content.Parent = notif

	-- Slide in
	notif.Position = UDim2.new(1, 0, 0, 0)
	tween(notif, 0.4, {Position = UDim2.new(0, 0, 0, 0)})

	task.delay(data.Duration, function()
		tween(notif, 0.4, {BackgroundTransparency = 1})
		tween(title, 0.4, {TextTransparency = 1})
		tween(content, 0.4, {TextTransparency = 1})
		task.wait(0.4)
		notif:Destroy()
		self._notifActive = self._notifActive - 1
		if #self._notifQueue > 0 then
			local nextData = table.remove(self._notifQueue, 1)
			self:_ShowNotification(nextData)
		end
	end)
end


--==============================================================
-- ANIMATION HELPERS (hide/show/minimise)
--==============================================================
function VaenHub:_AnimateHide(window)
	if not window._main then return end
	tween(window._main, 0.4, {Size = UDim2.fromOffset(620, 0)}, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
	for _, descendant in ipairs(window._main:GetDescendants()) do
		if descendant:IsA("TextLabel") or descendant:IsA("TextButton") or descendant:IsA("TextBox") then
			tween(descendant, 0.3, {TextTransparency = 1})
		elseif descendant:IsA("Frame") and descendant.BackgroundTransparency < 1 then
			tween(descendant, 0.3, {BackgroundTransparency = 1})
		end
	end
end

function VaenHub:_AnimateShow(window)
	if not window._main then return end
	-- Reset transparencies
	for _, descendant in ipairs(window._main:GetDescendants()) do
		if descendant:IsA("TextLabel") or descendant:IsA("TextButton") or descendant:IsA("TextBox") then
			descendant.TextTransparency = 0
		end
	end
	tween(window._main, 0.5, {Size = UDim2.fromOffset(620, 400)})
end

function VaenHub:_AnimateMinimise(window, minimised)
	if not window._main then return end
	if minimised then
		tween(window._main, 0.4, {Size = UDim2.fromOffset(620, 44)})
		window._content.Visible = false
		window._tabBar.Visible = false
	else
		window._content.Visible = true
		window._tabBar.Visible = true
		tween(window._main, 0.4, {Size = UDim2.fromOffset(620, 400)})
	end
end


