--==============================================================
-- 9. CONFIG SAVE/LOAD
--==============================================================
function VaenHub:_SaveConfig(win, profile)
	if not (writefile and makefolder) then return end
	local data = {}
	for _, e in ipairs(win._elements) do
		if e._flag then
			if e._type == "ColorPicker" then
				local c = e._current or Color3.new(1,1,1)
				data[e._flag] = {c.R*255, c.G*255, c.B*255}
			else
				data[e._flag] = e._current
			end
		end
	end
	pcall(function()
		if not isfolder("VaenHub") then makefolder("VaenHub") end
		if not isfolder("VaenHub/Configs") then makefolder("VaenHub/Configs") end
		local folder = "VaenHub/Configs/"..(win._configSave.FolderName or win._name)
		if not isfolder(folder) then makefolder(folder) end
		writefile(folder.."/"..profile..".vhc", HttpService:JSONEncode(data))
	end)
end

function VaenHub:_LoadConfig(win, profile)
	if not (readfile and isfile) then return end
	local folder = "VaenHub/Configs/"..(win._configSave.FolderName or win._name)
	local path = folder.."/"..profile..".vhc"
	if not isfile(path) then return end
	local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok or not data then return end
	for _, e in ipairs(win._elements) do
		if e._flag and data[e._flag] ~= nil then
			local v = data[e._flag]
			if e._type == "ColorPicker" and type(v) == "table" then
				v = Color3.fromRGB(v[1], v[2], v[3])
			end
			pcall(function() e:Set(v) end)
		end
	end
end

--==============================================================
-- 10. NOTIFICATIONS
--==============================================================
VaenHub._notifContainer = nil
VaenHub._notifActive = 0
VaenHub._notifQueue = {}

function VaenHub:_QueueNotif(d)
	if not self._notifContainer then self:_MakeNotifContainer() end
	if self._notifActive >= 4 then table.insert(self._notifQueue, d); return end
	self:_ShowNotif(d)
end

function VaenHub:_MakeNotifContainer()
	local g = newInst("ScreenGui", {
		Name = "VHNotif_"..HttpService:GenerateGUID(false):sub(1,6),
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 200,
		ResetOnSpawn = false,
	})
	if gethui then g.Parent = gethui() else g.Parent = CoreGui end
	local c = newInst("Frame", {
		AnchorPoint = Vector2.new(1, 1),
		Position = UDim2.new(1, -20, 1, -20),
		Size = UDim2.fromOffset(300, 400),
		BackgroundTransparency = 1,
	}, g)
	local l = listLayout(c, 8)
	l.VerticalAlignment = Enum.VerticalAlignment.Bottom
	l.HorizontalAlignment = Enum.HorizontalAlignment.Right
	self._notifContainer = c
end

function VaenHub:_ShowNotif(d)
	self._notifActive = self._notifActive + 1
	local n = newInst("Frame", {
		Size = UDim2.new(1, 0, 0, 62),
		BackgroundColor3 = THEME.ElementBg,
		BorderSizePixel = 0,
	}, self._notifContainer)
	corner(n, 10)
	stroke(n, THEME.Border, 0.5)

	local accentColor = THEME.Accent
	if d.Type == "success" then accentColor = THEME.Success
	elseif d.Type == "warning" then accentColor = THEME.Warning
	elseif d.Type == "error" then accentColor = THEME.Danger end

	-- Stripe
	local stripe = newInst("Frame", {
		Size = UDim2.fromOffset(3, 30),
		Position = UDim2.fromOffset(0, 16),
		BackgroundColor3 = accentColor,
		BorderSizePixel = 0,
	}, n)
	corner(stripe, 2)

	local title = newInst("TextLabel", {
		Size = UDim2.new(1, -24, 0, 18),
		Position = UDim2.fromOffset(14, 10),
		BackgroundTransparency = 1,
		Text = d.Title,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, n)

	local content = newInst("TextLabel", {
		Size = UDim2.new(1, -24, 0, 30),
		Position = UDim2.fromOffset(14, 28),
		BackgroundTransparency = 1,
		Text = d.Content,
		Font = Enum.Font.Gotham,
		TextSize = 11,
		TextColor3 = THEME.TextDim,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
	}, n)

	n.Position = UDim2.new(1, 50, 0, 0)
	tween(n, 0.35, {Position = UDim2.fromOffset(0, 0)})

	task.delay(d.Duration, function()
		tween(n, 0.35, {BackgroundTransparency = 1})
		tween(title, 0.35, {TextTransparency = 1})
		tween(content, 0.35, {TextTransparency = 1})
		task.wait(0.35)
		n:Destroy()
		self._notifActive = self._notifActive - 1
		if #self._notifQueue > 0 then self:_ShowNotif(table.remove(self._notifQueue, 1)) end
	end)
end

--==============================================================
-- 11. UTILITIES
--==============================================================
function VaenHub:_MakeDraggable(frame, handle)
	local dragging, dragStart, startPos
	handle.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = i.Position
			startPos = frame.Position
		end
	end)
	handle.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
			local d = i.Position - dragStart
			frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
		end
	end)
end

return VaenHub
