function Library:SetLoaderUrl(url)
    self._loaderUrl = url
end

-- queue_on_teleport hook: after TeleportService:Teleport, the queued code runs on next server
function Library:_armTeleportPersistence(extraInitCode)
    if not exec.queue_on_teleport then return end
    local payload = string.format(
        "repeat task.wait() until game:IsLoaded() and game.Players.LocalPlayer\n"..
        "local ok, err = pcall(function()\n"..
        "    loadstring(game:HttpGet(%q))()\n"..
        "    %s\n"..
        "end)\n"..
        "if not ok then warn('[ExampleHub] reload failed: ' .. tostring(err)) end",
        self._loaderUrl,
        extraInitCode or ""
    )
    pcall(exec.queue_on_teleport, payload)
end

function Library:Rejoin()
    self:_armTeleportPersistence()
    local placeId = game.PlaceId
    local jobId = game.JobId
    pcall(function() TeleportService:TeleportToPlaceInstance(placeId, jobId, LocalPlayer) end)
end

function Library:ServerHop()
    self:_armTeleportPersistence()
    local placeId = game.PlaceId
    -- fetch public server list
    local ok, response = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(
            "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
        ))
    end)
    if not ok or not response or not response.data then
        pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
        return
    end
    local best
    for _, srv in ipairs(response.data) do
        if srv.playing and srv.maxPlayers and srv.id ~= game.JobId and srv.playing < srv.maxPlayers then
            if not best or srv.playing > best.playing then
                best = srv
            end
        end
    end
    if best then
        pcall(function() TeleportService:TeleportToPlaceInstance(placeId, best.id, LocalPlayer) end)
    else
        pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
    end
end

