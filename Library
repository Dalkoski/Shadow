function Window:_SelectTab(tab)
	local theme = self._theme
	for _, t in ipairs(self._tabs) do
		if t == tab then
			t._page.Visible = true
			VaenHub._tween(t._buttonLabel, 0.3, {TextColor3 = Color3.fromRGB(255,255,255)})
			t._buttonGradient.Transparency = NumberSequence.new(0.75)
		else
			t._page.Visible = false
			VaenHub._tween(t._buttonLabel, 0.3, {TextColor3 = theme.TextDim})
			t._buttonGradient.Transparency = NumberSequence.new(1)
		end
	end
	self._currentTab = tab
end

function VaenHub:_NewElement(tab, elemType, name)
	local elem = setmetatable({
		_type        = elemType,
		_name        = name,
		_tab         = tab,
		_window      = tab._window,
		_built       = false,
		_enabled     = true,
		_options     = {},
		_current     = nil,
		_default     = nil,
	}, { __index = self._ElementMeta })

	-- For elements that don't need a callback (Label, Status, Section, Divider, Paragraph)
	-- auto-build them at the next tick
	if elemType == "Label" or elemType == "Status" or elemType == "Section"
		or elemType == "SectionToggle" or elemType == "Divider" or elemType == "Paragraph" then
		task.defer(function()
			if not elem._built then
				self:_MaterializeElement(elem)
			end
		end)
	end

	return elem
end

function VaenHub:_MaterializeElement(elem)
	if elem._built then return end
	elem._built = true

	local builder = self._ElementBuilders[elem._type]
	if builder then
		builder(self, elem)
		table.insert(elem._window._elements, elem)
	end
end

