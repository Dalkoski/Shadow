local Window = {}
Window.__index = Window

function Library:CreateWindow(opts)
    opts = opts or {}

    if opts.KeySystem and opts.KeySettings then
        local done, passed = false, false
        Library:_promptKey(opts.KeySettings,
            function() passed = true; done = true end,
            function() done = true end)
        repeat task.wait() until done
        if not passed then return nil end
    end

    local self = setmetatable({}, Window)
    self._lib = Library
    self.Name      = opts.Name or "Example"
    self.Subtitle  = opts.Subtitle or "v1.0"
    self.LogoText  = opts.LogoText or string.sub(self.Name, 1, 1):upper()
    self.Tabs      = {}
    self.ActiveTab = nil
    self.Config    = opts.ConfigurationSaving or { Enabled = false }
    self.Flags     = {}
    self._destroyed = false
    if self.Config.Enabled then
        self.Config.FolderName = self.Config.FolderName or "ExampleHub"
        self.Config.FileName   = self.Config.FileName or "Default"
        safeMkdir(self.Config.FolderName)
        safeMkdir(self.Config.FolderName .. "/Configs")
    end

    local existing = CoreGui:FindFirstChild("ExampleHub_" .. self.Name)
    if existing then existing:Destroy() end
    local gui = new("ScreenGui", {
        Name = "ExampleHub_" .. self.Name, ResetOnSpawn = false,
        IgnoreGuiInset = true, ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
