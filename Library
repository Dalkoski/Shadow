local function tween(obj, time, props, style, dir)
	style = style or Enum.EasingStyle.Quart
	dir   = dir or Enum.EasingDirection.Out
	local t = TweenService:Create(obj, TweenInfo.new(time, style, dir), props)
	t:Play()
	return t
end

local function tweenAsync(obj, time, props, style, dir)
	local t = tween(obj, time, props, style, dir)
	t.Completed:Wait()
end

VaenHub._tween = tween
VaenHub._tweenAsync = tweenAsync


