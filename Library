--==============================================================
-- STATUS BAR (window-level, optional)
--==============================================================
function Window:SetStatus(opts)
    opts = opts or {}
    local label = opts.Label or "Idle"
    local counter = opts.Counter
    local counterLbl = opts.CounterLabel or "COLLECTED"
    local accent = opts.Accent or COLOR.Success

    if self._statusBar then
        if self._statusBarPulse then self._statusBarPulse:Cancel() end
        self._statusBar:Destroy()
    end

    -- Status bar sits at bottom of content panel, above all tabs
    local row = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 1),
        Position = UDim2.new(0.5, 0, 1, -2),
        Size = UDim2.new(1, -32, 0, 46),
        BackgroundColor3 = accent,
        BackgroundTransparency = 1 - 0.07,
        BorderSizePixel = 0,
        ZIndex = 8,
    }, self.Content)
    corner(row, 10)
    stroke(row, accent, 1 - 0.2, 1)
    self._statusBar = row

    local pulse = new("ImageLabel", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 16, 0.5, 0),
        Size = UDim2.fromOffset(20, 20),
        BackgroundTransparency = 1,
        Image = GLOW_ASSET,
        ImageColor3 = accent,
        ImageTransparency = 0.3,
        ZIndex = 8,
    }, row)
    local dot = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 16, 0.5, 0),
        Size = UDim2.fromOffset(8, 8),
        BackgroundColor3 = accent,
        BorderSizePixel = 0,
        ZIndex = 9,
    }, row)
    corner(dot, 4)

    task.spawn(function()
        while pulse.Parent do
            pulse.Size = UDim2.fromOffset(20, 20)
            pulse.ImageTransparency = 0.3
            local tw = TweenService:Create(pulse, TweenInfo.new(1.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.fromOffset(46, 46), ImageTransparency = 1,
            })
            tw:Play()
            tw.Completed:Wait()
            if not pulse.Parent then break end
        end
    end)

    new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 36, 0.5, -8),
        Size = UDim2.fromOffset(120, 12),
        BackgroundTransparency = 1,
        Text = "STATUS",
        Font = Enum.Font.GothamMedium,
        TextSize = 9,
        TextColor3 = Color3.fromRGB(255,255,255),
        TextTransparency = whiteAlpha(0.45),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 9,
    }, row)
    local labelLbl = new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 36, 0.5, 7),
        Size = UDim2.fromOffset(220, 14),
        BackgroundTransparency = 1,
        Text = label,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = COLOR.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 9,
    }, row)

    local counterLblLbl, counterValLbl
    if counter ~= nil then
        counterValLbl = new("TextLabel", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -13, 0.5, -7),
            Size = UDim2.fromOffset(120, 18),
            BackgroundTransparency = 1,
            Text = tostring(counter),
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            TextColor3 = COLOR.TextPrimary,
            TextXAlignment = Enum.TextXAlignment.Right,
            ZIndex = 9,
        }, row)
        counterLblLbl = new("TextLabel", {
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -13, 0.5, 8),
            Size = UDim2.fromOffset(120, 11),
            BackgroundTransparency = 1,
            Text = counterLbl,
            Font = Enum.Font.GothamMedium,
            TextSize = 8,
            TextColor3 = Color3.fromRGB(255,255,255),
            TextTransparency = whiteAlpha(0.4),
            TextXAlignment = Enum.TextXAlignment.Right,
            ZIndex = 9,
        }, row)
    end

    -- Pad bottom of all panels so status doesn't cover content
    for _, t in ipairs(self.Tabs) do
        t.Panel.CanvasSize = UDim2.new(0, 0, 0, 0)
    end

    return {
        SetLabel = function(_, t) labelLbl.Text = t end,
        SetCounter = function(_, v) if counterValLbl then counterValLbl.Text = tostring(v) end end,
        SetAccent = function(_, c)
            row.BackgroundColor3 = c
            row:FindFirstChildOfClass("UIStroke").Color = c
            dot.BackgroundColor3 = c
            pulse.ImageColor3 = c
        end,
        Destroy = function() row:Destroy() end,
    }
end

--==============================================================
-- CONFIG SAVE / LOAD
--==============================================================
function Window:SaveConfig()
    if not self.Config.Enabled then return end
    if self._loadingConfig then return end -- prevent save during load
    local data = {}
    for flag, value in pairs(self.Flags) do
        if typeof(value) == "Color3" then
            data[flag] = { _t = "Color3", r = value.R, g = value.G, b = value.B }
        else
            data[flag] = value
        end
    end
    local path = self.Config.FolderName .. "/Configs/" .. self.Config.FileName .. ".json"
    safeWrite(path, HttpService:JSONEncode(data))
end

function Window:LoadConfig()
    if not self.Config.Enabled then return end
    local path = self.Config.FolderName .. "/Configs/" .. self.Config.FileName .. ".json"
    local raw = safeRead(path)
    if not raw then return end
    local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok or type(data) ~= "table" then return end
    self._loadingConfig = true
    for flag, value in pairs(data) do
        local element = Library.Flags[flag]
        if element and element.Set then
            if type(value) == "table" and value._t == "Color3" then
                pcall(function() element:Set(Color3.new(value.r, value.g, value.b)) end)
            else
                pcall(function() element:Set(value) end)
            end
        end
    end
    self._loadingConfig = false
end

return Library
