-- DROPDOWN (with expand animation)
VaenHub._ElementBuilders.Dropdown = function(self, elem)
	local theme = elem._window._theme
	elem._options = elem._options or {}
	if type(elem._current) ~= "table" then
		elem._current = elem._default or {}
		if type(elem._current) == "string" then elem._current = {elem._current} end
	end

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1, 0, 0, 40)
	frame.BackgroundColor3 = theme.ElementBg
	frame.BorderSizePixel = 0
	frame.ClipsDescendants = true
	frame.Parent = elem._tab._page
	corner(frame, 8)
	stroke(frame, Color3.fromRGB(255,255,255), 0.94)

	local headerHeight = 40

	local iconImg, labelX = addRowIcon(frame, elem._icon, theme)

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.fromOffset(120, headerHeight)
	lbl.Position = UDim2.fromOffset(labelX, 0)
	lbl.BackgroundTransparency = 1
