function VaenHub:_ResolveTheme(input)
	-- String preset
	if type(input) == "string" then
		return self.Presets[input] or self.Presets.Phantom
	end
	-- Custom table (merge with Phantom defaults)
	if type(input) == "table" then
		local merged = {}
		for k, v in pairs(self.Presets.Phantom) do merged[k] = v end
		for k, v in pairs(input) do merged[k] = v end
		return merged
	end
	return self.Presets.Phantom
end

function VaenHub:_ResolveKeybinds(input)
	local defaults = {
		Toggle = "K",
		Panic  = "P",
	}
	if type(input) == "table" then
		for k, v in pairs(input) do defaults[k] = v end
	end
	return defaults
end

function VaenHub:_ApplyTheme(window)
	if not window._gui then return end
	local theme = window._theme

	-- Walk all themed elements and update
	for _, descendant in ipairs(window._gui:GetDescendants()) do
		local role = descendant:GetAttribute("ThemeRole")
		if role and theme[role] then
			if descendant:IsA("Frame") or descendant:IsA("TextButton") then
				if typeof(theme[role]) == "Color3" then
					descendant.BackgroundColor3 = theme[role]
				end
			elseif descendant:IsA("TextLabel") or descendant:IsA("TextBox") then
				descendant.TextColor3 = theme[role]
			elseif descendant:IsA("UIStroke") then
				descendant.Color = theme[role]
			elseif descendant:IsA("UIGradient") and role == "Accent" then
				descendant.Color = ColorSequence.new{
					ColorSequenceKeypoint.new(0, theme.Accent[1]),
					ColorSequenceKeypoint.new(1, theme.Accent[2]),
				}
			end
		end
	end
end


