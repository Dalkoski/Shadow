        Name = "ShowPrompt", AnchorPoint = Vector2.new(0.5, 0),
        Position = UDim2.new(0.5, 0, 0, 20), Size = UDim2.fromOffset(120, 30),
        BackgroundColor3 = COLOR.BgDeep, BackgroundTransparency = 0.3,
        BorderSizePixel = 0, Text = "Show " .. self.Name,
        Font = Enum.Font.GothamMedium, TextSize = 11, TextColor3 = COLOR.TextPrimary,
        TextTransparency = 0.3, AutoButtonColor = false, Visible = false, ZIndex = 50,
    }, gui)
    corner(mobilePrompt, 10)
    stroke(mobilePrompt, Color3.fromRGB(255,255,255), wA(0.1), 1)
    mobilePrompt.MouseButton1Click:Connect(function() self:SetVisibility(true) end)
    self._mobilePrompt = mobilePrompt

    local dragGui = new("ScreenGui", {
        Name = LIBRARY_CONFIG.StealthMode and randName(12) or "Library_DragBar",
        ResetOnSpawn = false, IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling, DisplayOrder = 1001,
    })
    safeParent(dragGui)
    self._dragGui = dragGui

    local dragBar = new("Frame", {
        Name = "DragBar", AnchorPoint = Vector2.new(0.5, 0),
        Size = UDim2.fromOffset(240, 14),
        BackgroundColor3 = Color3.fromRGB(255, 40, 40),
        BackgroundTransparency = 0, BorderSizePixel = 0,
        Visible = true,
    }, dragGui)
    corner(dragBar, 4)
    stroke(dragBar, Color3.fromRGB(255, 255, 255), 0, 2)
    local dragHit = new("TextButton", {
        AnchorPoint = Vector2.new(0.5, 0), Position = UDim2.new(0.5, 0, 0, -4),
        Size = UDim2.fromOffset(260, 28), BackgroundTransparency = 1,
        Text = "", AutoButtonColor = false,
    }, dragBar)
    self._dragBar = dragBar
    local BAR_GAP = 30
    local debugPrinted = false
    local function updateBarPos()
        if not window or not window.Parent then return end
        local p = window.AbsolutePosition
        local s = window.AbsoluteSize
        local targetX = math.floor(p.X + s.X / 2)
        local targetY = math.floor(p.Y + s.Y + BAR_GAP)
        dragBar.Position = UDim2.fromOffset(targetX, targetY)
        if not debugPrinted and s.X > 100 and s.Y > 100 then
            debugPrinted = true
            print(string.format(
                "[Library] DragBar pos=(%d,%d)  window bottom=(%d,%d)  size=(%d,%d)  gap=%d",
                targetX, targetY, math.floor(p.X), math.floor(p.Y + s.Y),
                math.floor(s.X), math.floor(s.Y), BAR_GAP
            ))
        end
    end
    window:GetPropertyChangedSignal("AbsolutePosition"):Connect(updateBarPos)
    window:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateBarPos)
    local barConn
    barConn = RunService.Heartbeat:Connect(function()
        if not window or not window.Parent or self._destroyed then
            if barConn then barConn:Disconnect(); barConn = nil end
            return
        end
        updateBarPos()
    end)
    local barRSConn
    barRSConn = RunService.RenderStepped:Connect(function()
        if not window or not window.Parent or self._destroyed then
            if barRSConn then barRSConn:Disconnect(); barRSConn = nil end
            return
        end
        updateBarPos()
    end)
    self._barConn = barConn
    self._barRSConn = barRSConn
    updateBarPos()
    makeDraggable(window, dragHit, function() return self._hidden end)
    dragHit.MouseEnter:Connect(function()
        tween(dragBar, 0.18, { Size = UDim2.fromOffset(140, 7), BackgroundTransparency = 0.18 })
    end)
    dragHit.MouseLeave:Connect(function()
        tween(dragBar, 0.22, { Size = UDim2.fromOffset(120, 6), BackgroundTransparency = 0.4 })
    end)
    dragHit.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            tween(dragBar, 0.15, { Size = UDim2.fromOffset(150, 8), BackgroundTransparency = 0.05 })
            local ended
            ended = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    tween(dragBar, 0.25, { Size = UDim2.fromOffset(120, 6), BackgroundTransparency = 0.4 })
                    ended:Disconnect()
                end
            end)
        end
    end)

    table.insert(Library._windows, self)
    if self.Config.Enabled then self:_preloadConfig() end
    self:_createSettingsTab()

    return self
end

function Window:Minimize()
    if self._minimizing then return end
    self._minimizing = true
    if self._minimized then
        self._minimized = false
        self.Body.Visible = true
        local tw = tween(self.Window, 0.3, { Size = self._normalSize }, Enum.EasingStyle.Quint)
        tw.Completed:Connect(function() self._minimizing = false end)
    else
        self._minimized = true
        local tw = tween(self.Window, 0.3, { Size = UDim2.fromOffset(self._normalSize.X.Offset, 44) }, Enum.EasingStyle.Quint)
        tw.Completed:Connect(function()
            if self._minimized and not self._destroyed then self.Body.Visible = false end
            self._minimizing = false
        end)
    end
end

function Window:Hide()
    if self._hidden then return end
    self._hidden = true
    local w = self.Window
    self._restorePos = self._restorePos or w.Position
    local dur = LIBRARY_CONFIG.HideAnimDuration
    local scale = LIBRARY_CONFIG.HideAnimScale
    local drop = LIBRARY_CONFIG.HideAnimDrop
    local curSize = w.Size
    local mainTween = tween(w, dur, {
        Size = UDim2.fromOffset(curSize.X.Offset * scale, curSize.Y.Offset * scale),
        Position = self._restorePos + UDim2.fromOffset(0, drop),
    }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    if self._glow then tween(self._glow, dur, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) end
    if self._shadow then tween(self._shadow, dur, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) end
    mainTween.Completed:Connect(function()
        if self._hidden and w then w.Visible = false end
    end)
    if self._dragGui then self._dragGui.Enabled = false end
    if self._dragBar then self._dragBar.Visible = false end
    if self._mobilePrompt then self._mobilePrompt.Visible = true end
end

function Window:Unhide()
    if not self._hidden then return end
    self._hidden = false
    if self._minimized then
        self._minimized = false
        if self.Body then self.Body.Visible = true end
    end
    local w = self.Window
    local target = self._currentSize or self._normalSize
    local restorePos = self._restorePos or w.Position
    local scale = LIBRARY_CONFIG.HideAnimScale
    local drop = LIBRARY_CONFIG.HideAnimDrop
    if self._glow then self._glow.BackgroundTransparency = 1 end
    if self._shadow then self._shadow.BackgroundTransparency = 1 end
    w.Visible = true
    w.Size = UDim2.fromOffset(target.X.Offset * scale, target.Y.Offset * scale)
    w.Position = restorePos + UDim2.fromOffset(0, drop)
    tween(w, 0.5, {
        Size = target, Position = restorePos,
    }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    if self._glow then tween(self._glow, 0.5, { BackgroundTransparency = 0 }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) end
    if self._shadow then tween(self._shadow, 0.5, { BackgroundTransparency = 0 }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) end
    self._restorePos = nil
    if self._dragGui then self._dragGui.Enabled = true end
    if self._dragBar then self._dragBar.Visible = true end
    if self._mobilePrompt then self._mobilePrompt.Visible = false end
end

function Window:SetVisibility(v)
    if v then self:Unhide() else self:Hide() end
end

function Window:IsVisible()
    return not self._hidden and (not self._destroyed)
end

function Window:Destroy()
    if self._destroyed then return end
    self._destroyed = true
    if not self.Window or not self.Gui then return end
    local w = self.Window
    local dur = 0.5
    local absSize = w.AbsoluteSize
    local absPos = w.AbsolutePosition
    if w.AnchorPoint ~= Vector2.new(0.5, 0.5) then
        w.AnchorPoint = Vector2.new(0.5, 0.5)
        w.Position = UDim2.fromOffset(absPos.X + absSize.X / 2, absPos.Y + absSize.Y / 2)
    end
    if self._dragBar then
        tween(self._dragBar, 0.2, { BackgroundTransparency = 1, Size = UDim2.fromOffset(60, 3) })
    end
    if self._dragGui then
        task.delay(0.3, function() if self._dragGui then self._dragGui:Destroy() end end)
    end
    local mainTween = tween(w, dur, {
        Size = UDim2.fromOffset(absSize.X * 0.7, absSize.Y * 0.7),
        BackgroundTransparency = 1,
    }, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    if self._glow then tween(self._glow, dur * 0.7, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) end
    if self._shadow then tween(self._shadow, dur * 0.7, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) end
    for _, d in ipairs(w:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox") then
            tween(d, dur * 0.55, { TextTransparency = 1 })
        elseif d:IsA("ImageLabel") or d:IsA("ImageButton") then
            tween(d, dur * 0.55, { ImageTransparency = 1 })
        elseif d:IsA("Frame") or d:IsA("ScrollingFrame") then
            if d.BackgroundTransparency < 1 then
                tween(d, dur * 0.7, { BackgroundTransparency = 1 })
            end
        elseif d:IsA("UIStroke") then
            tween(d, dur * 0.55, { Transparency = 1 })
        end
    end
    mainTween.Completed:Connect(function()
        if self.Gui then self.Gui:Destroy() end
    end)
end

function Window:SetSectionTitle(text)
    if self.SectionTitle then self.SectionTitle.Text = text end
end

function Window:SetLogo(value)
    if not self._logoBox then return end
    local isIcon = type(value) == "string" and (#value > 1 or value:match("^%d+$") or value:sub(1,4) == "http" or value:sub(1,8) == "rbxasset")
    if isIcon or type(value) == "number" then
        if self._logoLabel then self._logoLabel:Destroy(); self._logoLabel = nil end
        if self._logoImg then self._logoImg:Destroy(); self._logoImg = nil end
        self._logoImg = applyIcon(self._logoBox, value, 16, 0.95)
        self.LogoIcon = value
    else
        if self._logoImg then self._logoImg:Destroy(); self._logoImg = nil end
        self.LogoText = tostring(value or "")
        if self._logoLabel then
            self._logoLabel.Text = self.LogoText
        else
            self._logoLabel = new("TextLabel", {
                Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = self.LogoText,
                Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = COLOR.TextPrimary, ZIndex = 4,
            }, self._logoBox)
        end
    end
end

local function isLightTheme()
    local bg = COLOR.BgDeep
    return (bg.R + bg.G + bg.B) / 3 > 0.5
end

function Window:_updateGlowForTheme()
    if not self._glow or not self._shadow then return end
    local light = isLightTheme()
    self._glow.Visible = not light
    self._shadow.Visible = not light
end

function Window:ModifyTheme(name)
    local newTheme
    if type(name) == "string" and THEMES[name] then
        newTheme = THEMES[name]
    elseif type(name) == "table" then
        newTheme = name
    else return end
    for k, v in pairs(newTheme) do COLOR[k] = v end
    self.Window.BackgroundColor3 = COLOR.BgDeep
    self:_updateGlowForTheme()
    local light = isLightTheme()
    for _, d in ipairs(self.Gui:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextBox") then
            if d.TextColor3 == Color3.fromRGB(255,255,255) or d.TextColor3 == Color3.fromRGB(0,0,0)
                or d.TextColor3 == Color3.fromRGB(20,20,22) then
                d.TextColor3 = COLOR.TextPrimary
            end
        elseif d:IsA("UIStroke") then
            if light then
                d.Color = Color3.fromRGB(0, 0, 0)
            else
                d.Color = Color3.fromRGB(255, 255, 255)
            end
        end
    end
end

function Window:_closeSearch()
    if not self._searchFrame or not self._searchFrame.Visible then return end
    local f = self._searchFrame
    if self._searchBox then self._searchBox.Text = "" end
    local mainTween = tween(f, 0.18, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 22) }, Enum.EasingStyle.Quart)
    if self._searchStroke then tween(self._searchStroke, 0.18, { Transparency = 1 }) end
    if self._searchBox then tween(self._searchBox, 0.18, { TextTransparency = 1 }) end
    for _, d in ipairs(f:GetDescendants()) do
        if d:IsA("ImageLabel") then tween(d, 0.18, { ImageTransparency = 1 }) end
    end
    mainTween.Completed:Connect(function() if f then f.Visible = false end end)
    if self.SectionTitle then
        self.SectionTitle.Visible = true
        self.SectionTitle.TextTransparency = 1
        tween(self.SectionTitle, 0.2, { TextTransparency = 0 })
    end
    if self.ActiveTab then
        for _, el in ipairs(self.ActiveTab.Panel:GetChildren()) do
            if el:IsA("GuiObject") and not el:IsA("UIListLayout") then el.Visible = true end
        end
    end
end

function Window:_toggleSearch()
    if self._searchFrame and self._searchFrame.Visible then
        self:_closeSearch()
        return
    end
    if not self._searchFrame then
        local f = new("Frame", {
            Name = "SearchBar",
            Position = UDim2.fromOffset(0, 0),
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundColor3 = Color3.fromRGB(255,255,255),
            BackgroundTransparency = 1,
            BorderSizePixel = 0, ZIndex = 20, Visible = false,
        }, self.Content)
        corner(f, 6)
        local fStroke = stroke(f, Color3.fromRGB(255,255,255), 1, 1)
        local searchIcon = new("Frame", {
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 10, 0.5, 0),
            Size = UDim2.fromOffset(14, 14), BackgroundTransparency = 1, ZIndex = 21,
        }, f)
        applyIcon(searchIcon, "search", 14, 0.55)
        local box = new("TextBox", {
            Position = UDim2.fromOffset(30, 0), Size = UDim2.new(1, -40, 1, 0),
            BackgroundTransparency = 1, Text = "", TextTransparency = 1,
            PlaceholderText = "Search...", PlaceholderColor3 = Color3.fromRGB(140,140,140),
            Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = COLOR.TextPrimary,
            TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false, ZIndex = 21,
        }, f)
        self._searchFrame = f
        self._searchBox = box
        self._searchStroke = fStroke
        box:GetPropertyChangedSignal("Text"):Connect(function()
            local q = string.lower(box.Text)
            if not self.ActiveTab then return end
            for _, el in ipairs(self.ActiveTab.Panel:GetChildren()) do
                if el:IsA("GuiObject") and not el:IsA("UIListLayout") then
                    if q == "" then el.Visible = true else
                        local found = false
                        for _, d in ipairs(el:GetDescendants()) do
                            if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Text ~= "" then
                                if string.lower(d.Text):find(q, 1, true) then found = true; break end
                            end
                        end
                        el.Visible = found
                    end
                end
            end
        end)
        box.FocusLost:Connect(function(enter)
            if enter and box.Text == "" then self:_closeSearch() end
        end)
    end
    local f = self._searchFrame
    if self.SectionTitle then
        tween(self.SectionTitle, 0.15, { TextTransparency = 1 })
        task.delay(0.15, function()
            if self._searchFrame and self._searchFrame.Visible then
                self.SectionTitle.Visible = false
            end
        end)
    end
    f.Visible = true
    f.BackgroundTransparency = 1
    f.Size = UDim2.new(1, 0, 0, 22)
    self._searchStroke.Transparency = 1
    self._searchBox.TextTransparency = 1
    for _, d in ipairs(f:GetDescendants()) do
        if d:IsA("ImageLabel") then d.ImageTransparency = 1 end
    end
    tween(f, 0.25, { BackgroundTransparency = wA(0.05), Size = UDim2.new(1, 0, 0, 26) }, Enum.EasingStyle.Quart)
    tween(self._searchStroke, 0.25, { Transparency = wA(0.1) })
    tween(self._searchBox, 0.25, { TextTransparency = 0 })
    for _, d in ipairs(f:GetDescendants()) do
        if d:IsA("ImageLabel") then tween(d, 0.25, { ImageTransparency = wA(0.55) }) end
    end
    task.wait(0.05)
    self._searchBox:CaptureFocus()
end

function Window:_createSettingsTab()
    local tab = setmetatable({
        _window = self, _name = "Settings",
        Button = nil, Panel = nil, BtnIcon = nil, BtnLabel = nil, BtnStroke = nil,
        _order = 0, _hidden = true,
    }, Tab)
    local panel = new("ScrollingFrame", {
        Name = "Panel_Settings", Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1, BorderSizePixel = 0,
        ScrollBarThickness = 2, ScrollBarImageColor3 = Color3.fromRGB(255,255,255),
        ScrollBarImageTransparency = 0.85, CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y, Visible = false, ZIndex = 2,
    }, self.PanelContainer)
    local pLayout = listV(panel, 7)
    pLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    tab.Panel = panel
    self._settingsTab = tab

    tab:CreateSection("Notifications")
    tab:CreateToggle({
        Name = "Enable Notifications", Icon = "bell",
        CurrentValue = Library._notifEnabled ~= false,
        Flag = "_ui_notif_enable",
        Callback = function(v) Library._notifEnabled = v end,
    })
    tab:CreateSlider({
        Name = "Duration", Icon = "clock",
        Range = {1, 10}, Increment = 1, Suffix = "s",
        CurrentValue = Library._notifDuration or LIBRARY_CONFIG.NotifDefaultDuration,
        Flag = "_ui_notif_duration",
        Callback = function(v) Library._notifDuration = v end,
    })

    tab:CreateSection("Theme")
    local themeNames = {}
    for n in pairs(THEMES) do table.insert(themeNames, n) end
    table.sort(themeNames)
    tab:CreateDropdown({
        Name = "Theme",
        Icon = "palette",
        Options = themeNames,
        CurrentOption = "Default",
        Flag = "_ui_theme",
        Callback = function(opt) self:ModifyTheme(opt) end,
    })

    tab:CreateSection("Window")
    tab:CreateKeybind({
        Name = "Toggle UI",
        Icon = "keyboard",
        CurrentKeybind = Library.ToggleKey.Name,
        CallOnChange = true,
        Callback = function(k)
            local ok, kc = pcall(function() return Enum.KeyCode[k] end)
            if ok and kc then Library.ToggleKey = kc end
        end,
    })
    tab:CreateButton({
        Name = "Hide UI",
        Icon = "eye-off",
        Callback = function() self:_closeSettings(); self:Hide() end,
    })
    tab:CreateButton({
        Name = "Unload",
        Icon = "log-out",
        Callback = function() self:Destroy() end,
    })

    if self.Config.Enabled then
        local cfg = self.Config
        local configsPath = cfg.FolderName .. "/Configs"
        local autoloadFile = cfg.FolderName .. "/autoload.txt"

        local function listConfigs()
            local list = {}
            if exec.isfolder and exec.isfolder(configsPath) and exec.listfiles then
                local ok, files = pcall(exec.listfiles, configsPath)
                if ok and files then
                    for _, f in ipairs(files) do
                        local n = string.match(f, "([^/\\]+)%.json$")
                        if n then table.insert(list, n) end
                    end
                end
            end
            table.sort(list)
            return list
        end
        local function readAutoload()
            local s = safeRead(autoloadFile)
            if s and s ~= "" then return s end
            return nil
        end

        tab:CreateSection("Configuration")
        local typedName = ""
        tab:CreateInput({
            Name = "Config name", Icon = "file-text",
            PlaceholderText = "MyConfig", CurrentValue = "",
            Callback = function(v) typedName = v end,
        })
        local list = listConfigs()
        local selected = list[1] or "---"
        local dropdown
        tab:CreateButton({
            Name = "Create config", Icon = "plus",
            Callback = function()
                if typedName == "" then
                    Library:Notify({Title = "Empty", Type = "warning", Image = "info", Content = "Enter a name first.", Duration = 2})
                    return
                end
                local orig = cfg.FileName
                cfg.FileName = typedName
                self:SaveConfig()
                cfg.FileName = orig
                Library:Notify({Title = "Created", Type = "success", Image = "check", Content = typedName, Duration = 2})
                list = listConfigs()
                if dropdown then dropdown:Refresh(#list > 0 and list or {"---"}) end
            end,
        })
        tab:CreateDivider()
        dropdown = tab:CreateDropdown({
            Name = "Config list", Icon = "list",
            Options = #list > 0 and list or {"---"},
            CurrentOption = list[1] or "---",
            Callback = function(v) selected = v end,
        })
        tab:CreateButton({
            Name = "Load config", Icon = "download",
            Callback = function()
                if selected == "---" or selected == "" then return end
                cfg.FileName = selected
                self:LoadConfig()
                Library:Notify({Title = "Loaded", Type = "success", Image = "check", Content = selected, Duration = 2})
            end,
        })
        tab:CreateButton({
            Name = "Save current as", Icon = "save",
            Callback = function()
                if selected == "---" or selected == "" then return end
                local orig = cfg.FileName
                cfg.FileName = selected
                self:SaveConfig()
                cfg.FileName = orig
                Library:Notify({Title = "Saved", Type = "success", Image = "check", Content = selected, Duration = 2})
            end,
        })
        tab:CreateButton({
            Name = "Delete config", Icon = "trash-2",
            ConfirmMessage = "Delete the selected config?", ConfirmDanger = true, ConfirmYes = "Delete",
            Callback = function()
                if selected == "---" or selected == "" then return end
                if exec.delfile then pcall(exec.delfile, configsPath .. "/" .. selected .. ".json") end
                Library:Notify({Title = "Deleted", Type = "error", Image = "trash-2", Content = selected, Duration = 2})
                list = listConfigs()
                if dropdown then dropdown:Refresh(#list > 0 and list or {"---"}) end
                selected = list[1] or "---"
            end,
        })
        tab:CreateButton({
            Name = "Refresh list", Icon = "refresh-cw",
            Callback = function()
                list = listConfigs()
                if dropdown then dropdown:Refresh(#list > 0 and list or {"---"}) end
            end,
        })
        local autoloadLabel
        local function renderAutoload()
            local cur = readAutoload()
            local txt = "Autoload: " .. (cur or "none")
            if autoloadLabel then autoloadLabel:Set(txt) end
        end
        tab:CreateButton({
            Name = "Set as autoload", Icon = "pin",
            Callback = function()
                if selected == "---" or selected == "" then return end
                safeWrite(autoloadFile, selected)
                renderAutoload()
                Library:Notify({Title = "Autoload set", Type = "success", Image = "check", Content = selected, Duration = 2})
            end,
        })
        tab:CreateButton({
            Name = "Reset autoload", Icon = "x",
            Callback = function()
                if exec.delfile then pcall(exec.delfile, autoloadFile) end
                renderAutoload()
                Library:Notify({Title = "Autoload reset", Type = "info", Image = "info", Duration = 2})
            end,
        })
        autoloadLabel = tab:CreateLabel("Autoload: " .. (readAutoload() or "none"))
    end
end

function Window:_openSettings()
    if not self._settingsTab then return end
    self:_closeSearch()
    self._previousTab = self.ActiveTab
    self:_showTab(self._settingsTab, "Settings")
end

function Window:_closeSettings()
    if self._previousTab then
        self:SetActiveTab(self._previousTab)
        self._previousTab = nil
    end
end

function Window:_showTab(tab, title)
    for _, t in ipairs(self.Tabs) do
        t.Panel.Visible = false
        tween(t.Button, 0.2, { BackgroundTransparency = wA(0.02) })
        tween(t.BtnStroke, 0.2, { Transparency = wA(0.04) })
        if t.BtnIcon then
            if t.BtnIcon:IsA("ImageLabel") then tween(t.BtnIcon, 0.2, { ImageTransparency = wA(0.5) })
            else tween(t.BtnIcon, 0.2, { TextTransparency = wA(0.5) }) end
        end
        tween(t.BtnLabel, 0.2, { TextTransparency = wA(0.5) })
    end
    if self._settingsTab then self._settingsTab.Panel.Visible = false end
    tab.Panel.Visible = true
    tab.Panel.Position = UDim2.fromOffset(0, 8)
    tween(tab.Panel, 0.3, { Position = UDim2.fromOffset(0, 0) }, Enum.EasingStyle.Quart)
    if tab.Button then
        tween(tab.Button, 0.2, { BackgroundTransparency = wA(0.06) })
        tween(tab.BtnStroke, 0.2, { Transparency = wA(0.08) })
        if tab.BtnIcon then
            if tab.BtnIcon:IsA("ImageLabel") then tween(tab.BtnIcon, 0.2, { ImageTransparency = 0 })
            else tween(tab.BtnIcon, 0.2, { TextTransparency = 0 }) end
        end
        tween(tab.BtnLabel, 0.2, { TextTransparency = 0 })
    end
    if self.SectionTitle then
        self.SectionTitle.TextTransparency = 1
        self.SectionTitle.Text = title or tab._name
        tween(self.SectionTitle, 0.25, { TextTransparency = 0 })
    end
end

function Window:CreateTab(name, icon)
    local W = self
    local btn = new("TextButton", {
        Name = "Tab_" .. name, Size = UDim2.new(1, 0, 0, 28),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.02), BorderSizePixel = 0,
        Text = "", AutoButtonColor = false, LayoutOrder = #W.Tabs + 1, ZIndex = 2,
    }, W.TabList)
    corner(btn, 7)
    local btnStroke = stroke(btn, Color3.fromRGB(255,255,255), wA(0.04), 1)
    local iconHolder = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 4, 0.5, 0),
        Size = UDim2.fromOffset(20, 20), BackgroundTransparency = 1, ZIndex = 3,
    }, btn)
    local btnIcon
    if icon and icon ~= "" then btnIcon = applyIcon(iconHolder, icon, 13, 0.5) end
    local btnLabel = new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 32, 0.5, 0),
        Size = UDim2.new(1, -42, 1, 0), BackgroundTransparency = 1,
        Text = name, Font = Enum.Font.GothamMedium, TextSize = 12,
        TextColor3 = Color3.fromRGB(255,255,255), TextTransparency = wA(0.5),
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 3,
    }, btn)
    local panel = new("ScrollingFrame", {
        Name = "Panel_" .. name, Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1, BorderSizePixel = 0,
        ScrollBarThickness = 2, ScrollBarImageColor3 = Color3.fromRGB(255,255,255),
        ScrollBarImageTransparency = 0.85, CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y, Visible = false, ZIndex = 2,
    }, W.PanelContainer)
    local pLayout = listV(panel, 7)
    pLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left

    local tab = setmetatable({
        _window = W, _name = name,
        Button = btn, Panel = panel, BtnIcon = btnIcon,
        BtnLabel = btnLabel, BtnStroke = btnStroke,
        _order = 0,
    }, Tab)
    btn.MouseEnter:Connect(function()
        if W.ActiveTab ~= tab then tween(btn, 0.15, { BackgroundTransparency = wA(0.04) }) end
    end)
    btn.MouseLeave:Connect(function()
        if W.ActiveTab ~= tab then tween(btn, 0.15, { BackgroundTransparency = wA(0.02) }) end
    end)
    btn.MouseButton1Click:Connect(function()
        W._previousTab = nil
        W:SetActiveTab(tab)
    end)
    table.insert(W.Tabs, tab)
    if #W.Tabs == 1 then W:SetActiveTab(tab) end
    return tab
end

function Window:SetActiveTab(tab)
    self:_closeSearch()
    self.ActiveTab = tab
    self:_showTab(tab, tab._name)
end

