------------------------------------------------------------
-- Helpers
------------------------------------------------------------
local function tween(obj, info, props)
    local ok, t = pcall(TweenService.Create, TweenService, obj, info, props)
    if ok and t then
        t:Play()
        return t
    end
end

local function corner(parent, rad)
    local c = Instance.new("UICorner")
    c.CornerRadius = rad or UDim.new(0, 6)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Color           = color or Color3.fromRGB(40, 40, 44)
    s.Thickness       = thickness or 1
    s.Transparency    = transparency or 0
    s.Parent          = parent
    return s
end

local function padding(parent, t, b, l, r)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, t or 0)
    p.PaddingBottom = UDim.new(0, b or t or 0)
    p.PaddingLeft   = UDim.new(0, l or t or 0)
    p.PaddingRight  = UDim.new(0, r or t or 0)
    p.Parent        = parent
    return p
end

local function listLayout(parent, dir, padPx, sortOrder)
    local l = Instance.new("UIListLayout")
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.SortOrder     = sortOrder or Enum.SortOrder.LayoutOrder
    l.Padding       = UDim.new(0, padPx or 0)
    l.Parent        = parent
    return l
end

local function safeParent(gui)
    local protect = (syn and syn.protect_gui) or (protect_gui)
    if protect then
        pcall(protect, gui)
    end
    local target
    if gethui then
        local ok, h = pcall(gethui); if ok then target = h end
    end
    if not target then
        local ok = pcall(function() return CoreGui:GetChildren() end)
        if ok then target = CoreGui end
    end
    if not target then
        target = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui")
    end
    gui.Parent = target
end

