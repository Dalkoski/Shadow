-- 6. KEY SYSTEM (full-screen blur + glass card)
--==============================================================

function VaenHub:_RunKeySystem(window)
	local keySettings = window._keySystem
	local theme = window._theme

	-- Check for saved key first
	if keySettings.SaveKey and writefile and isfile then
		local savedKey = self:_LoadSavedKey(keySettings)
		if savedKey then
			for _, validKey in ipairs(keySettings.Keys or {}) do
				if savedKey == validKey then
					return true
				end
			end
		end
	end

	-- Build the key UI
	local keyGui = Instance.new("ScreenGui")
	keyGui.Name = HttpService:GenerateGUID(false):sub(1, 8)
	keyGui.IgnoreGuiInset = true
	keyGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	keyGui.DisplayOrder = 999

	-- Apply protection
	if gethui then
		keyGui.Parent = gethui()
	elseif syn and syn.protect_gui then
		syn.protect_gui(keyGui)
		keyGui.Parent = CoreGui
	else
		keyGui.Parent = CoreGui
	end

	-- Full screen blur via Lighting
	local blur = Instance.new("BlurEffect")
	blur.Size = 0
	blur.Parent = Lighting
	TweenService:Create(blur, TweenInfo.new(0.6, Enum.EasingStyle.Quart), {Size = 24}):Play()

	-- Dimming overlay
	local overlay = Instance.new("Frame")
	overlay.Size = UDim2.fromScale(1, 1)
	overlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	overlay.BackgroundTransparency = 1
	overlay.BorderSizePixel = 0
	overlay.Parent = keyGui
	TweenService:Create(overlay, TweenInfo.new(0.6), {BackgroundTransparency = 0.5}):Play()

	-- Glass card
	local card = Instance.new("Frame")
	card.AnchorPoint = Vector2.new(0.5, 0.5)
	card.Position = UDim2.fromScale(0.5, 0.5)
	card.Size = UDim2.new(0, 380, 0, 0)
	card.BackgroundColor3 = theme.Background
	card.BackgroundTransparency = 0.05
	card.BorderSizePixel = 0
	card.Parent = keyGui

	local cardCorner = Instance.new("UICorner")
	cardCorner.CornerRadius = UDim.new(0, 14)
	cardCorner.Parent = card

	local cardStroke = Instance.new("UIStroke")
	cardStroke.Color = Color3.fromRGB(255, 255, 255)
	cardStroke.Transparency = 0.9
	cardStroke.Thickness = 1
	cardStroke.Parent = card

	-- Phantom logo background
	local phantom = Instance.new("TextLabel")
	phantom.Size = UDim2.new(0, 200, 0, 200)
	phantom.AnchorPoint = Vector2.new(1, 1)
	phantom.Position = UDim2.new(1, 20, 1, 20)
	phantom.BackgroundTransparency = 1
	phantom.Text = "V"
	phantom.Font = Enum.Font.GothamBold
	phantom.TextSize = 200
	phantom.TextColor3 = Color3.fromRGB(255, 255, 255)
	phantom.TextTransparency = 0.95
	phantom.TextXAlignment = Enum.TextXAlignment.Right
	phantom.TextYAlignment = Enum.TextYAlignment.Bottom
	phantom.ZIndex = 0
	phantom.Parent = card

	-- Gradient accent on top edge
	local accentBar = Instance.new("Frame")
