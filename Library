function Phantom:Notify(data)
    task.spawn(function()
        local n = Notifications.Template:Clone()
        n.Name = data.Title or "Notification"
        n.Parent = Notifications
        n.LayoutOrder = #Notifications:GetChildren()
        n.Visible = false

        n.Title.Text = data.Title or "Title"
        n.Description.Text = data.Content or ""
        n.Icon.Image = data.Image and ("rbxassetid://" .. tostring(data.Image)) or ""

        n.Title.TextColor3       = SelectedTheme.TextColor
        n.Description.TextColor3 = SelectedTheme.TextColor
        n.BackgroundColor3       = SelectedTheme.Background
        n.UIStroke.Color         = SelectedTheme.TextColor
        n.Icon.ImageColor3       = SelectedTheme.TextColor

        n.BackgroundTransparency = 1
        n.Title.TextTransparency = 1
        n.Description.TextTransparency = 1
        n.UIStroke.Transparency = 1
        n.Shadow.ImageTransparency = 1
        n.Icon.ImageTransparency = 1
        n.Icon.BackgroundTransparency = 1
        n.Size = UDim2.new(1, 0, 0, 800)

        task.wait()
        n.Visible = true

        local bounds = { n.Title.TextBounds.Y, n.Description.TextBounds.Y }
        n.Size = UDim2.new(1, -60, 0, -Notifications:FindFirstChild("UIListLayout").Padding.Offset)
        n.Icon.Size = UDim2.new(0, 32, 0, 32)
        n.Icon.Position = UDim2.new(0, 20, 0.5, 0)

        tween(n, TweenInfo.new(0.6, Enum.EasingStyle.Exponential), {
            Size = UDim2.new(1, 0, 0, math.max(bounds[1] + bounds[2] + 31, 60))
        })
        task.wait(0.15)
        tween(n,             TWEEN_MED, { BackgroundTransparency = 0.45 })
        tween(n.Title,       TWEEN_MED, { TextTransparency = 0 })
        task.wait(0.05)
        tween(n.Icon,        TWEEN_MED, { ImageTransparency = 0 })
        task.wait(0.05)
        tween(n.Description, TWEEN_MED, { TextTransparency = 0.35 })
        tween(n.UIStroke,    TWEEN_MED, { Transparency = 0.95 })
        tween(n.Shadow,      TWEEN_MED, { ImageTransparency = 0.82 })

        local dur = data.Duration or math.clamp((#n.Description.Text * 0.1) + 2.5, 3, 10)
        task.wait(dur)

        n.Icon.Visible = false
        tween(n,             TWEEN_MED, { BackgroundTransparency = 1 })
        tween(n.UIStroke,    TWEEN_MED, { Transparency = 1 })
        tween(n.Shadow,      TWEEN_MED, { ImageTransparency = 1 })
        tween(n.Title,       TWEEN_MED, { TextTransparency = 1 })
        tween(n.Description, TWEEN_MED, { TextTransparency = 1 })
        tween(n, TweenInfo.new(1, Enum.EasingStyle.Exponential), { Size = UDim2.new(1, -90, 0, 0) })
        task.wait(1)
        tween(n, TweenInfo.new(1, Enum.EasingStyle.Exponential), {
            Size = UDim2.new(1, -90, 0, -Notifications:FindFirstChild("UIListLayout").Padding.Offset),
        })
        n.Visible = false
        n:Destroy()
    end)
end

