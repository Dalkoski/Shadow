        function Tab:CreateDropdown(opts)
            opts = opts or {}
            local Dropdown = { Type = "Dropdown", Options = opts.Options or {}, Multi = opts.Multi == true }
            Dropdown.Value = opts.Default
            if Dropdown.Multi and type(Dropdown.Value) ~= "table" then
                Dropdown.Value = Dropdown.Value and { Dropdown.Value } or {}
            end

            local f = new("Frame", {
                Size = UDim2.new(1, 0, 0, 38),
                BackgroundColor3 = theme.Element,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                Parent = page,
            })
            corner(f, ELEMENT_RAD)
            local s = stroke(f, theme.ElementStroke)
            s.Transparency = 0.4

            local header = new("TextButton", {
                Size = UDim2.new(1, 0, 0, 38),
                BackgroundTransparency = 1,
                Text = "",
                AutoButtonColor = false,
                Parent = f,
            })

            local lbl = new("TextLabel", {
                Position = UDim2.new(0, 12, 0, 0),
                Size = UDim2.new(0.5, 0, 1, 0),
                BackgroundTransparency = 1,
                Font = FONT,
                Text = opts.Name or "Dropdown",
                TextSize = 13,
                TextColor3 = theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = header,
            })
            local valLbl = new("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -28, 0.5, 0),
                Size = UDim2.new(0.5, -16, 1, 0),
                BackgroundTransparency = 1,
                Font = FONT,
                Text = "",
                TextSize = 12,
                TextColor3 = theme.SubText,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = header,
            })
            local arrow = new("TextLabel", {
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -10, 0.5, 0),
                Size = UDim2.new(0, 14, 0, 14),
                BackgroundTransparency = 1,
                Font = FONT_BOLD,
                Text = "▾",
                TextSize = 14,
                TextColor3 = theme.SubText,
                Parent = header,
            })

            local list = new("Frame", {
                Position = UDim2.new(0, 0, 0, 38),
                Size = UDim2.new(1, 0, 0, 0),
                BackgroundTransparency = 1,
                Parent = f,
            })
            local listLayout = new("UIListLayout", {
                Padding = UDim.new(0, 2),
                SortOrder = Enum.SortOrder.LayoutOrder,
                Parent = list,
            })
            new("UIPadding", {
                PaddingLeft = UDim.new(0, 8),
                PaddingRight = UDim.new(0, 8),
                PaddingBottom = UDim.new(0, 6),
                Parent = list,
            })

            local function getValueText()
                if Dropdown.Multi then
                    local n = #Dropdown.Value
                    if n == 0 then return "None"
                    elseif n == 1 then return Dropdown.Value[1]
                    else return n .. " selected" end
                else
                    return Dropdown.Value or "None"
                end
            end

            local function isSelected(opt)
                if Dropdown.Multi then
                    for _, v in ipairs(Dropdown.Value) do if v == opt then return true end end
                    return false
                else
                    return Dropdown.Value == opt
                end
            end

            local optButtons = {}
            local function rebuildOptions()
                for _, b in ipairs(optButtons) do b:Destroy() end
                table.clear(optButtons)
                for i, opt in ipairs(Dropdown.Options) do
                    local ob = new("TextButton", {
                        Size = UDim2.new(1, 0, 0, 26),
                        BackgroundColor3 = isSelected(opt) and Window._theme.AccentDim or Window._theme.Element,
                        BorderSizePixel = 0,
                        Font = FONT,
                        Text = opt,
                        TextSize = 12,
                        TextColor3 = Window._theme.Text,
                        AutoButtonColor = false,
                        LayoutOrder = i,
                        Parent = list,
                    })
                    corner(ob, UDim.new(0, 4))
                    table.insert(optButtons, ob)
                    ob.MouseButton1Click:Connect(function()
                        if Dropdown.Multi then
                            local found
                            for idx, v in ipairs(Dropdown.Value) do
                                if v == opt then found = idx; break end
                            end
                            if found then table.remove(Dropdown.Value, found)
                            else table.insert(Dropdown.Value, opt) end
                        else
                            Dropdown.Value = opt
                        end
                        for j, b in ipairs(optButtons) do
                            b.BackgroundColor3 = isSelected(Dropdown.Options[j]) and Window._theme.AccentDim or Window._theme.Element
                        end
                        valLbl.Text = getValueText()
                        if opts.Callback then task.spawn(opts.Callback, Dropdown.Value) end
                    end)
                end
            end
            rebuildOptions()
            valLbl.Text = getValueText()

            local open = false
            header.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    local h = math.min(#Dropdown.Options * 28 + 8, 160)
                    tween(f, TWEEN_MED, { Size = UDim2.new(1, 0, 0, 38 + h) })
                    list.Size = UDim2.new(1, 0, 0, h)
                    tween(arrow, TWEEN_FAST, { Rotation = 180 })
                else
                    tween(f, TWEEN_MED, { Size = UDim2.new(1, 0, 0, 38) })
                    tween(arrow, TWEEN_FAST, { Rotation = 0 })
                end
            end)

            function Dropdown:Set(v)
                if self.Multi then
                    self.Value = type(v) == "table" and v or { v }
                else
                    self.Value = v
                end
                for j, b in ipairs(optButtons) do
                    b.BackgroundColor3 = isSelected(self.Options[j]) and Window._theme.AccentDim or Window._theme.Element
                end
                valLbl.Text = getValueText()
                if opts.Callback then task.spawn(opts.Callback, self.Value) end
            end
            function Dropdown:Refresh(newOpts)
                self.Options = newOpts or {}
                if self.Multi then
                    -- prune values not in new options
                    local kept = {}
                    for _, v in ipairs(self.Value) do
                        for _, o in ipairs(self.Options) do
                            if o == v then table.insert(kept, v); break end
                        end
                    end
                    self.Value = kept
                else
                    local found = false
                    for _, o in ipairs(self.Options) do if o == self.Value then found = true; break end end
                    if not found then self.Value = self.Options[1] end
                end
                rebuildOptions()
                valLbl.Text = getValueText()
            end

            addListener(function(nt)
                f.BackgroundColor3 = nt.Element
                s.Color = nt.ElementStroke
                lbl.TextColor3 = nt.Text
                valLbl.TextColor3 = nt.SubText
                arrow.TextColor3 = nt.SubText
                for j, b in ipairs(optButtons) do
                    b.BackgroundColor3 = isSelected(Dropdown.Options[j]) and nt.AccentDim or nt.Element
                    b.TextColor3 = nt.Text
                end
            end)

            if opts.Flag then Phantom.Flags[opts.Flag] = Dropdown end
            return Dropdown
        end

