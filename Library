-- Reusable row container
local function row(elem, height)
	return newInst("Frame", {
		Size = UDim2.new(1, 0, 0, height or ELEMENT_HEIGHT),
		BackgroundColor3 = THEME.ElementBg,
		BorderSizePixel = 0,
	}, elem._tab._page)
end

local function setupRow(frame)
	corner(frame, CORNER_RADIUS)
	stroke(frame, THEME.Border, 0.7)
	frame.MouseEnter:Connect(function() tween(frame, 0.15, {BackgroundColor3 = THEME.ElementHover}) end)
	frame.MouseLeave:Connect(function() tween(frame, 0.15, {BackgroundColor3 = THEME.ElementBg}) end)
end

-- TOGGLE (purple solid track when on, white thumb, glow ring)
VaenHub._Builders.Toggle = function(self, elem)
	local frame = row(elem)
	setupRow(frame)

	local lbl = newInst("TextLabel", {
		Size = UDim2.new(1, -64, 1, 0),
		Position = UDim2.fromOffset(14, 0),
		BackgroundTransparency = 1,
		Text = elem._name,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, frame)

	-- Track
	local track = newInst("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(34, 18),
		Position = UDim2.new(1, -14, 0.5, 0),
		BackgroundColor3 = THEME.ElementHover,
		BorderSizePixel = 0,
	}, frame)
	corner(track, 9)

	-- Thumb (anchor-based for smooth slide)
	local thumb = newInst("Frame", {
		Size = UDim2.fromOffset(12, 12),
		Position = UDim2.new(0, 3, 0.5, 0),
		AnchorPoint = Vector2.new(0, 0.5),
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BorderSizePixel = 0,
	}, track)
	corner(thumb, 6)

	-- Glow (UIStroke acts as halo)
	local glow = newInst("UIStroke", {
		Color = THEME.Accent,
		Transparency = 1,
		Thickness = 2,
	}, thumb)

	local btn = newInst("TextButton", {
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,
		Text = "",
		AutoButtonColor = false,
	}, frame)

	local function update(v, animate)
		elem._current = v
		local pos = v and UDim2.new(1, -3, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
		local anchor = v and Vector2.new(1, 0.5) or Vector2.new(0, 0.5)
		if animate == false then
			thumb.Position = pos
			thumb.AnchorPoint = anchor
			track.BackgroundColor3 = v and THEME.Accent or THEME.ElementHover
			glow.Transparency = v and 0.5 or 1
		else
			tween(thumb, 0.22, {Position = pos, AnchorPoint = anchor})
			tween(track, 0.22, {BackgroundColor3 = v and THEME.Accent or THEME.ElementHover})
			tween(glow, 0.22, {Transparency = v and 0.5 or 1})
		end
	end

	btn.MouseButton1Click:Connect(function()
		if not elem._enabled then return end
		update(not elem._current)
		if elem._callback then task.spawn(pcall, elem._callback, elem._current) end
		if elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
	end)

	elem._frame = frame
	elem._update = function(v) update(v) end
	update(elem._default == true, false)
end

-- SLIDER (purple fill, white thumb with glow halo)
VaenHub._Builders.Slider = function(self, elem)
	elem._min = elem._min or 0
	elem._max = elem._max or 100
	elem._step = elem._step or 1
	elem._current = elem._default or elem._min

	local frame = row(elem)
	setupRow(frame)

	local lbl = newInst("TextLabel", {
		Size = UDim2.fromOffset(90, ELEMENT_HEIGHT),
		Position = UDim2.fromOffset(14, 0),
		BackgroundTransparency = 1,
		Text = elem._name,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, frame)

	local valText = newInst("TextLabel", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(70, ELEMENT_HEIGHT),
		Position = UDim2.new(1, -14, 0.5, 0),
		BackgroundTransparency = 1,
		Text = tostring(elem._current)..(elem._suffix and (" "..elem._suffix) or ""),
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = THEME.TextDim,
		TextXAlignment = Enum.TextXAlignment.Right,
	}, frame)

	-- Track
	local track = newInst("Frame", {
		AnchorPoint = Vector2.new(0, 0.5),
		Size = UDim2.new(1, -(104 + 84), 0, 4),
		Position = UDim2.new(0, 104, 0.5, 0),
		BackgroundColor3 = THEME.ElementHover,
		BorderSizePixel = 0,
	}, frame)
	corner(track, 2)

	-- Fill
	local fill = newInst("Frame", {
		Size = UDim2.fromScale(0, 1),
		BackgroundColor3 = THEME.Accent,
		BorderSizePixel = 0,
	}, track)
	corner(fill, 2)

	-- Thumb with glow
	local thumb = newInst("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.fromOffset(12, 12),
		Position = UDim2.new(1, 0, 0.5, 0),
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BorderSizePixel = 0,
		ZIndex = 2,
	}, fill)
	corner(thumb, 6)
	newInst("UIStroke", {Color = THEME.Accent, Transparency = 0.4, Thickness = 2}, thumb)

	local dragging = false
	local function setFromX(x)
		local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local raw = elem._min + rel * (elem._max - elem._min)
		local snapped = math.floor(raw / elem._step + 0.5) * elem._step
		snapped = math.clamp(snapped, elem._min, elem._max)
		elem._current = snapped
		local p = (snapped - elem._min) / (elem._max - elem._min)
		fill.Size = UDim2.fromScale(p, 1)
		valText.Text = tostring(snapped)..(elem._suffix and (" "..elem._suffix) or "")
		if elem._callback then task.spawn(pcall, elem._callback, snapped) end
	end

	track.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true; setFromX(i.Position.X)
		end
	end)
	fill.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true; setFromX(i.Position.X)
		end
	end)

	local c1 = UserInputService.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
			setFromX(i.Position.X)
		end
	end)
	local c2 = UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			if dragging and elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
			dragging = false
		end
	end)
	table.insert(elem._window._connections, c1)
	table.insert(elem._window._connections, c2)

	local p0 = (elem._current - elem._min) / (elem._max - elem._min)
	fill.Size = UDim2.fromScale(p0, 1)

	elem._frame = frame
	elem._update = function(v)
		elem._current = v
		local p = (v - elem._min) / (elem._max - elem._min)
		fill.Size = UDim2.fromScale(p, 1)
		valText.Text = tostring(v)..(elem._suffix and (" "..elem._suffix) or "")
	end
end

