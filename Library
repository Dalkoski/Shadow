	end)
	inputBox.FocusLost:Connect(function()
		tween(inputStrokeObj, 0.2, {Color = Color3.fromRGB(255,255,255), Transparency = 0.88})
	end)

	-- Verify button (gradient)
	local verify = Instance.new("TextButton")
	verify.Size = UDim2.new(1, -48, 0, 40)
	verify.Position = UDim2.fromOffset(24, 178)
	verify.BackgroundColor3 = theme.Accent[1]
	verify.BorderSizePixel = 0
	verify.Text = "Verify"
	verify.Font = Enum.Font.GothamMedium
	verify.TextSize = 13
	verify.TextColor3 = Color3.fromRGB(255, 255, 255)
	verify.AutoButtonColor = false
	verify.Parent = card
	corner(verify, 8)
	gradient(verify, theme.Accent, 135)

	-- Close
	local close = Instance.new("TextButton")
	close.Size = UDim2.fromOffset(28, 28)
	close.Position = UDim2.new(1, -38, 0, 12)
	close.BackgroundTransparency = 1
	close.Text = "×"
	close.Font = Enum.Font.GothamBold
	close.TextSize = 22
	close.TextColor3 = theme.TextDim
	close.AutoButtonColor = false
	close.Parent = card

	-- Animate in
	tween(card, 0.5, {Size = UDim2.fromOffset(420, 238)})
	task.wait(0.2)
	tween(title, 0.4, {TextTransparency = 0})
	task.wait(0.05)
	tween(sub, 0.4, {TextTransparency = 0})
	task.wait(0.05)
	tween(note, 0.4, {TextTransparency = 0})

	-- Verify logic
	local result = nil
	local attempts = ks.MaxAttempts or 5
	local function doVerify()
		for _, k in ipairs(ks.Keys or {}) do
			if inputBox.Text == k then
				if ks.SaveKey and writefile then
					pcall(function()
						if not isfolder("VaenHub") then makefolder("VaenHub") end
						if not isfolder("VaenHub/Keys") then makefolder("VaenHub/Keys") end
						writefile("VaenHub/Keys/"..(ks.FileName or "key")..".key", inputBox.Text)
					end)
				end
				result = true
				return
			end
		end
		attempts = attempts - 1
		-- Shake
		local op = card.Position
		for i = 1, 3 do
			card.Position = op + UDim2.fromOffset(8, 0); task.wait(0.04)
			card.Position = op + UDim2.fromOffset(-8, 0); task.wait(0.04)
		end
		card.Position = op
		tween(inputStrokeObj, 0.3, {Color = theme.Danger, Transparency = 0.4})
		task.wait(0.3)
		tween(inputStrokeObj, 0.3, {Color = Color3.fromRGB(255,255,255), Transparency = 0.88})
		inputBox.Text = ""
		if attempts <= 0 then result = false end
	end

	verify.MouseButton1Click:Connect(doVerify)
	inputBox.FocusLost:Connect(function(enter) if enter then doVerify() end end)
	close.MouseButton1Click:Connect(function() result = false end)

	verify.MouseEnter:Connect(function() tween(verify, 0.2, {Size = UDim2.new(1, -44, 0, 40)}) end)
	verify.MouseLeave:Connect(function() tween(verify, 0.2, {Size = UDim2.new(1, -48, 0, 40)}) end)

	while result == nil do task.wait() end

	-- Fade out
	tween(blur, 0.4, {Size = 0})
	tween(dim, 0.4, {BackgroundTransparency = 1})
	tween(card, 0.4, {Size = UDim2.fromOffset(420, 0)}, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
	task.wait(0.45)
	pcall(function() blur:Destroy() end)
	gui:Destroy()
	return result
end

