	}, pill)

	local pillArrow = newInst("TextLabel", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(1, -4, 0.5, 0),
		BackgroundTransparency = 1,
		Text = "v",
		Font = Enum.Font.GothamBold,
		TextSize = 10,
		TextColor3 = THEME.TextDim,
	}, pill)

	-- Options list
	local optsFrame = newInst("Frame", {
		Size = UDim2.new(1, -28, 0, 0),
		Position = UDim2.fromOffset(14, headerH + 4),
		BackgroundTransparency = 1,
	}, frame)
	listLayout(optsFrame, 4)

	local function refreshOptions()
		for _, c in ipairs(optsFrame:GetChildren()) do
			if c:IsA("TextButton") then c:Destroy() end
		end
		for _, opt in ipairs(elem._options) do
			local optBtn = newInst("TextButton", {
				Size = UDim2.new(1, 0, 0, 26),
				BackgroundColor3 = THEME.ElementHover,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
			}, optsFrame)
			corner(optBtn, 6)

			local optLbl = newInst("TextLabel", {
				Size = UDim2.new(1, -16, 1, 0),
				Position = UDim2.fromOffset(10, 0),
				BackgroundTransparency = 1,
				Text = opt,
				Font = Enum.Font.Gotham,
				TextSize = 11,
				TextColor3 = THEME.TextDim,
				TextXAlignment = Enum.TextXAlignment.Left,
			}, optBtn)

			local function refresh()
				local isSel = table.find(elem._current, opt) ~= nil
				if isSel then
					optBtn.BackgroundColor3 = THEME.Accent
					optBtn.BackgroundTransparency = 0.5
					optLbl.TextColor3 = THEME.Text
				else
					optBtn.BackgroundColor3 = THEME.ElementHover
					optBtn.BackgroundTransparency = 0
					optLbl.TextColor3 = THEME.TextDim
				end
			end
			refresh()

			optBtn.MouseButton1Click:Connect(function()
				local idx = table.find(elem._current, opt)
				if elem._multi then
					if idx then table.remove(elem._current, idx)
					else table.insert(elem._current, opt) end
				else
					elem._current = {opt}
				end
				pillText.Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current.." selected")) or "None"
				for _, c in ipairs(optsFrame:GetChildren()) do
					if c:IsA("TextButton") then
						local cl = c:FindFirstChildWhichIsA("TextLabel")
						if cl then
							local isSel = table.find(elem._current, cl.Text) ~= nil
							c.BackgroundColor3 = isSel and THEME.Accent or THEME.ElementHover
							c.BackgroundTransparency = isSel and 0.5 or 0
							cl.TextColor3 = isSel and THEME.Text or THEME.TextDim
						end
					end
				end
				if elem._callback then task.spawn(pcall, elem._callback, elem._current) end
				if elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
			end)
		end
	end
	refreshOptions()

	local clickBtn = newInst("TextButton", {
		Size = UDim2.new(1, 0, 0, headerH),
		BackgroundTransparency = 1,
		Text = "",
		AutoButtonColor = false,
	}, frame)

	local open = false
	clickBtn.MouseButton1Click:Connect(function()
		open = not open
		local total = #elem._options * 30
		if open then
			tween(frame, 0.25, {Size = UDim2.new(1, 0, 0, headerH + total + 12)})
			tween(pillArrow, 0.25, {Rotation = 180})
		else
			tween(frame, 0.25, {Size = UDim2.new(1, 0, 0, headerH)})
			tween(pillArrow, 0.25, {Rotation = 0})
		end
	end)

	elem._frame = frame
	elem._refresh = refreshOptions
	elem._update = function(v)
		elem._current = type(v) == "table" and v or {v}
		pillText.Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current.." selected")) or "None"
		refreshOptions()
	end
end

