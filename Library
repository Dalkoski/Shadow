            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Parent = f

            local valLbl = Instance.new("TextLabel")
            valLbl.AnchorPoint = Vector2.new(1, 0)
            valLbl.Position = UDim2.new(1, -12, 0, 6)
            valLbl.Size = UDim2.new(0, 80, 0, 16)
            valLbl.BackgroundTransparency = 1
            valLbl.Font = FONT
            valLbl.Text = tostring(Slider.Value) .. (suf ~= "" and " " .. suf or "")
            valLbl.TextSize = 12
            valLbl.TextColor3 = Window._theme.SubText
            valLbl.TextXAlignment = Enum.TextXAlignment.Right
            valLbl.Parent = f

            local bar = Instance.new("Frame")
            bar.Position = UDim2.new(0, 12, 1, -14)
            bar.Size = UDim2.new(1, -24, 0, 6)
            bar.BackgroundColor3 = Window._theme.Stroke
            bar.BorderSizePixel = 0
            bar.Parent = f
            corner(bar, UDim.new(1, 0))

            local fill = Instance.new("Frame")
            fill.Size = UDim2.new(0, 0, 1, 0)
            fill.BackgroundColor3 = Window._theme.Accent
            fill.BorderSizePixel = 0
            fill.Parent = bar
            corner(fill, UDim.new(1, 0))

            local function setVal(v, fire)
                v = math.clamp(math.floor((v - min) / inc + 0.5) * inc + min, min, max)
                Slider.Value = v
                local pct = (max == min) and 0 or (v - min) / (max - min)
                tween(fill, TWEEN_FAST, { Size = UDim2.new(pct, 0, 1, 0) })
                valLbl.Text = tostring(v) .. (suf ~= "" and " " .. suf or "")
                if fire and o.Callback then task.spawn(o.Callback, v) end
            end

            local function fromX(x)
                local rel = math.clamp((x - bar.AbsolutePosition.X) / math.max(1, bar.AbsoluteSize.X), 0, 1)
                return min + (max - min) * rel
            end

            local dragging = false
            track(bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    setVal(fromX(input.Position.X), true)
                end
            end))
            track(UserInputService.InputChanged:Connect(function(input)
                if not dragging then return end
                if input.UserInputType == Enum.UserInputType.MouseMovement
                or input.UserInputType == Enum.UserInputType.Touch then
                    setVal(fromX(input.Position.X), true)
                end
            end))
            track(UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end))

            setVal(Slider.Value, false)

            function Slider:Set(v) setVal(v, true) end

            onTheme(function(nt)
                lbl.TextColor3 = nt.Text
                valLbl.TextColor3 = nt.SubText
                bar.BackgroundColor3 = nt.Stroke
                fill.BackgroundColor3 = nt.Accent
            end)

            if o.Flag then Phantom.Flags[o.Flag] = Slider end
            return Slider
        end

