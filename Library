        ----------------------------------------------------
        -- Dropdown
        ----------------------------------------------------
        function Tab:CreateDropdown(o)
            o = o or {}
            local Dropdown = {
                Type = "Dropdown",
                Options = o.Options or {},
                Multi = o.Multi == true,
            }
            if Dropdown.Multi then
                if type(o.Default) == "table" then
                    Dropdown.Value = {}
                    for _, v in ipairs(o.Default) do table.insert(Dropdown.Value, v) end
                elseif o.Default ~= nil then
                    Dropdown.Value = { o.Default }
                else
                    Dropdown.Value = {}
                end
            else
                Dropdown.Value = o.Default
            end

            local f = Instance.new("Frame")
            f.Size = UDim2.new(1, 0, 0, 38)
            f.BackgroundColor3 = Window._theme.Element
            f.BorderSizePixel = 0
            f.ClipsDescendants = true
            f.Parent = page
            corner(f, UDim.new(0, 6))
            local s = stroke(f, Window._theme.ElementStroke, 1, 0.4)

            local header = Instance.new("TextButton")
            header.Size = UDim2.new(1, 0, 0, 38)
            header.BackgroundTransparency = 1
            header.Text = ""
            header.AutoButtonColor = false
            header.Parent = f

            local lbl = Instance.new("TextLabel")
            lbl.Position = UDim2.new(0, 12, 0, 0)
            lbl.Size = UDim2.new(0.5, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Font = FONT
            lbl.Text = o.Name or "Dropdown"
            lbl.TextSize = 13
            lbl.TextColor3 = Window._theme.Text
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Parent = header

            local valLbl = Instance.new("TextLabel")
            valLbl.AnchorPoint = Vector2.new(1, 0.5)
            valLbl.Position = UDim2.new(1, -28, 0.5, 0)
            valLbl.Size = UDim2.new(0.5, -16, 1, 0)
            valLbl.BackgroundTransparency = 1
            valLbl.Font = FONT
            valLbl.Text = ""
            valLbl.TextSize = 12
            valLbl.TextColor3 = Window._theme.SubText
            valLbl.TextXAlignment = Enum.TextXAlignment.Right
            valLbl.TextTruncate = Enum.TextTruncate.AtEnd
            valLbl.Parent = header

            local arrow = Instance.new("TextLabel")
            arrow.AnchorPoint = Vector2.new(1, 0.5)
            arrow.Position = UDim2.new(1, -10, 0.5, 0)
            arrow.Size = UDim2.new(0, 14, 0, 14)
            arrow.BackgroundTransparency = 1
            arrow.Font = FONT_BOLD
            arrow.Text = "▾"
            arrow.TextSize = 14
            arrow.TextColor3 = Window._theme.SubText
            arrow.Parent = header

            local list = Instance.new("Frame")
            list.Position = UDim2.new(0, 0, 0, 38)
            list.Size = UDim2.new(1, 0, 0, 0)
            list.BackgroundTransparency = 1
            list.Parent = f
            listLayout(list, Enum.FillDirection.Vertical, 2)
            padding(list, 0, 6, 8, 8)

            local function isSelected(opt)
                if Dropdown.Multi then
                    for _, v in ipairs(Dropdown.Value) do
                        if v == opt then return true end
                    end
                    return false
                else
                    return Dropdown.Value == opt
                end
            end

            local function valueText()
                if Dropdown.Multi then
                    local n = #Dropdown.Value
                    if n == 0 then return "None"
                    elseif n == 1 then return tostring(Dropdown.Value[1])
                    else return n .. " selected" end
                else
                    return Dropdown.Value and tostring(Dropdown.Value) or "None"
                end
            end

            local optButtons = {}
            local function rebuildOptions()
                for _, b in ipairs(optButtons) do b:Destroy() end
                table.clear(optButtons)
                for i, opt in ipairs(Dropdown.Options) do
                    local ob = Instance.new("TextButton")
                    ob.Size = UDim2.new(1, 0, 0, 26)
                    ob.BackgroundColor3 = isSelected(opt) and Window._theme.AccentDim or Window._theme.Element
                    ob.BorderSizePixel = 0
                    ob.Font = FONT
                    ob.Text = tostring(opt)
                    ob.TextSize = 12
                    ob.TextColor3 = Window._theme.Text
                    ob.AutoButtonColor = false
                    ob.LayoutOrder = i
                    ob.Parent = list
                    corner(ob, UDim.new(0, 4))
                    table.insert(optButtons, ob)

                    track(ob.MouseButton1Click:Connect(function()
                        if Dropdown.Multi then
                            local found
                            for idx, v in ipairs(Dropdown.Value) do
                                if v == opt then found = idx; break end
                            end
                            if found then
                                table.remove(Dropdown.Value, found)
                            else
                                table.insert(Dropdown.Value, opt)
                            end
                        else
                            Dropdown.Value = opt
                        end
                        for j, b in ipairs(optButtons) do
                            b.BackgroundColor3 = isSelected(Dropdown.Options[j])
                                and Window._theme.AccentDim or Window._theme.Element
                        end
                        valLbl.Text = valueText()
                        if o.Callback then task.spawn(o.Callback, Dropdown.Value) end
                    end))
                end
            end
            rebuildOptions()
            valLbl.Text = valueText()

            local open = false
            track(header.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    local h = math.min(#Dropdown.Options * 28 + 8, 160)
                    tween(f, TWEEN_MED, { Size = UDim2.new(1, 0, 0, 38 + h) })
                    list.Size = UDim2.new(1, 0, 0, h)
                    tween(arrow, TWEEN_FAST, { Rotation = 180 })
                else
                    tween(f, TWEEN_MED, { Size = UDim2.new(1, 0, 0, 38) })
                    tween(arrow, TWEEN_FAST, { Rotation = 0 })
                end
            end))

            function Dropdown:Set(v)
                if self.Multi then
                    if type(v) == "table" then
                        self.Value = {}
                        for _, x in ipairs(v) do table.insert(self.Value, x) end
                    else
                        self.Value = v ~= nil and { v } or {}
                    end
                else
                    self.Value = v
                end
                for j, b in ipairs(optButtons) do
                    b.BackgroundColor3 = isSelected(self.Options[j])
                        and Window._theme.AccentDim or Window._theme.Element
                end
                valLbl.Text = valueText()
                if o.Callback then task.spawn(o.Callback, self.Value) end
            end

            function Dropdown:Refresh(newOpts)
                self.Options = newOpts or {}
                if self.Multi then
                    local kept = {}
                    for _, v in ipairs(self.Value) do
                        for _, ox in ipairs(self.Options) do
                            if ox == v then table.insert(kept, v); break end
                        end
                    end
                    self.Value = kept
                else
                    local found
                    for _, ox in ipairs(self.Options) do
                        if ox == self.Value then found = true; break end
                    end
                    if not found then self.Value = self.Options[1] end
                end
                rebuildOptions()
                valLbl.Text = valueText()
            end

            onTheme(function(nt)
                f.BackgroundColor3 = nt.Element
                s.Color = nt.ElementStroke
                lbl.TextColor3 = nt.Text
                valLbl.TextColor3 = nt.SubText
                arrow.TextColor3 = nt.SubText
                for j, b in ipairs(optButtons) do
                    b.BackgroundColor3 = isSelected(Dropdown.Options[j]) and nt.AccentDim or nt.Element
                    b.TextColor3 = nt.Text
                end
            end)

            if o.Flag then Phantom.Flags[o.Flag] = Dropdown end
            return Dropdown
        end

