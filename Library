local function makeGradient(parent, cfg)
    cfg = cfg or LIBRARY_CONFIG.GlowWhite
    local stops = {}
    for _, s in ipairs(cfg.Stops) do
        table.insert(stops, NumberSequenceKeypoint.new(s[1], s[2]))
    end
    return new("UIGradient", {
        Color = ColorSequence.new(cfg.Color or Color3.fromRGB(255,255,255)),
        Transparency = NumberSequence.new(stops),
        Rotation = cfg.Rotation or 135,
    }, parent)
end

local function addGlow(parent, radius)
    radius = radius or 14
    local glow = new("Frame", {
        Name = "Glow", Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = LIBRARY_CONFIG.GlowWhite.Color,
        BackgroundTransparency = 0, BorderSizePixel = 0, ZIndex = 1,
    }, parent)
    new("UICorner", { CornerRadius = UDim.new(0, radius) }, glow)
    makeGradient(glow, LIBRARY_CONFIG.GlowWhite)
    local shadow = new("Frame", {
        Name = "Shadow", Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = LIBRARY_CONFIG.ShadowBlack.Color,
        BackgroundTransparency = 0, BorderSizePixel = 0, ZIndex = 1,
    }, parent)
    new("UICorner", { CornerRadius = UDim.new(0, radius) }, shadow)
    makeGradient(shadow, LIBRARY_CONFIG.ShadowBlack)
    return glow, shadow
end

local function applyTextGradient(label, g)
    if not g then return nil end
    local colors
    if typeof(g) == "Color3" then
        colors = ColorSequence.new(g)
    elseif type(g) == "table" then
        if g.Colors or g.Color then
            local list = g.Colors or g.Color
            if typeof(list) == "Color3" then
                colors = ColorSequence.new(list)
            elseif type(list) == "table" then
                local seq = {}
                for i, c in ipairs(list) do
                    table.insert(seq, ColorSequenceKeypoint.new((i-1)/math.max(#list-1, 1), c))
                end
                colors = ColorSequence.new(seq)
            end
        elseif #g >= 1 and typeof(g[1]) == "Color3" then
            if #g == 1 then
                colors = ColorSequence.new(g[1])
            else
                local seq = {}
                for i, c in ipairs(g) do
                    table.insert(seq, ColorSequenceKeypoint.new((i-1)/math.max(#g-1, 1), c))
                end
                colors = ColorSequence.new(seq)
            end
        end
    end
    if not colors then return nil end
    return new("UIGradient", {
        Color = colors,
        Rotation = (type(g) == "table" and g.Rotation) or 0,
    }, label)
end

