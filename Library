function Window:_openSettings()
    if not self._settingsTab then return end
    self:_closeSearch()
    self._previousTab = self.ActiveTab
    self:_showTab(self._settingsTab, "Settings")
end

function Window:_closeSettings()
    if self._previousTab then
        self:SetActiveTab(self._previousTab)
        self._previousTab = nil
    end
end

function Window:_showTab(tab, title)
    for _, t in ipairs(self.Tabs) do
        t.Panel.Visible = false
        tween(t.Button, 0.2, { BackgroundTransparency = wA(0.02) })
        tween(t.BtnStroke, 0.2, { Transparency = wA(0.04) })
        if t.BtnIcon then
            if t.BtnIcon:IsA("ImageLabel") then tween(t.BtnIcon, 0.2, { ImageTransparency = wA(0.5) })
            else tween(t.BtnIcon, 0.2, { TextTransparency = wA(0.5) }) end
        end
        tween(t.BtnLabel, 0.2, { TextTransparency = wA(0.5) })
    end
    if self._settingsTab then self._settingsTab.Panel.Visible = false end
    tab.Panel.Visible = true
    tab.Panel.Position = UDim2.fromOffset(0, 8)
    tween(tab.Panel, 0.3, { Position = UDim2.fromOffset(0, 0) }, Enum.EasingStyle.Quart)
    if tab.Button then
        tween(tab.Button, 0.2, { BackgroundTransparency = wA(0.06) })
        tween(tab.BtnStroke, 0.2, { Transparency = wA(0.08) })
        if tab.BtnIcon then
            if tab.BtnIcon:IsA("ImageLabel") then tween(tab.BtnIcon, 0.2, { ImageTransparency = 0 })
            else tween(tab.BtnIcon, 0.2, { TextTransparency = 0 }) end
        end
        tween(tab.BtnLabel, 0.2, { TextTransparency = 0 })
    end
    if self.SectionTitle then
        self.SectionTitle.TextTransparency = 1
        self.SectionTitle.Text = title or tab._name
        tween(self.SectionTitle, 0.25, { TextTransparency = 0 })
    end
end

function Window:CreateTab(name, icon)
    local W = self
    local btn = new("TextButton", {
        Name = "Tab_" .. name, Size = UDim2.new(1, 0, 0, 28),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.02), BorderSizePixel = 0,
        Text = "", AutoButtonColor = false, LayoutOrder = #W.Tabs + 1, ZIndex = 2,
    }, W.TabList)
    corner(btn, 7)
    local btnStroke = stroke(btn, Color3.fromRGB(255,255,255), wA(0.04), 1)
    local iconHolder = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 4, 0.5, 0),
        Size = UDim2.fromOffset(20, 20), BackgroundTransparency = 1, ZIndex = 3,
    }, btn)
    local btnIcon
    if icon and icon ~= "" then btnIcon = applyIcon(iconHolder, icon, 13, 0.5) end
    local btnLabel = new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 32, 0.5, 0),
        Size = UDim2.new(1, -42, 1, 0), BackgroundTransparency = 1,
        Text = name, Font = Enum.Font.GothamMedium, TextSize = 12,
        TextColor3 = Color3.fromRGB(255,255,255), TextTransparency = wA(0.5),
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 3,
    }, btn)
    local panel = new("ScrollingFrame", {
        Name = "Panel_" .. name, Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1, BorderSizePixel = 0,
        ScrollBarThickness = 2, ScrollBarImageColor3 = Color3.fromRGB(255,255,255),
        ScrollBarImageTransparency = 0.85, CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y, Visible = false, ZIndex = 2,
    }, W.PanelContainer)
    local pLayout = listV(panel, 7)
    pLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left

    local tab = setmetatable({
        _window = W, _name = name,
        Button = btn, Panel = panel, BtnIcon = btnIcon,
        BtnLabel = btnLabel, BtnStroke = btnStroke,
        _order = 0,
    }, Tab)
    btn.MouseEnter:Connect(function()
        if W.ActiveTab ~= tab then tween(btn, 0.15, { BackgroundTransparency = wA(0.04) }) end
    end)
    btn.MouseLeave:Connect(function()
        if W.ActiveTab ~= tab then tween(btn, 0.15, { BackgroundTransparency = wA(0.02) }) end
    end)
    btn.MouseButton1Click:Connect(function()
        W._previousTab = nil
        W:SetActiveTab(tab)
    end)
    table.insert(W.Tabs, tab)
    if #W.Tabs == 1 then W:SetActiveTab(tab) end
    return tab
end

function Window:SetActiveTab(tab)
    self:_closeSearch()
    self.ActiveTab = tab
    self:_showTab(tab, tab._name)
end

local function nextOrder(tab)
    tab._order = tab._order + 1
    return tab._order
end

local function makeCard(tab, height)
    local card = new("Frame", {
        Size = UDim2.new(1, -2, 0, height or 50),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.025), BorderSizePixel = 0,
        LayoutOrder = nextOrder(tab), ZIndex = 2,
    }, tab.Panel)
    corner(card, 10)
    stroke(card, Color3.fromRGB(255,255,255), wA(0.06), 1)
    return card
end

local function makeIconSquare(parent, size, icon)
    size = size or 28
    local s = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 13, 0.5, 0),
        Size = UDim2.fromOffset(size, size), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.04), BorderSizePixel = 0, ZIndex = 3,
    }, parent)
    corner(s, 7)
    stroke(s, Color3.fromRGB(255,255,255), wA(0.07), 1)
    local img
    if icon and icon ~= "" then img = applyIcon(s, icon, math.floor(size * 0.55), 0.7) end
    return s, img
end

local function makeCardLabels(card, title, desc)
