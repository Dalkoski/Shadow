function Tab:CreateColorPicker(opts)
    local win = self._window
    local startColor = opts.Color or Color3.fromRGB(255, 255, 255)
    local flag = opts.Flag
    local cb = opts.Callback or function() end

    local card = makeCard(self, 50)
    attachHover(card)
    makeIconSquare(card, 28, opts.Icon)
    makeCardLabels(card, opts.Name or "Color", opts.Description)

    local swatch = new("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(38, 24), BackgroundColor3 = startColor,
        BorderSizePixel = 0, Text = "", AutoButtonColor = false, ZIndex = 3,
    }, card)
    corner(swatch, 6)
    stroke(swatch, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)

    local panel = new("Frame", {
        Visible = false, Position = UDim2.fromOffset(0, 52),
        Size = UDim2.new(1, 0, 0, 110), BackgroundTransparency = 1, ZIndex = 4,
    }, card)
    card.ClipsDescendants = true

    local sv = new("Frame", {
        Position = UDim2.fromOffset(13, 4), Size = UDim2.new(0.55, -20, 1, -10),
        BackgroundColor3 = startColor, BorderSizePixel = 0, ZIndex = 5,
    }, panel)
    corner(sv, 7)
    local svWhite = new("Frame", { Size = UDim2.fromScale(1,1), BackgroundColor3 = Color3.new(1,1,1),
        BorderSizePixel = 0, BackgroundTransparency = 0, ZIndex = 6 }, sv)
    corner(svWhite, 7)
    new("UIGradient", { Parent = svWhite,
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1),
        }), Color = ColorSequence.new(Color3.new(1,1,1)),
    })
    local svBlack = new("Frame", { Size = UDim2.fromScale(1,1), BackgroundColor3 = Color3.new(0,0,0),
        BorderSizePixel = 0, ZIndex = 7 }, sv)
    corner(svBlack, 7)
    new("UIGradient", { Parent = svBlack, Rotation = 90,
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0),
        }),
    })
    local svCursor = new("Frame", {
        Size = UDim2.fromOffset(10, 10), AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundTransparency = 1, ZIndex = 8,
    }, sv)
    stroke(svCursor, Color3.new(1,1,1), 0, 2)
    corner(svCursor, 999)

    local hue = new("Frame", {
        Position = UDim2.fromScale(0.55, 0), Size = UDim2.new(0.45, -16, 0, 14),
        BackgroundColor3 = Color3.new(1,1,1), BorderSizePixel = 0, ZIndex = 5,
    }, panel)
    corner(hue, 999)
    new("UIGradient", { Parent = hue,
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0.00, Color3.fromHSV(0.00, 1, 1)),
            ColorSequenceKeypoint.new(0.16, Color3.fromHSV(0.16, 1, 1)),
            ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33, 1, 1)),
            ColorSequenceKeypoint.new(0.50, Color3.fromHSV(0.50, 1, 1)),
            ColorSequenceKeypoint.new(0.66, Color3.fromHSV(0.66, 1, 1)),
            ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83, 1, 1)),
            ColorSequenceKeypoint.new(1.00, Color3.fromHSV(1.00, 1, 1)),
        }),
    })
    local hueCursor = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.fromOffset(3, 18), BackgroundColor3 = Color3.new(1,1,1),
        BorderSizePixel = 0, ZIndex = 6,
    }, hue)
    corner(hueCursor, 2)

    local rgbLbl = new("TextLabel", {
        Position = UDim2.new(0.55, 0, 0, 22), Size = UDim2.new(0.45, -16, 0, 16),
        BackgroundTransparency = 1, Font = Enum.Font.GothamMedium, TextSize = 10,
        Text = "", TextColor3 = COLOR.TextPrimary, TextTransparency = whiteAlpha(0.6),
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
    }, panel)
    local hexLbl = new("TextLabel", {
        Position = UDim2.new(0.55, 0, 0, 40), Size = UDim2.new(0.45, -16, 0, 14),
        BackgroundTransparency = 1, Font = Enum.Font.GothamMedium, TextSize = 10,
        Text = "", TextColor3 = COLOR.TextPrimary, TextTransparency = whiteAlpha(0.6),
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6,
    }, panel)

    local h, s, v = startColor:ToHSV()
    local function repaint()
        sv.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
        hueCursor.Position = UDim2.new(h, 0, 0.5, 0)
        local c = Color3.fromHSV(h, s, v)
        swatch.BackgroundColor3 = c
        rgbLbl.Text = string.format("%d, %d, %d", math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5))
        hexLbl.Text = string.format("#%02X%02X%02X", math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5))
        return c
    end
    repaint()

    local open = false
    swatch.MouseButton1Click:Connect(function()
        open = not open
        panel.Visible = open
        tween(card, 0.25, { Size = UDim2.new(1, -2, 0, open and 168 or 50) }, Enum.EasingStyle.Quint)
    end)

    local svDrag, hueDrag = false, false
    local function svHit(input)
        local p = input.Position
        local pos, size = sv.AbsolutePosition, sv.AbsoluteSize
        s = math.clamp((p.X - pos.X) / size.X, 0, 1)
        v = math.clamp(1 - (p.Y - pos.Y) / size.Y, 0, 1)
        local c = repaint()
        win.Flags[flag] = c; pcall(cb, c)
    end
    local function hueHit(input)
        local p = input.Position
        local pos, size = hue.AbsolutePosition, hue.AbsoluteSize
        h = math.clamp((p.X - pos.X) / size.X, 0, 1)
        local c = repaint()
        win.Flags[flag] = c; pcall(cb, c)
    end
    local svButton = new("TextButton", { Size = UDim2.fromScale(1,1), BackgroundTransparency = 1,
        Text = "", AutoButtonColor = false, ZIndex = 9 }, sv)
    svButton.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            svDrag = true; svHit(i)
        end
    end)
    local hueButton = new("TextButton", { Size = UDim2.fromScale(1,1), BackgroundTransparency = 1,
        Text = "", AutoButtonColor = false, ZIndex = 7 }, hue)
    hueButton.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            hueDrag = true; hueHit(i)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            if svDrag or hueDrag then win:SaveConfig() end
            svDrag = false; hueDrag = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
            if svDrag then svHit(i) end
            if hueDrag then hueHit(i) end
        end
    end)

    local element = {
        Type = "ColorPicker", Value = startColor,
        Set = function(self2, c)
            if typeof(c) == "Color3" then
                h, s, v = c:ToHSV()
                self2.Value = repaint()
                win.Flags[flag] = self2.Value; pcall(cb, self2.Value)
            end
        end,
        Get = function() return Color3.fromHSV(h, s, v) end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

