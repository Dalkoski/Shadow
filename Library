function Tab:CreateToggle(opts)
    local self_tab = self
    local win = self._window
    local state = opts.CurrentValue or false
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local card = makeCard(self.Panel, 50)
    attachHover(card)
    makeIconSquare(card, 28)
    makeCardLabels(card, opts.Name or "Toggle", opts.Description)

    local width, height = 34, 19
    local knobSize = height - 6
    local track = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(width, height),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        ZIndex = 3,
    }, card)
    corner(track, math.floor(height/2))
    local trackStroke = stroke(track, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)
    local knob = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 2, 0.5, 0),
        Size = UDim2.fromOffset(knobSize, knobSize),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        ZIndex = 4,
    }, track)
    corner(knob, math.floor(knobSize/2))

    local function apply(s, animate)
        state = s
        local dur = animate and 0.2 or 0
        if s then
            tween(track, dur, { BackgroundTransparency = whiteAlpha(0.92) })
            tween(trackStroke, dur, { Transparency = 1 })
            tween(knob, dur, {
                Position = UDim2.new(1, -(knobSize + 2), 0.5, 0),
                BackgroundColor3 = COLOR.KnobOn,
                BackgroundTransparency = 0,
            }, Enum.EasingStyle.Quart)
            knob.AnchorPoint = Vector2.new(0, 0.5)
        else
            tween(track, dur, { BackgroundTransparency = whiteAlpha(0.07) })
            tween(trackStroke, dur, { Transparency = whiteAlpha(0.08) })
            tween(knob, dur, {
                Position = UDim2.new(0, 2, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BackgroundTransparency = whiteAlpha(0.45),
            }, Enum.EasingStyle.Quart)
            knob.AnchorPoint = Vector2.new(0, 0.5)
        end
    end
    apply(state, false)

    local hit = new("TextButton", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false,
        ZIndex = 5,
    }, card)
    hit.MouseButton1Click:Connect(function()
        state = not state
        apply(state, true)
        updateFlag(win, flag, state)
        win:SaveConfig()
        pcall(cb, state)
    end)

    local element = {
        Type = "Toggle",
        Value = state,
        Set = function(self, v) state = v and true or false; self.Value = state; apply(state, true); updateFlag(win, flag, state); pcall(cb, state) end,
        Get = function() return state end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

