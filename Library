    local function unhide()
        if Debounce then return end
        Debounce = true
        Hidden = false

        Main.Position = UDim2.new(0.5, 0, 0.5, 0)
        Main.Visible = true
        tween(Main,             TWEEN_MED, { Size = UDim2.new(0, 500, 0, 475), BackgroundTransparency = 0 })
        tween(Main.Topbar,      TWEEN_MED, { Size = UDim2.new(0, 500, 0, 45),  BackgroundTransparency = 0 })
        tween(Main.Shadow.Image,TWEEN_MED, { ImageTransparency = 0.6 })
        tween(Main.Topbar.Divider,      TWEEN_MED, { BackgroundTransparency = 0 })
        tween(Main.Topbar.CornerRepair, TWEEN_MED, { BackgroundTransparency = 0 })
        tween(Main.Topbar.Title,        TWEEN_MED, { TextTransparency = 0 })

        if MPrompt then
            tween(MPrompt,       TWEEN_MED, { Position = UDim2.new(0.5,0,0,-50), Size = UDim2.new(0,40,0,10), BackgroundTransparency = 1 })
            tween(MPrompt.Title, TWEEN_MED, { TextTransparency = 1 })
            task.delay(0.5, function() MPrompt.Visible = false end)
        end

        for _, btn in ipairs(Topbar:GetChildren()) do
            if btn:IsA("ImageButton") then
                if btn.Name == "Icon" then
                    tween(btn, TWEEN_MED, { ImageTransparency = 0 })
                else
                    tween(btn, TWEEN_MED, { ImageTransparency = 0.8 })
                end
            end
        end
        setTabButtons(true)
        setElementsVisible(true)
        task.wait(0.5)
        Debounce = false
    end

