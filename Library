            new("TextLabel", {
                AnchorPoint = Vector2.new(0, 0.5),
                Position = UDim2.new(0, 10, 0.5, 0),
                Size = UDim2.new(1, -20, 1, 0),
                BackgroundTransparency = 1,
                Text = opt,
                Font = Enum.Font.GothamMedium,
                TextSize = 11,
                TextColor3 = Color3.fromRGB(255, 255, 255),
                TextTransparency = (opt == current) and 0 or whiteAlpha(0.65),
                TextXAlignment = Enum.TextXAlignment.Left,
                TextYAlignment = Enum.TextYAlignment.Center,
                ZIndex = 52,
            }, row)
            row.MouseEnter:Connect(function() tween(row, 0.1, { BackgroundTransparency = whiteAlpha(0.06) }) end)
            row.MouseLeave:Connect(function()
                tween(row, 0.1, { BackgroundTransparency = (opt == current) and whiteAlpha(0.08) or 1 })
            end)
            row.MouseButton1Click:Connect(function()
                current = opt
                valueLbl.Text = opt
                updateFlag(win, flag, opt)
                win:SaveConfig()
                pcall(cb, opt)
                rebuildMenu()
                menu.Visible = false
                tween(chev, 0.15, { Rotation = 0 })
            end)
            table.insert(optionButtons, row)
        end
    end
    rebuildMenu()

    local function positionMenu()
        local p = trigger.AbsolutePosition
        local s = trigger.AbsoluteSize
        menu.Position = UDim2.fromOffset(p.X + s.X, p.Y + s.Y + 4)
    end

    trigger.MouseButton1Click:Connect(function()
        if menu.Visible then
            menu.Visible = false
            tween(chev.Parent, 0.15, { Rotation = 0 })
        else
            positionMenu()
            menu.Visible = true
            for _, otherWin in ipairs(Library._windows) do end -- close others (skip)
        end
    end)

    -- close menu on outside click
    UserInputService.InputBegan:Connect(function(input)
        if not menu.Visible then return end
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local mp = input.Position
        local mPos, mSize = menu.AbsolutePosition, menu.AbsoluteSize
        local tPos, tSize = trigger.AbsolutePosition, trigger.AbsoluteSize
        local inMenu = mp.X >= mPos.X and mp.X <= mPos.X + mSize.X and mp.Y >= mPos.Y and mp.Y <= mPos.Y + mSize.Y
        local inTrig = mp.X >= tPos.X and mp.X <= tPos.X + tSize.X and mp.Y >= tPos.Y and mp.Y <= tPos.Y + tSize.Y
        if not inMenu and not inTrig then
            menu.Visible = false
        end
    end)

    local element = {
        Type = "Dropdown",
        Value = current,
        Set = function(self, opt)
            current = opt
            valueLbl.Text = opt
            self.Value = opt
            updateFlag(win, flag, opt)
            rebuildMenu()
            pcall(cb, opt)
        end,
        Get = function() return current end,
        Refresh = function(_, newOpts)
            options = newOpts
            if not table.find(options, current) then current = options[1] or "None"; valueLbl.Text = current end
            rebuildMenu()
        end,
        Destroy = function() card:Destroy(); menu:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

--==============================================================
-- INPUT
--==============================================================
function Tab:CreateInput(opts)
    local win = self._window
    local value = opts.CurrentValue or ""
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local clearOnFocus = opts.RemoveTextAfterFocusLost

    local card = makeCard(self.Panel, 50)
    attachHover(card)
    makeIconSquare(card, 28)
    makeCardLabels(card, opts.Name or "Input", opts.Description)

    local frame = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(120, 24),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = whiteAlpha(0.04),
        BorderSizePixel = 0,
        ZIndex = 3,
    }, card)
    corner(frame, 6)
    local fStroke = stroke(frame, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)
    local box = new("TextBox", {
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.fromOffset(8, 0),
        BackgroundTransparency = 1,
        Text = value,
        PlaceholderText = opts.PlaceholderText or "",
        PlaceholderColor3 = Color3.fromRGB(140, 140, 140),
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = COLOR.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left,
        ClearTextOnFocus = false,
        ZIndex = 4,
    }, frame)

    box.Focused:Connect(function() tween(fStroke, 0.15, { Transparency = whiteAlpha(0.2) }) end)
    box.FocusLost:Connect(function()
        tween(fStroke, 0.15, { Transparency = whiteAlpha(0.08) })
        value = box.Text
        updateFlag(win, flag, value)
        win:SaveConfig()
        pcall(cb, value)
        if clearOnFocus then box.Text = "" end
    end)

    local element = {
        Type = "Input",
        Value = value,
        Set = function(self, v) value = tostring(v); self.Value = value; box.Text = value; updateFlag(win, flag, value); pcall(cb, value) end,
        Get = function() return value end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

--==============================================================
-- KEYBIND
--==============================================================
function Tab:CreateKeybind(opts)
    local win = self._window
    local current = opts.CurrentKeybind or "None"
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local holdToInteract = opts.HoldToInteract
    local callOnChange = opts.CallOnChange

    local card = makeCard(self.Panel, 50)
    attachHover(card)
    makeIconSquare(card, 28)
    makeCardLabels(card, opts.Name or "Keybind", opts.Description)

    local btn = new("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(72, 24),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = whiteAlpha(0.04),
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        ZIndex = 3,
    }, card)
    corner(btn, 6)
    stroke(btn, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)
    local kLbl = new("TextLabel", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Text = current,
        Font = Enum.Font.GothamMedium,
        TextSize = 11,
        TextColor3 = COLOR.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Center,
        ZIndex = 4,
    }, btn)

    local listening = false
    btn.MouseButton1Click:Connect(function()
        listening = true
        kLbl.Text = "..."
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
            local key = input.KeyCode.Name
            current = key
            kLbl.Text = key
            listening = false
            updateFlag(win, flag, key)
            win:SaveConfig()
            if callOnChange then pcall(cb, key) end
            return
        end
        if processed then return end
        if not listening and input.UserInputType == Enum.UserInputType.Keyboard and current ~= "None" then
            if input.KeyCode == Enum.KeyCode[current] then
                if holdToInteract then
                    pcall(cb, true)
                    local conn
                    conn = UserInputService.InputEnded:Connect(function(i2)
                        if i2.KeyCode == Enum.KeyCode[current] then
                            pcall(cb, false)
                            conn:Disconnect()
                        end
                    end)
                else
                    if not callOnChange then pcall(cb) end
                end
            end
        end
    end)

    local element = {
        Type = "Keybind",
        Value = current,
        Set = function(self, k) current = tostring(k); self.Value = current; kLbl.Text = current; updateFlag(win, flag, current) end,
        Get = function() return current end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

