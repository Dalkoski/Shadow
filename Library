function Window:CreateHomeTab(opts)
    opts = opts or {}
    local tab = self:CreateTab(opts.Name or "Home", opts.Icon or "home")

    if opts.Executor ~= false then
        tab:CreateSection(opts.ExecutorTitle or "Executor")
        local name, ver = Library:GetExecutor()
        local text = "Executor: " .. tostring(name)
        if ver then text = text .. " (" .. tostring(ver) .. ")" end
        tab:CreateLabel(text, "code")
    end

    local linksList = {}
    if opts.Discord then
        table.insert(linksList, { Name = "Copy Discord", Icon = "copy", Value = opts.Discord })
    end
    if opts.Links then
        for _, l in ipairs(opts.Links) do table.insert(linksList, l) end
    end
    if #linksList > 0 then
        tab:CreateSection(opts.LinksTitle or "Links")
        for _, link in ipairs(linksList) do
            local label = link.Name or "Copy Link"
            tab:CreateButton({
                Name = label, Icon = link.Icon or "copy",
                Callback = function()
                    if link.Callback then pcall(link.Callback); return end
                    if Library:CopyToClipboard(link.Value or "") then
                        Library:Notify({
                            Title = "Copied", Image = "clipboard-check",
                            Content = label .. " copied to clipboard.", Duration = 2,
                        })
                    else
                        Library:Notify({
                            Title = "Failed", Image = "x",
                            Content = "Your executor does not support clipboard.", Duration = 2,
                        })
                    end
                end,
            })
        end
    end

    if opts.Feedback then
        local fb = opts.Feedback
        tab:CreateSection(fb.Title or "Feedback")
        local current = ""
        tab:CreateInput({
            Name = "Feedback", Icon = "message-square",
            PlaceholderText = fb.Placeholder or "Write your feedback here...",
            CurrentValue = "",
            Callback = function(v) current = v end,
        })
        tab:CreateButton({
            Name = fb.ButtonText or "Send Feedback", Icon = "send",
            Callback = function()
                if current == "" then
                    Library:Notify({Title = "Empty", Image = "info", Content = "Type something first.", Duration = 2})
                    return
                end
                if fb.Callback then
                    pcall(fb.Callback, current)
                    Library:Notify({Title = "Sent", Image = "check", Content = "Thanks for the feedback.", Duration = 2})
                    current = ""
                    return
                end
                if not fb.Webhook or fb.Webhook == "" then
                    Library:Notify({Title = "Not Configured", Image = "info", Content = "No webhook or callback set.", Duration = 2})
                    return
                end
                local payload = "**Feedback from " .. (LocalPlayer.DisplayName or LocalPlayer.Name) .. "** (@" .. LocalPlayer.Name .. ", Id " .. LocalPlayer.UserId .. ")\n"
                    .. "Executor: " .. tostring(Library:GetExecutor()) .. "\n"
                    .. "Game: " .. tostring(game.PlaceId) .. "\n\n" .. current
                local ok = Library:SendWebhook(fb.Webhook, payload, { Username = fb.Username })
                if ok then
                    Library:Notify({Title = "Sent", Image = "check", Content = "Thanks for the feedback.", Duration = 2})
                    current = ""
                else
                    Library:Notify({Title = "Failed", Image = "x", Content = "Could not send. Executor must support HTTP.", Duration = 2})
                end
            end,
        })
    end

    if opts.Universal then
        local u = type(opts.Universal) == "table" and opts.Universal or {}
        tab:CreateSection(u.Title or "Universal")
        local state = { WalkSpeed = 16, JumpPower = 50 }
        local function hum()
            local c = LocalPlayer.Character
            return c and c:FindFirstChildOfClass("Humanoid")
        end
        if u.WalkSpeed ~= false then
            tab:CreateSlider({
                Name = "Walk Speed", Icon = "footprints",
                Range = u.WalkSpeedRange or {16, 200}, Increment = 1, Suffix = "studs/s",
                CurrentValue = (u.WalkSpeedDefault or 16), Flag = "_uni_ws",
                Callback = function(v) state.WalkSpeed = v; local h = hum(); if h then h.WalkSpeed = v end end,
            })
        end
        if u.JumpPower ~= false then
            tab:CreateSlider({
                Name = "Jump Power", Icon = "arrow-up",
                Range = u.JumpPowerRange or {50, 500}, Increment = 5,
                CurrentValue = (u.JumpPowerDefault or 50), Flag = "_uni_jp",
                Callback = function(v) state.JumpPower = v; local h = hum(); if h then h.JumpPower = v end end,
            })
        end
        if u.InfiniteJump ~= false then
            local conn
            tab:CreateToggle({
                Name = "Infinite Jump", Icon = "chevrons-up", CurrentValue = false, Flag = "_uni_ij",
                Callback = function(v)
                    if conn then conn:Disconnect(); conn = nil end
                    if v then
                        conn = UserInputService.JumpRequest:Connect(function()
                            local h = hum(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
                        end)
                    end
                end,
            })
        end
        if u.NoClip ~= false then
            local conn
            tab:CreateToggle({
                Name = "NoClip", Icon = "ghost", CurrentValue = false, Flag = "_uni_nc",
                Callback = function(v)
                    if conn then conn:Disconnect(); conn = nil end
                    if v then
                        conn = RunService.Stepped:Connect(function()
                            local c = LocalPlayer.Character
                            if c then
                                for _, p in ipairs(c:GetDescendants()) do
                                    if p:IsA("BasePart") then p.CanCollide = false end
                                end
                            end
                        end)
                    end
                end,
            })
        end
        if u.Server ~= false then
            tab:CreateButton({ Name = "Rejoin", Icon = "refresh-cw", Callback = function() Library:Rejoin() end })
            tab:CreateButton({ Name = "Server Hop", Icon = "shuffle", Callback = function() Library:ServerHop() end })
        end
        LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.1)
            local h = hum()
            if h then
                if state.WalkSpeed then h.WalkSpeed = state.WalkSpeed end
                if state.JumpPower then h.JumpPower = state.JumpPower end
            end
        end)
    end

    if opts.Credits then
        local c = opts.Credits
        tab:CreateSection(c.Title or "Credits")
        if c.Script then tab:CreateLabel("Script: " .. tostring(c.Script), "user") end
        if c.UI then tab:CreateLabel("UI: " .. tostring(c.UI), "palette") end
        if c.Items then
            for _, line in ipairs(c.Items) do tab:CreateLabel(line.Text, line.Icon) end
        end
        if c.Disclaimer then
            tab:CreateDivider()
            tab:CreateParagraph({ Content = c.Disclaimer })
        end
    end

    return tab
end

