	accentBar.Position = UDim2.fromOffset(0, 0)
	accentBar.BackgroundColor3 = theme.Accent[1]
	accentBar.BorderSizePixel = 0
	accentBar.Parent = card

	local accentGradient = Instance.new("UIGradient")
