function Tab:CreateDropdown(opts)
    local win = self._window
    local options = opts.Options or {}
    local current = opts.CurrentOption or options[1] or "None"
    if type(current) == "table" then current = current[1] end
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local card = makeCard(self.Panel, 50)
    attachHover(card)
    makeIconSquare(card, 28, opts.Icon)
    makeCardLabels(card, opts.Name or "Dropdown", opts.Description)

    local trigger = new("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(96, 24), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = whiteAlpha(0.04), BorderSizePixel = 0,
        Text = "", AutoButtonColor = false, ZIndex = 5,
    }, card)
    corner(trigger, 6)
    stroke(trigger, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)
    local valueLbl = new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 10, 0.5, 0),
        Size = UDim2.new(1, -28, 1, 0), BackgroundTransparency = 1,
        Text = current, Font = Enum.Font.GothamMedium, TextSize = 11,
        TextColor3 = COLOR.TextPrimary, TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 6,
    }, trigger)
    local chev = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -9, 0.5, 0),
        Size = UDim2.fromOffset(9, 6), BackgroundTransparency = 1, ZIndex = 6,
    }, trigger)
    new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 0, 0.4, 0),
        Size = UDim2.fromOffset(6, 1.5), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = whiteAlpha(0.5), BorderSizePixel = 0, Rotation = 30, ZIndex = 7,
    }, chev)
    new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, 0, 0.4, 0),
        Size = UDim2.fromOffset(6, 1.5), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = whiteAlpha(0.5), BorderSizePixel = 0, Rotation = -30, ZIndex = 7,
    }, chev)

    local menu = new("Frame", {
        Visible = false, AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(0, 0, 0, 0), Size = UDim2.fromOffset(140, 0),
        AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = COLOR.BgLight,
        BorderSizePixel = 0, ZIndex = 50,
    }, win.Gui)
    corner(menu, 9)
    stroke(menu, Color3.fromRGB(255,255,255), whiteAlpha(0.1), 1)
    new("UIPadding", { PaddingTop = UDim.new(0,4), PaddingBottom = UDim.new(0,4),
        PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4) }, menu)
    listV(menu, 1)
    local optionButtons = {}
    local function rebuildMenu()
        for _, b in ipairs(optionButtons) do b:Destroy() end
        table.clear(optionButtons)
        for i, opt in ipairs(options) do
            local row = new("TextButton", {
                Size = UDim2.new(1, 0, 0, 24), BackgroundColor3 = Color3.fromRGB(255,255,255),
                BackgroundTransparency = (opt == current) and whiteAlpha(0.08) or 1,
                BorderSizePixel = 0, Text = "", AutoButtonColor = false,
                LayoutOrder = i, ZIndex = 51,
            }, menu)
            corner(row, 5)
            new("TextLabel", {
                AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 10, 0.5, 0),
                Size = UDim2.new(1, -20, 1, 0), BackgroundTransparency = 1,
                Text = opt, Font = Enum.Font.GothamMedium, TextSize = 11,
                TextColor3 = Color3.fromRGB(255,255,255),
                TextTransparency = (opt == current) and 0 or whiteAlpha(0.65),
                TextXAlignment = Enum.TextXAlignment.Left,
                TextYAlignment = Enum.TextYAlignment.Center, ZIndex = 52,
            }, row)
            row.MouseEnter:Connect(function() tween(row, 0.1, { BackgroundTransparency = whiteAlpha(0.06) }) end)
            row.MouseLeave:Connect(function()
                tween(row, 0.1, { BackgroundTransparency = (opt == current) and whiteAlpha(0.08) or 1 })
            end)
            row.MouseButton1Click:Connect(function()
                current = opt; valueLbl.Text = opt
                updateFlag(win, flag, opt); win:SaveConfig(); pcall(cb, opt)
                rebuildMenu(); menu.Visible = false
                tween(chev, 0.15, { Rotation = 0 })
            end)
            table.insert(optionButtons, row)
        end
    end
    rebuildMenu()
    local function positionMenu()
        local p = trigger.AbsolutePosition
        local s = trigger.AbsoluteSize
        menu.Position = UDim2.fromOffset(p.X + s.X, p.Y + s.Y + 4)
    end
    trigger.MouseButton1Click:Connect(function()
        if menu.Visible then
            menu.Visible = false
            tween(chev.Parent, 0.15, { Rotation = 0 })
        else
            positionMenu(); menu.Visible = true
        end
    end)
    UserInputService.InputBegan:Connect(function(input)
        if not menu.Visible then return end
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local mp = input.Position
        local mPos, mSize = menu.AbsolutePosition, menu.AbsoluteSize
        local tPos, tSize = trigger.AbsolutePosition, trigger.AbsoluteSize
        local inMenu = mp.X >= mPos.X and mp.X <= mPos.X + mSize.X and mp.Y >= mPos.Y and mp.Y <= mPos.Y + mSize.Y
        local inTrig = mp.X >= tPos.X and mp.X <= tPos.X + tSize.X and mp.Y >= tPos.Y and mp.Y <= tPos.Y + tSize.Y
        if not inMenu and not inTrig then menu.Visible = false end
    end)
    local element = {
        Type = "Dropdown", Value = current,
        Set = function(self, opt)
            current = opt; valueLbl.Text = opt; self.Value = opt
            updateFlag(win, flag, opt); rebuildMenu(); pcall(cb, opt)
        end,
        Get = function() return current end,
        Refresh = function(_, newOpts)
            options = newOpts
            if not table.find(options, current) then
                current = options[1] or "None"; valueLbl.Text = current
            end
            rebuildMenu()
        end,
        Destroy = function() card:Destroy(); menu:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

