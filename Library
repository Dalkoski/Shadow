function Window:Minimize()
    if self._minimizing then return end
    self._minimizing = true
    if self._minimized then
        self._minimized = false
        self.Body.Visible = true
        local tw = tween(self.Window, 0.3, { Size = self._normalSize }, Enum.EasingStyle.Quint)
        tw.Completed:Connect(function() self._minimizing = false end)
    else
        self._minimized = true
        local tw = tween(self.Window, 0.3, { Size = UDim2.fromOffset(self._normalSize.X.Offset, 44) }, Enum.EasingStyle.Quint)
        tw.Completed:Connect(function()
            if self._minimized and not self._destroyed then self.Body.Visible = false end
            self._minimizing = false
        end)
    end
end

function Window:Hide()
    if self._hidden then return end
    self._hidden = true
    local w = self.Window
    tween(w, 0.35, {
        Size = UDim2.fromOffset(self._normalSize.X.Offset * 0.88, self._normalSize.Y.Offset * 0.88),
    }, Enum.EasingStyle.Quint)
    task.delay(0.36, function()
        if self._hidden and w then w.Visible = false end
    end)
    if self._mobilePrompt then self._mobilePrompt.Visible = true end
end

function Window:Unhide()
    if not self._hidden then return end
    self._hidden = false
    if self._minimized then
        self._minimized = false
        if self.Body then self.Body.Visible = true end
    end
    local w = self.Window
    w.Visible = true
    w.Size = UDim2.fromOffset(self._normalSize.X.Offset * 0.88, self._normalSize.Y.Offset * 0.88)
    tween(w, 0.4, { Size = self._normalSize }, Enum.EasingStyle.Quint)
    if self._mobilePrompt then self._mobilePrompt.Visible = false end
end

function Window:SetVisibility(v)
    if v then self:Unhide() else self:Hide() end
end

function Window:IsVisible()
    return not self._hidden and (not self._destroyed)
end

function Window:Destroy()
    if self._destroyed then return end
    self._destroyed = true
    if not self.Window or not self.Gui then return end
    local w = self.Window
    tween(w, 0.28, {
        Size = UDim2.fromOffset(w.AbsoluteSize.X * 0.9, w.AbsoluteSize.Y * 0.9),
    }, Enum.EasingStyle.Quart)
    task.delay(0.3, function() if self.Gui then self.Gui:Destroy() end end)
end

function Window:SetSectionTitle(text)
    if self.SectionTitle then self.SectionTitle.Text = text end
end

function Window:ModifyTheme(name)
    local newTheme
    if type(name) == "string" and THEMES[name] then
        newTheme = THEMES[name]
    elseif type(name) == "table" then
        newTheme = name
    else return end
    for k, v in pairs(newTheme) do COLOR[k] = v end
    self.Window.BackgroundColor3 = COLOR.BgDeep
    for _, d in ipairs(self.Gui:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextBox") then
            if d.TextColor3 == Color3.fromRGB(255,255,255) or d.TextColor3 == Color3.fromRGB(0,0,0) then
                d.TextColor3 = COLOR.TextPrimary
            end
        end
    end
end

function Window:_closeSearch()
    if not self._searchFrame or not self._searchFrame.Visible then return end
    local f = self._searchFrame
    if self._searchBox then self._searchBox.Text = "" end
    tween(f, 0.18, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 22) }, Enum.EasingStyle.Quart)
    if self._searchStroke then tween(self._searchStroke, 0.18, { Transparency = 1 }) end
    if self._searchBox then tween(self._searchBox, 0.18, { TextTransparency = 1 }) end
    task.delay(0.19, function() if f then f.Visible = false end end)
    if self.SectionTitle then
        self.SectionTitle.Visible = true
        self.SectionTitle.TextTransparency = 1
        tween(self.SectionTitle, 0.2, { TextTransparency = 0 })
    end
    if self.ActiveTab then
        for _, el in ipairs(self.ActiveTab.Panel:GetChildren()) do
            if el:IsA("GuiObject") and not el:IsA("UIListLayout") then el.Visible = true end
        end
    end
end

function Window:_toggleSearch()
    if self._searchFrame and self._searchFrame.Visible then
        self:_closeSearch()
        return
    end
    if not self._searchFrame then
        local f = new("Frame", {
            Name = "SearchBar",
            Position = UDim2.fromOffset(0, 0),
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundColor3 = Color3.fromRGB(255,255,255),
            BackgroundTransparency = 1,
            BorderSizePixel = 0, ZIndex = 20, Visible = false,
        }, self.Content)
        corner(f, 6)
        local fStroke = stroke(f, Color3.fromRGB(255,255,255), 1, 1)
        local searchIcon = new("Frame", {
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 10, 0.5, 0),
            Size = UDim2.fromOffset(14, 14), BackgroundTransparency = 1, ZIndex = 21,
        }, f)
        applyIcon(searchIcon, "search", 14, 0.55)
        local box = new("TextBox", {
            Position = UDim2.fromOffset(30, 0), Size = UDim2.new(1, -40, 1, 0),
            BackgroundTransparency = 1, Text = "", TextTransparency = 1,
            PlaceholderText = "Search...", PlaceholderColor3 = Color3.fromRGB(140,140,140),
            Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = COLOR.TextPrimary,
            TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false, ZIndex = 21,
        }, f)
        self._searchFrame = f
        self._searchBox = box
        self._searchStroke = fStroke
        box:GetPropertyChangedSignal("Text"):Connect(function()
            local q = string.lower(box.Text)
            if not self.ActiveTab then return end
            for _, el in ipairs(self.ActiveTab.Panel:GetChildren()) do
                if el:IsA("GuiObject") and not el:IsA("UIListLayout") then
                    if q == "" then el.Visible = true else
                        local found = false
                        for _, d in ipairs(el:GetDescendants()) do
                            if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Text ~= "" then
                                if string.lower(d.Text):find(q, 1, true) then found = true; break end
                            end
                        end
                        el.Visible = found
                    end
                end
            end
        end)
        box.FocusLost:Connect(function(enter)
            if enter and box.Text == "" then self:_closeSearch() end
        end)
    end
    local f = self._searchFrame
    if self.SectionTitle then
        tween(self.SectionTitle, 0.15, { TextTransparency = 1 })
        task.delay(0.15, function()
            if self._searchFrame and self._searchFrame.Visible then
                self.SectionTitle.Visible = false
            end
        end)
    end
    f.Visible = true
    f.BackgroundTransparency = 1
    f.Size = UDim2.new(1, 0, 0, 22)
    self._searchStroke.Transparency = 1
    self._searchBox.TextTransparency = 1
    tween(f, 0.25, { BackgroundTransparency = wA(0.05), Size = UDim2.new(1, 0, 0, 26) }, Enum.EasingStyle.Quart)
    tween(self._searchStroke, 0.25, { Transparency = wA(0.1) })
    tween(self._searchBox, 0.25, { TextTransparency = 0 })
    task.wait(0.05)
    self._searchBox:CaptureFocus()
end

