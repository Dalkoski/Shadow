--==============================================================
-- EXECUTOR PERSISTENCE
--==============================================================
local exec = {
    writefile         = (writefile         or (syn and syn.write_file)),
    readfile          = (readfile          or (syn and syn.read_file)),
    isfile            = (isfile            or (syn and syn.is_file)),
    makefolder        = (makefolder        or (syn and syn.make_folder)),
    isfolder          = (isfolder          or (syn and syn.is_folder)),
    delfile           = (delfile           or (syn and syn.delete_file)),
    queue_on_teleport = (queue_on_teleport or syn_queue_on_teleport or (syn and syn.queue_on_teleport)),
}
local function safeMkdir(p) if exec.makefolder and exec.isfolder and not exec.isfolder(p) then pcall(exec.makefolder, p) end end
local function safeWrite(p, d) if exec.writefile then return pcall(exec.writefile, p, d) end end
local function safeRead(p)
    if not exec.readfile or not exec.isfile then return nil end
    if not exec.isfile(p) then return nil end
    local ok, data = pcall(exec.readfile, p)
    if ok then return data end
end

