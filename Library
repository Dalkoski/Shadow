VaenHub._ElementBuilders.Dropdown = function(self, elem)
	local window = elem._window
	local theme  = window._theme

	elem._options = elem._options or {}
	if type(elem._current) ~= "table" then
		elem._current = elem._default or {}
		if type(elem._current) == "string" then
			elem._current = {elem._current}
		end
	end

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1, 0, 0, 36)
	frame.BackgroundColor3 = theme.ElementBg
	frame.BorderSizePixel = 0
	frame.ClipsDescendants = true
	frame.Parent = elem._tab._page

	makeCorner(frame, 8)
	makeGradientStroke(frame, theme, 0.94)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.5, 0, 0, 36)
	label.Position = UDim2.fromOffset(12, 0)
	label.BackgroundTransparency = 1
	label.Text = elem._name
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.TextColor3 = theme.Text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = frame

	local selectedText = Instance.new("TextLabel")
	selectedText.Size = UDim2.new(0.5, -36, 0, 36)
	selectedText.Position = UDim2.new(0.5, 0, 0, 0)
	selectedText.BackgroundTransparency = 1
	selectedText.Text = #elem._current > 0 and table.concat(elem._current, ", ") or "None"
	selectedText.Font = Enum.Font.Gotham
	selectedText.TextSize = 11
	selectedText.TextColor3 = theme.TextDim
	selectedText.TextXAlignment = Enum.TextXAlignment.Right
	selectedText.Parent = frame

	local arrow = Instance.new("TextLabel")
	arrow.Size = UDim2.fromOffset(20, 20)
	arrow.Position = UDim2.new(1, -28, 0, 8)
	arrow.BackgroundTransparency = 1
	arrow.Text = "▾"
	arrow.Font = Enum.Font.GothamBold
	arrow.TextSize = 10
	arrow.TextColor3 = theme.TextDim
	arrow.Parent = frame

	-- Options list (hidden by default)
	local optionsList = Instance.new("Frame")
	optionsList.Size = UDim2.new(1, -16, 0, 0)
	optionsList.Position = UDim2.fromOffset(8, 38)
	optionsList.BackgroundTransparency = 1
	optionsList.Parent = frame

	local listLayout = Instance.new("UIListLayout")
	listLayout.Padding = UDim.new(0, 2)
	listLayout.Parent = optionsList

	local open = false
	local function refreshOptions()
		for _, c in ipairs(optionsList:GetChildren()) do
			if c:IsA("TextButton") then c:Destroy() end
		end

		for _, opt in ipairs(elem._options) do
			local optBtn = Instance.new("TextButton")
			optBtn.Size = UDim2.new(1, 0, 0, 24)
			optBtn.BackgroundColor3 = theme.ElementHover
			optBtn.BorderSizePixel = 0
			optBtn.Text = opt
			optBtn.Font = Enum.Font.Gotham
			optBtn.TextSize = 11
			optBtn.TextColor3 = theme.TextDim
			optBtn.AutoButtonColor = false
			optBtn.Parent = optionsList

			makeCorner(optBtn, 6)

			-- Highlight if selected
			local function refresh()
				local isSel = table.find(elem._current, opt) ~= nil
				optBtn.TextColor3 = isSel and theme.Text or theme.TextDim
				optBtn.BackgroundColor3 = isSel and theme.Accent[1] or theme.ElementHover
				optBtn.BackgroundTransparency = isSel and 0.7 or 0
			end
			refresh()

			optBtn.MouseButton1Click:Connect(function()
				local idx = table.find(elem._current, opt)
				if elem._multi then
					if idx then
						table.remove(elem._current, idx)
					else
						table.insert(elem._current, opt)
					end
				else
					elem._current = {opt}
				end
				selectedText.Text = #elem._current > 0 and table.concat(elem._current, ", ") or "None"
				for _, child in ipairs(optionsList:GetChildren()) do
					if child:IsA("TextButton") then
						local isSel = table.find(elem._current, child.Text) ~= nil
						child.TextColor3 = isSel and theme.Text or theme.TextDim
						child.BackgroundColor3 = isSel and theme.Accent[1] or theme.ElementHover
						child.BackgroundTransparency = isSel and 0.7 or 0
					end
				end
				if elem._callback then
					task.spawn(pcall, elem._callback, elem._current)
				end
				if elem._flag and window._configSave.Enabled then
					window:SaveConfig()
				end
			end)
		end
	end
	refreshOptions()

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, 0, 0, 36)
	button.BackgroundTransparency = 1
	button.Text = ""
	button.AutoButtonColor = false
	button.Parent = frame

	button.MouseButton1Click:Connect(function()
		open = not open
		local listHeight = #elem._options * 26 + 8
		if open then
			tween(frame, 0.3, {Size = UDim2.new(1, 0, 0, 36 + listHeight)})
			tween(arrow, 0.3, {Rotation = 180})
		else
			tween(frame, 0.3, {Size = UDim2.new(1, 0, 0, 36)})
			tween(arrow, 0.3, {Rotation = 0})
		end
	end)

	elem._frame = frame
	elem._refreshOptions = refreshOptions
	elem._update = function(value)
		elem._current = type(value) == "table" and value or {value}
		selectedText.Text = #elem._current > 0 and table.concat(elem._current, ", ") or "None"
		refreshOptions()
	end
end

function VaenHub:_RefreshDropdown(elem)
	if elem._refreshOptions then elem._refreshOptions() end
end

