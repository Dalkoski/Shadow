-- STATUS (glowing green dot, name + value, optional metric)
VaenHub._Builders.Status = function(self, elem)
	local frame = newInst("Frame", {
		Size = UDim2.new(1, 0, 0, 36),
		BackgroundColor3 = THEME.ElementBg,
		BorderSizePixel = 0,
	}, elem._tab._page)
	corner(frame, CORNER_RADIUS)
	stroke(frame, THEME.Success, 0.75)

	-- Pulsing dot
	local dot = newInst("Frame", {
		AnchorPoint = Vector2.new(0, 0.5),
		Size = UDim2.fromOffset(7, 7),
		Position = UDim2.new(0, 14, 0.5, 0),
		BackgroundColor3 = THEME.Success,
		BorderSizePixel = 0,
	}, frame)
	corner(dot, 4)
	local dotGlow = newInst("UIStroke", {Color = THEME.Success, Transparency = 0.3, Thickness = 2}, dot)

	-- Pulse loop
	task.spawn(function()
		while frame.Parent do
			tween(dotGlow, 1.0, {Transparency = 0.85, Thickness = 5}, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
			task.wait(1.0)
			if not frame.Parent then break end
			tween(dotGlow, 1.0, {Transparency = 0.3, Thickness = 2}, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
			task.wait(1.0)
		end
	end)

	-- Name
	local nameLbl = newInst("TextLabel", {
		Size = UDim2.fromOffset(56, 36),
		Position = UDim2.fromOffset(30, 0),
		BackgroundTransparency = 1,
		Text = elem._name,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		TextColor3 = THEME.TextDim,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, frame)

	-- Value
	local valLbl = newInst("TextLabel", {
		Size = UDim2.new(1, -200, 1, 0),
		Position = UDim2.fromOffset(90, 0),
		BackgroundTransparency = 1,
		Text = elem._content or "—",
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, frame)

	-- Metric (right side)
	local metric = newInst("TextLabel", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(100, 36),
		Position = UDim2.new(1, -14, 0.5, 0),
		BackgroundTransparency = 1,
		Text = "",
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = THEME.Success,
		TextXAlignment = Enum.TextXAlignment.Right,
	}, frame)

	elem._frame = frame
	elem._setContent = function(c) valLbl.Text = tostring(c) end

	elem.Set = function(s, val, met)
		s._current = val
		valLbl.Text = tostring(val)
		if met ~= nil then metric.Text = tostring(met) end
		return s
	end
	elem.Metric = function(s, m) metric.Text = tostring(m); return s end
end

-- DROPDOWN
VaenHub._Builders.Dropdown = function(self, elem)
	elem._options = elem._options or {}
	if type(elem._current) ~= "table" then
