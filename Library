    local panelContainer = new("Frame", {
        Position = UDim2.fromOffset(0, 32),
        Size = UDim2.new(1, 0, 1, -32),
        BackgroundTransparency = 1,
        ZIndex = 2,
    }, content)
    self.PanelContainer = panelContainer

    -- Status bar (optional, set via SetStatus)
    self._statusBar = nil

    table.insert(Library._windows, self)
    return self
end

function Window:Minimize()
    if self._minimized then
        tween(self.Window, 0.3, { Size = UDim2.fromOffset(660, 420) }, Enum.EasingStyle.Quint)
        self._minimized = false
    else
        tween(self.Window, 0.3, { Size = UDim2.fromOffset(660, 44) }, Enum.EasingStyle.Quint)
        self._minimized = true
    end
end

function Window:Destroy()
    if self._destroyed then return end
    self._destroyed = true
    if self.Gui then self.Gui:Destroy() end
end

function Window:SetSectionTitle(text)
    if self.SectionTitle then self.SectionTitle.Text = text end
end

