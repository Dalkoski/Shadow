--==============================================================
function VaenHub:_BuildTab(win, t)
	-- Pill button (solid purple when active, transparent when not)
	local btn = newInst("TextButton", {
		Name = t._name,
		AutomaticSize = Enum.AutomaticSize.X,
		Size = UDim2.new(0, 0, 0, 26),
		BackgroundColor3 = THEME.ElementBg,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
	}, win._tabBar)
	corner(btn, 6)
	padding(btn, 0, 14, 0, 14)

	-- Inner layout (dot + label horizontally)
	local innerLayout = newInst("UIListLayout", {
		FillDirection = Enum.FillDirection.Horizontal,
		Padding = UDim.new(0, 8),
		VerticalAlignment = Enum.VerticalAlignment.Center,
		SortOrder = Enum.SortOrder.LayoutOrder,
	}, btn)

	-- Active indicator dot (small circle, only visible when active)
	local activeDot = newInst("Frame", {
		Size = UDim2.fromOffset(6, 6),
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		LayoutOrder = 1,
	}, btn)
	corner(activeDot, 3)

	-- Label
	local lbl = newInst("TextLabel", {
		AutomaticSize = Enum.AutomaticSize.X,
		Size = UDim2.new(0, 0, 1, 0),
		BackgroundTransparency = 1,
		Text = t._name,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = THEME.TextDim,
		LayoutOrder = 2,
	}, btn)

	t._button = btn
	t._buttonLabel = lbl
	t._activeDot = activeDot

	-- Click
	btn.MouseButton1Click:Connect(function() win:_SelectTab(t) end)

	-- Hover (only when not active)
	btn.MouseEnter:Connect(function()
		if win._currentTab ~= t then
			tween(lbl, 0.15, {TextColor3 = THEME.Text})
		end
	end)
	btn.MouseLeave:Connect(function()
		if win._currentTab ~= t then
			tween(lbl, 0.15, {TextColor3 = THEME.TextDim})
		end
	end)

	-- Page
	local page = newInst("ScrollingFrame", {
		Name = t._name,
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 2,
		ScrollBarImageColor3 = THEME.TextDim,
		ScrollBarImageTransparency = 0.7,
		CanvasSize = UDim2.new(),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false,
	}, win._content)
	listLayout(page, ELEMENT_SPACING)
	padding(page, 10, 14, 12, 14)

	t._page = page
end

--==============================================================
-- ELEMENT FACTORY
--==============================================================
function VaenHub:_NewElement(tab, kind, name)
	local e = setmetatable({
		_type = kind, _name = name, _tab = tab, _window = tab._window,
		_built = false, _enabled = true,
		-- Capture layout order at creation time so Section appears above its elements
		_layoutOrder = #tab._page:GetChildren(),
	}, {__index = Elem})

	-- Elements that don't need a callback — auto-build
	if kind == "Label" or kind == "Status" or kind == "Section"
		or kind == "Divider" or kind == "Paragraph" then
		task.defer(function() if not e._built then self:_Build(e) end end)
	end
	return e
end

function VaenHub:_Build(e)
	if e._built then return end
	e._built = true
	local b = self._Builders[e._type]
	if b then
		b(self, e)
		if e._frame then e._frame.LayoutOrder = e._layoutOrder end
		table.insert(e._window._elements, e)
	end
end

VaenHub._Builders = {}

