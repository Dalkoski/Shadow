        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 0,
        ScrollingDirection = Enum.ScrollingDirection.X,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.X,
        ClipsDescendants = true,
        Parent = TabBar,
    })
    new("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        VerticalAlignment = Enum.VerticalAlignment.Center,
        Padding = UDim.new(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = TabScroll,
    })
    new("UIPadding", {
        PaddingLeft = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 12),
        PaddingTop = UDim.new(0, 6),
        PaddingBottom = UDim.new(0, 6),
        Parent = TabScroll,
    })

    -- Divider between tab row and content
    local TabDivider = new("Frame", {
        Position = UDim2.new(0, 0, 1, 0),
        Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = theme.Stroke,
        BorderSizePixel = 0,
        BackgroundTransparency = 0.4,
        Parent = TabBar,
    })

    ----------------------------------------------------------
    -- Content container (holds all tab pages)
    ----------------------------------------------------------
    local Content = new("Frame", {
        Position = UDim2.new(0, 0, 0, 92),
        Size = UDim2.new(1, 0, 1, -92),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = Main,
    })

    Window._tabs = {}
    Window._activeTab = nil

    ----------------------------------------------------------
    -- Theme change handler
    ----------------------------------------------------------
    local function applyTheme(newTheme)
        Window._theme = newTheme
        theme = newTheme
        Main.BackgroundColor3 = newTheme.Background
        mainStroke.Color = newTheme.Stroke
        Topbar.BackgroundColor3 = newTheme.Topbar
        for _, child in ipairs(Topbar:GetChildren()) do
            if child:IsA("Frame") and child ~= Divider and child ~= TitleHolder and child ~= btnHolder then
                child.BackgroundColor3 = newTheme.Topbar
            end
        end
        Divider.BackgroundColor3 = newTheme.Stroke
        TitleText.TextColor3 = newTheme.Text
        SubtitleText.TextColor3 = newTheme.SubText
        TabBar.BackgroundColor3 = newTheme.Background
        TabDivider.BackgroundColor3 = newTheme.Stroke
        MinBtn.BackgroundColor3 = newTheme.Element
        MinBtn.TextColor3 = newTheme.Text
        CloseBtn.BackgroundColor3 = newTheme.Element
        CloseBtn.TextColor3 = newTheme.Text
        fireTheme(newTheme)
    end

    function Window:SetTheme(name)
        local t = Phantom.Themes[name]
        if not t then return end
        applyTheme(t)
    end

    ----------------------------------------------------------
    -- Show/Hide toggle keybind
    ----------------------------------------------------------
    local toggleKey = opts.Keybind or "K"
    local hidden = false
    local function setHidden(state)
        hidden = state
        Main.Visible = not state
    end
    Window._setHidden = setHidden
    -- Resolve the key once and guard against invalid names
    local toggleKeyCode = Enum.KeyCode[toggleKey] or Enum.KeyCode.K
    track(UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == toggleKeyCode then
            setHidden(not hidden)
        end
    end))

    ----------------------------------------------------------
    -- Tab Creation
    ----------------------------------------------------------
    function Window:CreateTab(name, icon)
        local Tab = {}

        -- Tab button in top bar
        local tabBtn = new("TextButton", {
            AutomaticSize = Enum.AutomaticSize.X,
            Size = UDim2.new(0, 0, 0, 30),
            BackgroundColor3 = theme.TabBackground,
            BackgroundTransparency = 0.3,
            BorderSizePixel = 0,
            Text = "",
            AutoButtonColor = false,
            Parent = TabScroll,
        })
        corner(tabBtn, UDim.new(0, 6))
        local tabStroke = stroke(tabBtn, theme.ElementStroke)
        tabStroke.Transparency = 0.5

        new("UIPadding", {
            PaddingLeft = UDim.new(0, 12),
            PaddingRight = UDim.new(0, 12),
            Parent = tabBtn,
        })
        new("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Padding = UDim.new(0, 6),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = tabBtn,
        })

        local tabIcon
        if icon and icon ~= "" then
            tabIcon = new("ImageLabel", {
                Size = UDim2.new(0, 16, 0, 16),
                BackgroundTransparency = 1,
                Image = tostring(icon),
                ImageColor3 = theme.SubText,
                LayoutOrder = 1,
                Parent = tabBtn,
            })
        end
        local tabLabel = new("TextLabel", {
            AutomaticSize = Enum.AutomaticSize.X,
            Size = UDim2.new(0, 0, 1, 0),
            BackgroundTransparency = 1,
            Font = FONT,
            Text = name,
            TextSize = 13,
            TextColor3 = theme.SubText,
            LayoutOrder = 2,
            Parent = tabBtn,
        })

        -- Tab page
        local page = new("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = theme.SubText,
            ScrollBarImageTransparency = 0.6,
            Visible = false,
            Parent = Content,
        })
        new("UIListLayout", {
            Padding = UDim.new(0, 6),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Parent = page,
        })
        new("UIPadding", {
            PaddingLeft = UDim.new(0, 14),
            PaddingRight = UDim.new(0, 14),
            PaddingTop = UDim.new(0, 10),
            PaddingBottom = UDim.new(0, 14),
            Parent = page,
        })

        local function selectTab()
            for _, t in ipairs(Window._tabs) do
                t._btn.BackgroundColor3 = theme.TabBackground
                t._btn.BackgroundTransparency = 0.3
                t._label.TextColor3 = theme.SubText
                if t._icon then t._icon.ImageColor3 = theme.SubText end
                t._page.Visible = false
                t._stroke.Transparency = 0.5
            end
            tabBtn.BackgroundColor3 = theme.TabSelected
            tabBtn.BackgroundTransparency = 0
            tabLabel.TextColor3 = theme.Text
            if tabIcon then tabIcon.ImageColor3 = theme.Text end
            page.Visible = true
            tabStroke.Transparency = 0.2
            Window._activeTab = Tab
        end
        tabBtn.MouseButton1Click:Connect(selectTab)

        Tab._btn   = tabBtn
        Tab._page  = page
        Tab._label = tabLabel
        Tab._icon  = tabIcon
        Tab._stroke = tabStroke

        table.insert(Window._tabs, Tab)
        if #Window._tabs == 1 then
            selectTab()
        end

        -- Theme listener for tab
        addListener(function(nt)
            theme = nt
            if Window._activeTab == Tab then
                tabBtn.BackgroundColor3 = nt.TabSelected
                tabLabel.TextColor3 = nt.Text
                if tabIcon then tabIcon.ImageColor3 = nt.Text end
            else
                tabBtn.BackgroundColor3 = nt.TabBackground
                tabLabel.TextColor3 = nt.SubText
                if tabIcon then tabIcon.ImageColor3 = nt.SubText end
            end
            tabStroke.Color = nt.ElementStroke
            page.ScrollBarImageColor3 = nt.SubText
        end)

        ----------------------------------------------------------
        -- Element factory (shared base for hover styling)
        ----------------------------------------------------------
        local function baseElement(height)
