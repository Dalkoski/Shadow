--==============================================================
-- 4. CHAINABLE ELEMENT BUILDERS
--==============================================================
-- All elements share these chainable methods. The actual builder pattern
-- stores config on the element, then _MaterializeElement creates the UI
-- when the chain ends (lazy build via __index/__newindex magic).

VaenHub._ElementMeta = {}
local Elem = VaenHub._ElementMeta

function Elem:Default(value)
	self._default = value
	self._current = value
	return self
end

function Elem:Range(min, max)
	self._min = min
	self._max = max
	return self
end

function Elem:Increment(step)
	self._step = step
	return self
end

function Elem:Suffix(suffix)
	self._suffix = suffix
	return self
end

function Elem:Options(opts)
	self._options = opts
	return self
end

function Elem:Multi(enabled)
	self._multi = enabled ~= false
	return self
end

function Elem:Placeholder(text)
	self._placeholder = text
	return self
end

function Elem:Flag(flagName)
	self._flag = flagName
	VaenHub.Flags[flagName] = self
	return self
end

function Elem:Icon(icon)
	self._icon = icon
	return self
end

function Elem:Hold(enabled)
	self._hold = enabled ~= false
	return self
end

function Elem:Content(text)
	self._content = text
	if self._frame and self._frame:FindFirstChild("Content") then
		self._frame.Content.Text = text
	end
	return self
end

function Elem:OnChange(callback)
	self._callback = callback
	-- Materialize the element now that we have the callback
	-- (or finalize if already built)
	if not self._built then
		VaenHub:_MaterializeElement(self)
	end
	return self
end

-- Buttons use OnClick instead of OnChange (semantic alias)
function Elem.OnClick(self, callback)
	return self:OnChange(callback)
end

-- Programmatically set the value
function Elem:Set(value)
	self._current = value
	VaenHub:_UpdateElement(self, value)
	if self._callback then
		task.spawn(pcall, self._callback, value)
	end
	if self._flag and self._window and self._window._configSave.Enabled then
		self._window:SaveConfig()
	end
	return self
end

function Elem:Get()
	return self._current
end

-- Force build for elements with no callback (Labels, Status, Section, Divider)
function Elem:Build()
	if not self._built then
		VaenHub:_MaterializeElement(self)
	end
	return self
end

-- Refreshes options (for dropdowns)
function Elem:Refresh(newOptions)
	self._options = newOptions
	VaenHub:_RefreshDropdown(self)
	return self
end

-- Disable/enable the element
function Elem:Enabled(enabled)
	self._enabled = enabled ~= false
	VaenHub:_SetElementEnabled(self, self._enabled)
	return self
end

-- Destroy a single element
function Elem:Destroy()
	if self._frame then
		self._frame:Destroy()
	end
	if self._flag then
		VaenHub.Flags[self._flag] = nil
	end
end


--==============================================================
-- 5. PROTECTION LAYER
--==============================================================

function VaenHub:_HideFromCoreGui(window)
	if not window._gui then return end
	local gui = window._gui

	-- Randomize name to avoid pattern detection
	gui.Name = HttpService:GenerateGUID(false):sub(1, 8)

	-- Try every protection method available
	local protected = false
	if gethui then
		pcall(function() gui.Parent = gethui() protected = true end)
	end
	if not protected and syn and syn.protect_gui then
		pcall(function()
			syn.protect_gui(gui)
			gui.Parent = CoreGui
			protected = true
		end)
	end
	if not protected and protectgui then
		pcall(function()
			protectgui(gui)
			gui.Parent = CoreGui
			protected = true
		end)
	end
	if not protected then
		pcall(function() gui.Parent = CoreGui end)
	end
end

function VaenHub:_EnableAntiAFK(window)
	-- Disconnect the idle kick connection
	local success = pcall(function()
		local VirtualUser = getService("VirtualUser")
		local conn = LocalPlayer.Idled:Connect(function()
			VirtualUser:CaptureController()
			VirtualUser:ClickButton2(Vector2.new())
		end)
		table.insert(window._connections, conn)
	end)
end

function VaenHub:_EnableAntiKick(window)
	-- Hook __namecall to block kicks
	if not hookmetamethod then return end

	local blockedMethods = {
		Kick = true,
		kick = true,
	}

	local old
	old = hookmetamethod(game, "__namecall", function(self, ...)
		local method = getnamecallmethod()
		if blockedMethods[method] and self == LocalPlayer then
			return nil
		end
		return old(self, ...)
	end)

	-- Store original for restoration
	window._originalNamecall = old
end

function VaenHub:_EnableAntiLag(window)
	pcall(function()
		settings().Rendering.QualityLevel = 1
		Lighting.GlobalShadows = false
		Lighting.FogEnd = 1e10
		for _, v in ipairs(workspace:GetDescendants()) do
			if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") then
				v.Enabled = false
			elseif v:IsA("Decal") or v:IsA("Texture") then
				v.Transparency = 1
			end
		end
	end)
end

function VaenHub:_EnableAutoRejoin(window)
	local placeId = game.PlaceId
	local jobId   = game.JobId

	-- On game close, attempt rejoin
	local conn = game:GetService("GuiService").ErrorMessageChanged:Connect(function(msg)
		if msg and msg ~= "" then
			task.wait(3)
			pcall(function()
				TeleportService:TeleportToPlaceInstance(placeId, jobId, LocalPlayer)
			end)
		end
	end)
	table.insert(window._connections, conn)
end

function VaenHub:_SetupServerHop(window, opts)
	window._serverHop = function()
		local servers = {}
		local req = (syn and syn.request) or http_request or request
		if not req then return false end

		local success, response = pcall(function()
			return req({
				Url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", game.PlaceId),
				Method = "GET",
			})
		end)

		if not success or not response then return false end

		local data = HttpService:JSONDecode(response.Body)
		if not data or not data.data then return false end

		for _, server in ipairs(data.data) do
			if server.id ~= game.JobId and server.playing < server.maxPlayers then
				table.insert(servers, server)
			end
		end

		if #servers == 0 then return false end

		-- Sort by player count if preferLow
		if opts.PreferLow then
			table.sort(servers, function(a, b) return a.playing < b.playing end)
		end

		local chosen = servers[1]
		TeleportService:TeleportToPlaceInstance(game.PlaceId, chosen.id, LocalPlayer)
		return true
	end
end


