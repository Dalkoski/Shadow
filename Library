    if getBtnLbl then tween(getBtnLbl, 0.3, { TextTransparency = 0 }) end
    tween(inputFrame, 0.3, { BackgroundTransparency = wA(0.05) })
    tween(inputStroke, 0.3, { Transparency = wA(0.12) })
    tween(input, 0.3, { TextTransparency = 0 })
    tween(submit, 0.3, { BackgroundTransparency = wA(1) })
    tween(submitLbl, 0.3, { TextTransparency = 0 })
    tween(cancel, 0.3, { BackgroundTransparency = 1 })
    tween(cancelStroke, 0.3, { Transparency = wA(0.1) })
    tween(cancelLbl, 0.3, { TextTransparency = wA(0.85) })

    local closing = false
    local function closeAnim(success, cb)
        if closing then return end
        closing = true
        if success then
            tween(inputStroke, 0.2, { Color = COLOR.Success, Transparency = 0 })
            tween(submit, 0.2, { BackgroundColor3 = COLOR.Success })
            tween(glow, 0.3, { BackgroundColor3 = COLOR.Success })
            task.wait(0.35)
        end
        tween(backdrop, 0.3, { BackgroundTransparency = 1 })
        tween(modal, 0.3, {
            Size = UDim2.fromOffset(MW * 0.9, MH * 0.9),
            BackgroundTransparency = 1,
        }, Enum.EasingStyle.Quart)
        tween(modalStroke, 0.3, { Transparency = 1 })
        tween(glow, 0.3, { BackgroundTransparency = 1 })
        for _, d in ipairs(modal:GetDescendants()) do
            if d:IsA("TextLabel") or d:IsA("TextBox") then tween(d, 0.2, { TextTransparency = 1 }) end
            if d:IsA("UIStroke") then tween(d, 0.2, { Transparency = 1 }) end
            if d:IsA("Frame") and d ~= glow then tween(d, 0.2, { BackgroundTransparency = 1 }) end
            if d:IsA("ImageLabel") then tween(d, 0.2, { ImageTransparency = 1 }) end
        end
        task.delay(0.32, function() if gui then gui:Destroy() end if cb then cb() end end)
    end

    cancel.MouseButton1Click:Connect(function()
        closeAnim(false, function() if onCancel then onCancel() end end)
    end)

    local function showStatus(text, color)
        if not errLbl then return end
        errLbl.Text = text or ""
        errLbl.TextColor3 = color or COLOR.Danger
        errLbl.TextTransparency = 1
        tween(errLbl, 0.2, { TextTransparency = wA(0.9) })
        task.delay(2.5, function()
            if errLbl and errLbl.Parent then tween(errLbl, 0.5, { TextTransparency = 1 }) end
        end)
    end

    local function trySubmit()
        if closing then return end
        local text = input.Text
        if text == "" then return end
        local valid, errMsg = false, nil
        if hasValidate then
            local ok, res = pcall(opts.Validate, text)
            if ok then
                if type(res) == "table" then
                    valid = res.success == true
                    errMsg = res.error
                else
                    valid = res == true
                end
            else
                errMsg = tostring(res)
            end
        else
            for _, k in ipairs(keys) do
                if text == k then valid = true; break end
            end
        end
        if valid then
            if opts.SaveKey and not hasValidate then safeWrite(path, text) end
            closeAnim(true, function() onSuccess() end)
            return
        end
        showStatus(errMsg or "Invalid key", COLOR.Danger)
        tween(inputStroke, 0.15, { Color = COLOR.Danger, Transparency = 0 })
        local origPos = modal.Position
        for _ = 1, 4 do
            tween(modal, 0.05, { Position = origPos + UDim2.fromOffset(12, 0) }, Enum.EasingStyle.Quad)
            task.wait(0.05)
            tween(modal, 0.05, { Position = origPos - UDim2.fromOffset(12, 0) }, Enum.EasingStyle.Quad)
            task.wait(0.05)
        end
        tween(modal, 0.06, { Position = origPos })
        task.wait(0.5)
        tween(inputStroke, 0.3, { Color = Color3.fromRGB(255,255,255), Transparency = wA(0.12) })
    end
    submit.MouseButton1Click:Connect(trySubmit)
    input.FocusLost:Connect(function(enter) if enter then trySubmit() end end)

    if getBtn then
        getBtn.MouseButton1Click:Connect(function()
            if closing then return end
            local ok, a, b = pcall(opts.GetKey)
            if ok and a then
                showStatus(b or "Key link copied to clipboard", COLOR.Success)
            else
                showStatus((ok and b) or (not ok and tostring(a)) or "Try again later", COLOR.Warning)
            end
        end)
    end
end

local Window = {}
