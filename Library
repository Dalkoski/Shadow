--==============================================================
-- TAB BUILDER (proper layoutorder, icons, gradient pill)
--==============================================================
function VaenHub:_BuildTab(win, t)
	win._tabOrder = win._tabOrder + 1

	-- Calculate label width manually
	local iconStrForWidth = tostring(t._icon or "")
	local hasIcon = t._icon and (LUCIDE[iconStrForWidth] or GLYPHS[iconStrForWidth] or iconStrForWidth:match("^rbxasset") or iconStrForWidth:match("^%d+$"))
	local approxTextWidth = #t._name * 7
	local btnWidth = 24 + approxTextWidth + (hasIcon and 24 or 0)

	-- Tab pill — INACTIVE by default (transparent). _SelectTab will set active state instantly.
	local btn = new("Frame", {
		Name = "Tab_" .. t._name,
		Size = UDim2.fromOffset(btnWidth, 30),
		BackgroundColor3 = Color3.fromRGB(38, 32, 64),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		LayoutOrder = win._tabOrder,
		Visible = true,
		ClipsDescendants = false,
		ZIndex = 3,
	}, win._tabBar)
	corner(btn, 6)

	-- No gradient overlay on tabs (keeps active fill solid violet per spec)
	local btnStroke = nil

	-- Icon resolution: LUCIDE dict → raw asset path → glyph fallback
	local iconLbl
	local labelX = 12
	if t._icon then
		local iconStr = tostring(t._icon)
		-- Priority 1: Lucide dictionary lookup (e.g. "bolt", "user", "eye", "shield")
		if LUCIDE[iconStr] then
			iconLbl = new("ImageLabel", {
				AnchorPoint = Vector2.new(0, 0.5),
				Size = UDim2.fromOffset(16, 16),
				Position = UDim2.new(0, 12, 0.5, 0),
				BackgroundTransparency = 1,
				Image = LUCIDE[iconStr],
				ImageColor3 = Color3.fromRGB(140, 140, 155),
			}, btn)
			labelX = 34
		-- Priority 2: raw asset path
		elseif iconStr:match("^rbxasset") or iconStr:match("^rbxassetid") or iconStr:match("^%d+$") then
			local src = (iconStr:match("^rbxasset") or iconStr:match("^rbxassetid")) and iconStr or ("rbxassetid://" .. iconStr)
			iconLbl = new("ImageLabel", {
				AnchorPoint = Vector2.new(0, 0.5),
				Size = UDim2.fromOffset(16, 16),
				Position = UDim2.new(0, 12, 0.5, 0),
				BackgroundTransparency = 1,
				Image = src,
				ImageColor3 = Color3.fromRGB(140, 140, 155),
			}, btn)
			labelX = 34
		-- Priority 3: glyph fallback
		elseif GLYPHS[iconStr] then
			iconLbl = new("TextLabel", {
				AnchorPoint = Vector2.new(0, 0.5),
				Size = UDim2.fromOffset(14, 28),
				Position = UDim2.new(0, 12, 0.5, 0),
				BackgroundTransparency = 1,
				Text = GLYPHS[iconStr],
				Font = Enum.Font.GothamBold,
				TextSize = 13,
				TextColor3 = Color3.fromRGB(140, 140, 155),
				TextXAlignment = Enum.TextXAlignment.Center,
			}, btn)
			labelX = 32
		end
	end

	local lbl = new("TextLabel", {
		AnchorPoint = Vector2.new(0, 0.5),
		Size = UDim2.new(1, -(labelX + 12), 1, 0),
		Position = UDim2.new(0, labelX, 0.5, 0),
		BackgroundTransparency = 1,
		Text = t._name,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = Color3.fromRGB(140, 140, 155),
		TextXAlignment = Enum.TextXAlignment.Center,
		TextYAlignment = Enum.TextYAlignment.Center,
	}, btn)

	local clickBtn = new("TextButton", {
		Size = UDim2.fromScale(1,1),
		BackgroundTransparency = 1,
		Text = "",
		AutoButtonColor = false,
	}, btn)

	t._button = btn
	t._buttonLabel = lbl
	t._buttonIcon = iconLbl
	t._buttonStroke = btnStroke
	t._gradient = nil

	clickBtn.MouseButton1Click:Connect(function() win:_SelectTab(t) end)
	clickBtn.MouseEnter:Connect(function()
		if win._currentTab ~= t then
			tween(lbl, 0.15, {TextColor3 = THEME.Text})
			if iconLbl then
				if iconLbl:IsA("ImageLabel") then
					tween(iconLbl, 0.15, {ImageColor3 = THEME.Text})
				else
					tween(iconLbl, 0.15, {TextColor3 = THEME.Text})
				end
			end
		end
	end)
	clickBtn.MouseLeave:Connect(function()
		if win._currentTab ~= t then
			tween(lbl, 0.15, {TextColor3 = THEME.TextDim})
			if iconLbl then
				if iconLbl:IsA("ImageLabel") then
					tween(iconLbl, 0.15, {ImageColor3 = THEME.TextDim})
				else
					tween(iconLbl, 0.15, {TextColor3 = THEME.TextDim})
				end
			end
		end
	end)

	-- Page
	local page = new("ScrollingFrame", {
		Name = t._name,
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 2,
		ScrollBarImageColor3 = THEME.TextDim,
		ScrollBarImageTransparency = 0.7,
		CanvasSize = UDim2.new(),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false,
	}, win._content)
	list(page, ELEM_GAP)
	pad(page, 10, 14, 12, 14)
	t._page = page
end

--==============================================================
-- ELEMENT FACTORY (with explicit LayoutOrder pre-assignment)
--==============================================================
function VaenHub:_NewElement(tab, kind, name)
	tab._elemOrder = tab._elemOrder + 1
	local e = setmetatable({
		_type = kind, _name = name, _tab = tab, _window = tab._window,
		_built = false, _enabled = true,
		_layoutOrder = tab._elemOrder,
	}, {__index = Elem})

	if kind == "Label" or kind == "Status" or kind == "Section"
		or kind == "Divider" or kind == "Paragraph" then
		task.defer(function() if not e._built then self:_Build(e) end end)
	end
	return e
end

function VaenHub:_Build(e)
	if e._built then return end
	e._built = true
	local b = self._Builders[e._type]
	if b then
		b(self, e)
		if e._frame then e._frame.LayoutOrder = e._layoutOrder end
		table.insert(e._window._elements, e)
	end
end

VaenHub._Builders = {}

--==============================================================
-- ELEMENT HELPERS
--==============================================================
local function row(elem, h)
	local f = new("Frame", {
		Size = UDim2.new(1, 0, 0, h or ELEMENT_H),
		BackgroundColor3 = THEME.ElementBg,
		BorderSizePixel = 0,
		LayoutOrder = elem._layoutOrder,
	}, elem._tab._page)
	corner(f, RADIUS)
	stroke(f, THEME.Border, 0.7)
	f.MouseEnter:Connect(function() tween(f, 0.15, {BackgroundColor3 = THEME.ElementHover}) end)
	f.MouseLeave:Connect(function() tween(f, 0.15, {BackgroundColor3 = THEME.ElementBg}) end)
	return f
end

local function addIcon(frame, iconID)
	if not iconID or iconID == "" then return nil, 14 end

	local imageSource = nil
	local glyphText = nil

	if type(iconID) == "string" then
		-- Priority 1: LUCIDE dictionary
		if LUCIDE[iconID] then
			imageSource = LUCIDE[iconID]
		-- Priority 2: raw asset path
		elseif iconID:match("^rbxasset://") or iconID:match("^rbxassetid://") then
			imageSource = iconID
		elseif iconID:match("^%d+$") then
			imageSource = "rbxassetid://" .. iconID
		-- Priority 3: glyph fallback
		elseif GLYPHS[iconID] then
			glyphText = GLYPHS[iconID]
		end
	end

	if imageSource then
		local img = new("ImageLabel", {
			AnchorPoint = Vector2.new(0, 0.5),
			Size = UDim2.fromOffset(18, 18),
			Position = UDim2.new(0, 14, 0.5, 0),
			BackgroundTransparency = 1,
			Image = imageSource,
			ImageColor3 = THEME.AccentEnd,
		}, frame)
		return img, 40
	elseif glyphText then
		local img = new("TextLabel", {
			AnchorPoint = Vector2.new(0, 0.5),
			Size = UDim2.fromOffset(20, 20),
			Position = UDim2.new(0, 14, 0.5, 0),
			BackgroundTransparency = 1,
			Text = glyphText,
			Font = Enum.Font.GothamBold,
			TextSize = 14,
			TextColor3 = THEME.AccentEnd,
		}, frame)
		return img, 40
	end

	return nil, 14
end

