local function applyIcon(parent, icon, size, alpha)
    if not icon or icon == "" or icon == 0 then return nil end
    size = size or 14
    alpha = alpha or 0.7
    local zi = (parent.ZIndex or 1) + 1
    local function asImage(props)
        local base = {
            Name = "Icon",
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(0.5, 0.5),
            Size = UDim2.fromOffset(size, size),
            BackgroundTransparency = 1,
            ImageColor3 = Color3.fromRGB(255,255,255),
            ImageTransparency = 1 - alpha,
            ZIndex = zi,
        }
        for k, v in pairs(props) do base[k] = v end
        return new("ImageLabel", base, parent)
    end
    if type(icon) == "number" then return asImage({ Image = "rbxassetid://"..icon }) end
    if type(icon) == "string" then
        if icon:sub(1,8) == "rbxasset" or icon:sub(1,4) == "http" then
            return asImage({ Image = icon })
        end
        if icon:match("^%d+$") then return asImage({ Image = "rbxassetid://"..icon }) end
        if Lucide and Lucide["48px"] and Lucide["48px"][icon] then
            local d = Lucide["48px"][icon]
            return asImage({
                Image = "rbxassetid://"..d[1],
                ImageRectSize = Vector2.new(d[2][1], d[2][2]),
                ImageRectOffset = Vector2.new(d[3][1], d[3][2]),
            })
        end
        if Lucide then return nil end
        return new("TextLabel", {
            Name = "Icon",
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(0.5, 0.5),
            Size = UDim2.fromOffset(size + 8, size + 8),
            BackgroundTransparency = 1,
            Text = icon,
            Font = Enum.Font.GothamMedium,
            TextSize = size + 4,
            TextColor3 = Color3.fromRGB(255,255,255),
            TextTransparency = 1 - alpha,
            ZIndex = zi,
        }, parent)
    end
end

