        return c
    end
    repaint()
    local open = false
    swatch.MouseButton1Click:Connect(function()
        open = not open
        panel.Visible = open
        tween(card, 0.25, { Size = UDim2.new(1, -2, 0, open and 168 or 50) }, Enum.EasingStyle.Quint)
    end)
    local function svHit(p)
        local pos, size = sv.AbsolutePosition, sv.AbsoluteSize
        s = math.clamp((p.X - pos.X) / size.X, 0, 1)
        v = math.clamp(1 - (p.Y - pos.Y) / size.Y, 0, 1)
        local c = repaint()
        win.Flags[flag] = c; pcall(cb, c)
    end
    local function hueHit(p)
        local pos, size = hue.AbsolutePosition, hue.AbsoluteSize
        h = math.clamp((p.X - pos.X) / size.X, 0, 1)
        local c = repaint()
        win.Flags[flag] = c; pcall(cb, c)
    end
    local function bindDrag(zone, fn)
        local b = new("TextButton", { Size = UDim2.fromScale(1,1), BackgroundTransparency = 1,
            Text = "", AutoButtonColor = false, ZIndex = 9 }, zone)
        b.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
                and input.UserInputType ~= Enum.UserInputType.Touch then return end
            fn(input.Position)
            local rs
            rs = RunService.RenderStepped:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    rs:Disconnect()
                    win:SaveConfig()
                    return
                end
                fn(input.Position)
            end)
        end)
    end
    bindDrag(sv, svHit)
    bindDrag(hue, hueHit)
    local element = {
        Type = "ColorPicker", Value = startColor,
        Set = function(self2, c)
            if typeof(c) == "Color3" then
                h, s, v = c:ToHSV()
                self2.Value = repaint()
                win.Flags[flag] = self2.Value; pcall(cb, self2.Value)
            end
        end,
        Get = function() return Color3.fromHSV(h, s, v) end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

