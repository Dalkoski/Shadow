    corner(card, 10)
    stroke(card, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)

    new("UIPadding", {
        PaddingTop = UDim.new(0, 10),
        PaddingBottom = UDim.new(0, 10),
        PaddingLeft = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 12),
    }, card)

    new("Frame", {
        Size = UDim2.new(0, 3, 1, -8),
        Position = UDim2.fromOffset(0, 4),
        BackgroundColor3 = accent,
        BorderSizePixel = 0,
    }, card)

    new("TextLabel", {
        Size = UDim2.new(1, -10, 0, 16),
        Position = UDim2.fromOffset(10, 0),
        BackgroundTransparency = 1,
        Text = title,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = COLOR.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
    }, card)

    local body = new("TextLabel", {
        Size = UDim2.new(1, -10, 0, 0),
        Position = UDim2.fromOffset(10, 18),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Text = content,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextTransparency = whiteAlpha(0.7),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
    }, card)

    -- slide in
    card.Position = UDim2.new(1, 50, 0, 0)
    tween(card, 0.3, { Position = UDim2.new(0, 0, 0, 0) }, Enum.EasingStyle.Quint)

    task.delay(duration, function()
        if not card.Parent then return end
        local tw = tween(card, 0.25, { Position = UDim2.new(1, 50, 0, 0) }, Enum.EasingStyle.Quint)
        tw.Completed:Wait()
        card:Destroy()
    end)
end

