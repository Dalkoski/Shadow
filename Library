local function attachHover(card, base, hover)
    base = base or wA(0.025)
    hover = hover or wA(0.05)
    local st = card:FindFirstChildOfClass("UIStroke")
    card.MouseEnter:Connect(function()
        tween(card, 0.15, { BackgroundTransparency = hover })
        if st then tween(st, 0.15, { Transparency = wA(0.12) }) end
    end)
    card.MouseLeave:Connect(function()
        tween(card, 0.15, { BackgroundTransparency = base })
        if st then tween(st, 0.15, { Transparency = wA(0.06) }) end
    end)
end

local function registerFlag(win, flag, element)
    if not flag then return end
    Library.Flags[flag] = element
    win.Flags[flag] = element.Value
end
local function updateFlag(win, flag, value) if flag then win.Flags[flag] = value end end

