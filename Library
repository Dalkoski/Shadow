    Quick API:
        local Phantom = loadstring(game:HttpGet("..."))()
        local Window = Phantom:CreateWindow({ Name = "Title", Subtitle = "Desc", Keybind = "K" })
        local Tab    = Window:CreateTab("Main", "rbxassetid://...")
        Tab:CreateSection("Section")
        Tab:CreateButton({ Name = "Click",   Callback = function() end })
        Tab:CreateToggle({ Name = "Toggle",  Default = false, Flag = "tog1", Callback = function(v) end })
        Tab:CreateSlider({ Name = "Slider",  Min = 0, Max = 100, Default = 50, Increment = 1, Suffix = "ms", Flag = "sl1", Callback = function(v) end })
        Tab:CreateInput({ Name = "Input",    Placeholder = "...", Default = "", ClearOnFocus = false, Flag = "in1", Callback = function(t) end })
        Tab:CreateKeybind({ Name = "Bind",   Default = "F", Flag = "kb1", Callback = function() end })
        Tab:CreateDropdown({ Name = "Drop",  Options = {"A","B"}, Default = "A", Multi = false, Flag = "dd1", Callback = function(v) end })
        Tab:CreateColorPicker({ Name="Color",Default=Color3.new(1,1,1), Flag="cp1", Callback=function(c) end })
        Tab:CreateLabel("text")
        Tab:CreateParagraph({ Title = "T", Content = "C" })
        Phantom:Notify({ Title = "...", Content = "...", Duration = 5 })
        Phantom.Flags["tog1"]:Set(true)              -- works on any element with a Flag
        Window:SetTheme("Dark")                       -- "Dark" | "Light" | "Ocean" | "Amethyst"
        Window:Destroy()
]]

