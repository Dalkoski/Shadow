function Phantom:CreateWindow(opts)
    opts = opts or {}
    local Window = {}
    local theme = self.Themes[opts.Theme or "Dark"] or self.Themes.Dark
    Window._theme = theme
    Window._connections = {}  -- track all connections for cleanup

    local function track(conn)
        table.insert(Window._connections, conn)
        return conn
    end

    -- Window-local theme listener helper (auto-tagged for cleanup)
    local function addListener(fn)
        addThemeListener(fn, Window)
    end

    -- Root GUI
    local gui = new("ScreenGui", {
        Name = "Phantom_" .. HttpService:GenerateGUID(false):sub(1, 8),
        IgnoreGuiInset = true,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder = 100,
    })
    safeParent(gui)
    Window._gui = gui
    activeWindow = Window

    -- Main container
    local Main = new("Frame", {
        Name = "Main",
        Size = UDim2.new(0, 540, 0, 420),
        Position = UDim2.new(0.5, -270, 0.5, -210),
        BackgroundColor3 = theme.Background,
        BorderSizePixel = 0,
        Parent = gui,
        ClipsDescendants = true,
    })
    corner(Main, UDim.new(0, 10))
    local mainStroke = stroke(Main, theme.Stroke)

    -- Topbar
    local Topbar = new("Frame", {
        Name = "Topbar",
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundColor3 = theme.Topbar,
        BorderSizePixel = 0,
        Parent = Main,
    })
    corner(Topbar, UDim.new(0, 10))
    -- Topbar bottom edge cover (so corner doesn't make bottom rounded)
    new("Frame", {
        Position = UDim2.new(0, 0, 1, -10),
        Size = UDim2.new(1, 0, 0, 10),
        BackgroundColor3 = theme.Topbar,
        BorderSizePixel = 0,
        Parent = Topbar,
    })
    -- Divider line below topbar (between topbar and content)
    local Divider = new("Frame", {
        Position = UDim2.new(0, 0, 1, 0),
        Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = theme.Stroke,
        BorderSizePixel = 0,
        BackgroundTransparency = 0.3,
        Parent = Topbar,
    })

    do
        local dc1, dc2 = makeDraggable(Main, Topbar)
        track(dc1); track(dc2)
    end

    -- Title group (left side of topbar)
