local function loadInterface()
    local ok, result = pcall(function()
        return game:GetObjects("rbxassetid://" .. RayfieldAssetId)[1]
    end)
    if not ok or not result then
        error("[Phantom] Failed to load interface asset: " .. tostring(result))
    end
    return result
end

