-- 7. KEY SYSTEM (purple solid Verify, glowing dot, clean)
--==============================================================
function VaenHub:_RunKeySystem(win, ks)
	-- Saved key check
	if ks.SaveKey and isfile then
		local path = "VaenHub/Keys/"..(ks.FileName or "key")..".key"
		if isfile(path) then
			local ok, saved = pcall(readfile, path)
			if ok then
				for _, k in ipairs(ks.Keys or {}) do
					if saved == k then return true end
				end
			end
		end
	end

	-- Build UI
	local gui = newInst("ScreenGui", {
		Name = HttpService:GenerateGUID(false):sub(1,8),
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 999,
		ResetOnSpawn = false,
	})
	if gethui then gui.Parent = gethui()
	elseif syn and syn.protect_gui then syn.protect_gui(gui); gui.Parent = CoreGui
	else gui.Parent = CoreGui end

	-- Blur
	local blur = newInst("BlurEffect", {Size = 0}, Lighting)
	tween(blur, 0.5, {Size = 22})

	-- Dim overlay
	local dim = newInst("Frame", {
		Size = UDim2.fromScale(1,1),
		BackgroundColor3 = Color3.new(0,0,0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
	}, gui)
	tween(dim, 0.4, {BackgroundTransparency = 0.55})

	-- Card
	local card = newInst("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromOffset(420, 0),
		BackgroundColor3 = THEME.Background,
		BorderSizePixel = 0,
		ClipsDescendants = true,
	}, gui)
	corner(card, 12)
	stroke(card, Color3.fromRGB(255,255,255), 0.88)

	-- Top accent bar (solid purple, thin)
	local accentBar = newInst("Frame", {
		Size = UDim2.new(1, 0, 0, 2),
		BackgroundColor3 = THEME.Accent,
		BorderSizePixel = 0,
		ZIndex = 3,
	}, card)

	-- Logo (small purple square in top-left)
	local logo = newInst("Frame", {
		Size = UDim2.fromOffset(24, 24),
		Position = UDim2.fromOffset(20, 20),
		BackgroundColor3 = THEME.Accent,
		BorderSizePixel = 0,
	}, card)
	corner(logo, 6)
	newInst("TextLabel", {
		Size = UDim2.fromScale(1,1),
		BackgroundTransparency = 1,
		Text = "V",
		Font = Enum.Font.GothamBold,
		TextSize = 13,
		TextColor3 = Color3.fromRGB(255,255,255),
	}, logo)

	-- Title
	local title = newInst("TextLabel", {
		Size = UDim2.new(1, -80, 0, 22),
		Position = UDim2.fromOffset(56, 18),
		BackgroundTransparency = 1,
		Text = ks.Title or win._name,
		Font = Enum.Font.GothamBold,
		TextSize = 15,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTransparency = 1,
	}, card)

	-- Subtitle
	local sub = newInst("TextLabel", {
		Size = UDim2.new(1, -80, 0, 14),
		Position = UDim2.fromOffset(56, 38),
		BackgroundTransparency = 1,
		Text = ks.Subtitle or "Authentication",
		Font = Enum.Font.Gotham,
		TextSize = 11,
		TextColor3 = THEME.TextDim,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTransparency = 1,
	}, card)

	-- Close
	local close = newInst("TextButton", {
		Size = UDim2.fromOffset(28, 28),
		Position = UDim2.new(1, -36, 0, 16),
		BackgroundTransparency = 1,
		Text = "×",
		Font = Enum.Font.GothamBold,
		TextSize = 22,
		TextColor3 = THEME.TextDim,
		AutoButtonColor = false,
	}, card)
	close.MouseEnter:Connect(function() tween(close, 0.15, {TextColor3 = THEME.Text}) end)
	close.MouseLeave:Connect(function() tween(close, 0.15, {TextColor3 = THEME.TextDim}) end)

	-- Note (instruction text)
	local note = newInst("TextLabel", {
		Size = UDim2.new(1, -40, 0, 32),
		Position = UDim2.fromOffset(20, 78),
		BackgroundTransparency = 1,
		Text = ks.Note or "Enter your access key below.",
		Font = Enum.Font.Gotham,
		TextSize = 12,
		TextColor3 = THEME.TextDim,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		TextTransparency = 1,
	}, card)

	-- Input
	local inputFrame = newInst("Frame", {
		Size = UDim2.new(1, -40, 0, 38),
		Position = UDim2.fromOffset(20, 120),
		BackgroundColor3 = THEME.ElementBg,
		BorderSizePixel = 0,
	}, card)
	corner(inputFrame, 8)
	local inputStrokeObj = stroke(inputFrame, THEME.Border, 0.5)

	local inputBox = newInst("TextBox", {
		Size = UDim2.new(1, -24, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		BackgroundTransparency = 1,
		Text = "",
		PlaceholderText = "Enter key...",
		PlaceholderColor3 = THEME.TextFaint,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		ClearTextOnFocus = false,
	}, inputFrame)

	inputBox.Focused:Connect(function()
		tween(inputStrokeObj, 0.2, {Color = THEME.Accent, Transparency = 0.3})
	end)
	inputBox.FocusLost:Connect(function()
		tween(inputStrokeObj, 0.2, {Color = THEME.Border, Transparency = 0.5})
	end)

	-- Verify button (SOLID purple, no gradient)
	local verify = newInst("TextButton", {
		Size = UDim2.new(1, -40, 0, 38),
		Position = UDim2.fromOffset(20, 170),
		BackgroundColor3 = THEME.Accent,
		BorderSizePixel = 0,
		Text = "Verify",
		Font = Enum.Font.GothamMedium,
		TextSize = 13,
		TextColor3 = Color3.fromRGB(255,255,255),
		AutoButtonColor = false,
	}, card)
	corner(verify, 8)

	verify.MouseEnter:Connect(function()
		tween(verify, 0.15, {BackgroundColor3 = Color3.fromRGB(155, 110, 255)})
	end)
	verify.MouseLeave:Connect(function()
		tween(verify, 0.15, {BackgroundColor3 = THEME.Accent})
	end)

	-- Animate in
	tween(card, 0.45, {Size = UDim2.fromOffset(420, 230)})
	task.wait(0.2)
	tween(title, 0.3, {TextTransparency = 0})
	task.wait(0.04)
	tween(sub, 0.3, {TextTransparency = 0})
	task.wait(0.04)
	tween(note, 0.3, {TextTransparency = 0})

	-- Verify logic
	local result = nil
	local attempts = ks.MaxAttempts or 5

	local function doVerify()
		for _, k in ipairs(ks.Keys or {}) do
			if inputBox.Text == k then
				if ks.SaveKey and writefile then
					pcall(function()
						if not isfolder("VaenHub") then makefolder("VaenHub") end
						if not isfolder("VaenHub/Keys") then makefolder("VaenHub/Keys") end
						writefile("VaenHub/Keys/"..(ks.FileName or "key")..".key", inputBox.Text)
					end)
				end
				result = true
				return
			end
		end
		attempts = attempts - 1
		-- Shake
		local op = card.Position
		for _ = 1, 3 do
			card.Position = op + UDim2.fromOffset(7, 0); task.wait(0.04)
			card.Position = op + UDim2.fromOffset(-7, 0); task.wait(0.04)
		end
		card.Position = op
		tween(inputStrokeObj, 0.2, {Color = THEME.Danger, Transparency = 0.3})
		task.wait(0.5)
		tween(inputStrokeObj, 0.2, {Color = THEME.Border, Transparency = 0.5})
		inputBox.Text = ""
		if attempts <= 0 then result = false end
	end

	verify.MouseButton1Click:Connect(doVerify)
	inputBox.FocusLost:Connect(function(enter) if enter then doVerify() end end)
	close.MouseButton1Click:Connect(function() result = false end)

	while result == nil do task.wait() end

	tween(blur, 0.3, {Size = 0})
	tween(dim, 0.3, {BackgroundTransparency = 1})
	tween(card, 0.3, {Size = UDim2.fromOffset(420, 0)}, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
	task.wait(0.35)
	pcall(function() blur:Destroy() end)
	gui:Destroy()
	return result
end

