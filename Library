-- EXECUTOR DETECTION + PERSISTENCE
--==============================================================
local exec = {}
exec.writefile        = (writefile        or (syn and syn.write_file))
exec.readfile         = (readfile         or (syn and syn.read_file))
exec.isfile           = (isfile           or (syn and syn.is_file))
exec.makefolder       = (makefolder       or (syn and syn.make_folder))
exec.isfolder         = (isfolder         or (syn and syn.is_folder))
exec.listfiles        = listfiles
exec.delfile          = (delfile          or (syn and syn.delete_file))
exec.queue_on_teleport = (queue_on_teleport or syn_queue_on_teleport or (syn and syn.queue_on_teleport))
exec.identifyexecutor = identifyexecutor or (function() return "Unknown" end)

local function safeMkdir(path)
    if not exec.makefolder or not exec.isfolder then return end
    if not exec.isfolder(path) then pcall(exec.makefolder, path) end
end

local function safeWrite(path, data)
    if not exec.writefile then return false end
    local ok = pcall(exec.writefile, path, data)
    return ok
end

local function safeRead(path)
    if not exec.readfile or not exec.isfile then return nil end
    if not exec.isfile(path) then return nil end
    local ok, data = pcall(exec.readfile, path)
    if ok then return data end
    return nil
end

