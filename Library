    --=====================================================
    -- Tab creation
    --=====================================================
    local firstTab
    function Window:CreateTab(name, icon)
        local Tab = {}

        local tabBtn = TabList.Template:Clone()
        tabBtn.Name = name
        tabBtn.Title.Text = name
        tabBtn.Parent = TabList
        tabBtn.Title.TextWrapped = false
        tabBtn.Size = UDim2.new(0, tabBtn.Title.TextBounds.X + 30, 0, 30)

        if icon and icon ~= 0 then
            tabBtn.Image.Image = "rbxassetid://" .. tostring(icon)
            tabBtn.Title.AnchorPoint = Vector2.new(0, 0.5)
            tabBtn.Title.Position = UDim2.new(0, 37, 0.5, 0)
            tabBtn.Image.Visible = true
            tabBtn.Title.TextXAlignment = Enum.TextXAlignment.Left
            tabBtn.Size = UDim2.new(0, tabBtn.Title.TextBounds.X + 52, 0, 30)
        end

        tabBtn.BackgroundTransparency = 1
        tabBtn.Title.TextTransparency = 1
        tabBtn.Image.ImageTransparency = 1
        tabBtn.UIStroke.Transparency = 1

        local page = Elements.Template:Clone()
        page.Name = name
        page.Visible = true
        page.LayoutOrder = #Elements:GetChildren()
        for _, t in ipairs(page:GetChildren()) do
            if t:IsA("Frame") and t.Name ~= "Placeholder" then t:Destroy() end
        end
        page.Parent = Elements

        if not firstTab then
            firstTab = name
            Elements.UIPageLayout.Animated = false
            Elements.UIPageLayout:JumpTo(page)
            Elements.UIPageLayout.Animated = true
        end

        tabBtn.UIStroke.Color = SelectedTheme.TabStroke
        if Elements.UIPageLayout.CurrentPage == page then
            tabBtn.BackgroundColor3 = SelectedTheme.TabBackgroundSelected
            tabBtn.Image.ImageColor3 = SelectedTheme.SelectedTabTextColor
            tabBtn.Title.TextColor3 = SelectedTheme.SelectedTabTextColor
        else
            tabBtn.BackgroundColor3 = SelectedTheme.TabBackground
            tabBtn.Image.ImageColor3 = SelectedTheme.TabTextColor
            tabBtn.Title.TextColor3 = SelectedTheme.TabTextColor
        end

        task.wait(0.1)
        if firstTab == name then
            tween(tabBtn,          TWEEN_SLOW, { BackgroundTransparency = 0 })
            tween(tabBtn.Title,    TWEEN_SLOW, { TextTransparency = 0 })
            tween(tabBtn.Image,    TWEEN_SLOW, { ImageTransparency = 0 })
        else
            tween(tabBtn,          TWEEN_SLOW, { BackgroundTransparency = 0.7 })
            tween(tabBtn.Title,    TWEEN_SLOW, { TextTransparency = 0.2 })
            tween(tabBtn.Image,    TWEEN_SLOW, { ImageTransparency = 0.2 })
            tween(tabBtn.UIStroke, TWEEN_SLOW, { Transparency = 0.5 })
        end

        tabBtn.Interact.MouseButton1Click:Connect(function()
            if Minimized then return end
            tween(tabBtn,       TWEEN_SLOW, { BackgroundTransparency = 0, BackgroundColor3 = SelectedTheme.TabBackgroundSelected })
            tween(tabBtn.Title, TWEEN_SLOW, { TextTransparency = 0, TextColor3 = SelectedTheme.SelectedTabTextColor })
            tween(tabBtn.Image, TWEEN_SLOW, { ImageTransparency = 0, ImageColor3 = SelectedTheme.SelectedTabTextColor })
            tween(tabBtn.UIStroke, TWEEN_SLOW, { Transparency = 1 })
            for _, other in ipairs(TabList:GetChildren()) do
                if other:IsA("Frame") and other ~= tabBtn and other.Name ~= "Template" and other.Name ~= "Placeholder" then
                    tween(other,          TWEEN_SLOW, { BackgroundTransparency = 0.7, BackgroundColor3 = SelectedTheme.TabBackground })
                    tween(other.Title,    TWEEN_SLOW, { TextTransparency = 0.2, TextColor3 = SelectedTheme.TabTextColor })
                    tween(other.Image,    TWEEN_SLOW, { ImageTransparency = 0.2, ImageColor3 = SelectedTheme.TabTextColor })
                    tween(other.UIStroke, TWEEN_SLOW, { Transparency = 0.5 })
                end
            end
            if Elements.UIPageLayout.CurrentPage ~= page then
                Elements.UIPageLayout:JumpTo(page)
            end
        end)

