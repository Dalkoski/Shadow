	lbl.Font = Enum.Font.Gotham
	lbl.TextSize = 13
	lbl.TextColor3 = theme.Text
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = frame

	-- Selected pill (right side)
	local pill = Instance.new("Frame")
	pill.AnchorPoint = Vector2.new(1, 0.5)
	pill.Size = UDim2.fromOffset(110, 22)
	pill.Position = UDim2.new(1, -14, 0, headerHeight/2)
	pill.BackgroundColor3 = theme.ElementHover
	pill.BorderSizePixel = 0
	pill.Parent = frame
	corner(pill, 5)

	local pillText = Instance.new("TextLabel")
	pillText.Size = UDim2.new(1, -24, 1, 0)
	pillText.Position = UDim2.fromOffset(8, 0)
	pillText.BackgroundTransparency = 1
	pillText.Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current .. " selected")) or "None"
	pillText.Font = Enum.Font.Gotham
	pillText.TextSize = 11
	pillText.TextColor3 = theme.Text
	pillText.TextXAlignment = Enum.TextXAlignment.Left
	pillText.TextTruncate = Enum.TextTruncate.AtEnd
	pillText.Parent = pill

	local pillArrow = Instance.new("TextLabel")
	pillArrow.AnchorPoint = Vector2.new(1, 0.5)
	pillArrow.Size = UDim2.fromOffset(14, 14)
	pillArrow.Position = UDim2.new(1, -6, 0.5, 0)
	pillArrow.BackgroundTransparency = 1
	pillArrow.Text = "▾"
	pillArrow.Font = Enum.Font.GothamBold
	pillArrow.TextSize = 10
	pillArrow.TextColor3 = theme.TextDim
	pillArrow.Parent = pill

	-- Options container
	local optsFrame = Instance.new("Frame")
	optsFrame.Size = UDim2.new(1, -28, 0, 0)
	optsFrame.Position = UDim2.fromOffset(14, headerHeight + 4)
	optsFrame.BackgroundTransparency = 1
	optsFrame.Parent = frame
	local optsLayout = listLayout(optsFrame, 4)

	local function refreshOptions()
		for _, c in ipairs(optsFrame:GetChildren()) do
			if c:IsA("TextButton") then c:Destroy() end
		end
		for _, opt in ipairs(elem._options) do
			local optBtn = Instance.new("TextButton")
			optBtn.Size = UDim2.new(1, 0, 0, 26)
			optBtn.BackgroundColor3 = theme.ElementHover
			optBtn.BorderSizePixel = 0
			optBtn.Text = ""
			optBtn.AutoButtonColor = false
			optBtn.Parent = optsFrame
			corner(optBtn, 6)

			local optLbl = Instance.new("TextLabel")
			optLbl.Size = UDim2.new(1, -16, 1, 0)
			optLbl.Position = UDim2.fromOffset(10, 0)
			optLbl.BackgroundTransparency = 1
			optLbl.Text = opt
			optLbl.Font = Enum.Font.Gotham
			optLbl.TextSize = 11
			optLbl.TextColor3 = theme.TextDim
			optLbl.TextXAlignment = Enum.TextXAlignment.Left
			optLbl.Parent = optBtn

			local function refresh()
				local isSel = table.find(elem._current, opt) ~= nil
				if isSel then
					optBtn.BackgroundColor3 = theme.Accent[1]
					optBtn.BackgroundTransparency = 0.6
					optLbl.TextColor3 = theme.Text
				else
					optBtn.BackgroundColor3 = theme.ElementHover
					optBtn.BackgroundTransparency = 0
					optLbl.TextColor3 = theme.TextDim
				end
			end
			refresh()

			optBtn.MouseButton1Click:Connect(function()
				local idx = table.find(elem._current, opt)
				if elem._multi then
					if idx then table.remove(elem._current, idx) else table.insert(elem._current, opt) end
				else
					elem._current = {opt}
				end
				pillText.Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current .. " selected")) or "None"
				for _, c in ipairs(optsFrame:GetChildren()) do
					if c:IsA("TextButton") then
						local cl = c:FindFirstChildWhichIsA("TextLabel")
						if cl then
							local isSel = table.find(elem._current, cl.Text) ~= nil
							if isSel then
								c.BackgroundColor3 = theme.Accent[1]
								c.BackgroundTransparency = 0.6
								cl.TextColor3 = theme.Text
							else
								c.BackgroundColor3 = theme.ElementHover
								c.BackgroundTransparency = 0
								cl.TextColor3 = theme.TextDim
							end
						end
					end
				end
				if elem._callback then task.spawn(pcall, elem._callback, elem._current) end
				if elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
			end)
		end
	end
	refreshOptions()

	-- Click to expand
	local clickBtn = Instance.new("TextButton")
	clickBtn.Size = UDim2.new(1, 0, 0, headerHeight)
	clickBtn.BackgroundTransparency = 1
	clickBtn.Text = ""
	clickBtn.AutoButtonColor = false
	clickBtn.Parent = frame

	local open = false
	clickBtn.MouseButton1Click:Connect(function()
		open = not open
		local total = #elem._options * 30
		if open then
			tween(frame, 0.3, {Size = UDim2.new(1, 0, 0, headerHeight + total + 12)})
			tween(pillArrow, 0.3, {Rotation = 180})
		else
			tween(frame, 0.3, {Size = UDim2.new(1, 0, 0, headerHeight)})
			tween(pillArrow, 0.3, {Rotation = 0})
		end
	end)

	elem._frame = frame
	elem._refreshOptions = refreshOptions
	elem._update = function(v)
		elem._current = type(v) == "table" and v or {v}
		pillText.Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current .. " selected")) or "None"
		refreshOptions()
	end
end

