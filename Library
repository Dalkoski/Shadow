	inputBox.TextSize = 13
	inputBox.TextColor3 = Color3.fromRGB(240, 240, 245)
	inputBox.TextXAlignment = Enum.TextXAlignment.Left
	inputBox.ClearTextOnFocus = false
	inputBox.Parent = inputFrame

	-- Submit button
	local submit = Instance.new("TextButton")
	submit.Size = UDim2.new(1, -32, 0, 36)
	submit.Position = UDim2.fromOffset(20, 176)
	submit.BackgroundColor3 = theme.Accent[1]
	submit.BorderSizePixel = 0
	submit.Text = "Verify"
	submit.Font = Enum.Font.GothamMedium
	submit.TextSize = 13
	submit.TextColor3 = Color3.fromRGB(255, 255, 255)
	submit.AutoButtonColor = false
	submit.Parent = card

	local submitCorner = Instance.new("UICorner")
	submitCorner.CornerRadius = UDim.new(0, 8)
	submitCorner.Parent = submit

	local submitGradient = Instance.new("UIGradient")
	submitGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, theme.Accent[1]),
		ColorSequenceKeypoint.new(1, theme.Accent[2]),
	}
	submitGradient.Rotation = 135
	submitGradient.Parent = submit

	-- Cancel/close
	local cancel = Instance.new("TextButton")
	cancel.Size = UDim2.new(0, 28, 0, 28)
	cancel.Position = UDim2.new(1, -36, 0, 8)
	cancel.BackgroundTransparency = 1
	cancel.Text = "×"
	cancel.Font = Enum.Font.GothamBold
	cancel.TextSize = 20
	cancel.TextColor3 = Color3.fromRGB(180, 180, 190)
	cancel.Parent = card

	-- Animate card in
	card:TweenSize(UDim2.new(0, 380, 0, 228), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.5, true)
	task.wait(0.15)
	for _, label in ipairs({title, subtitle, note}) do
		TweenService:Create(label, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
		task.wait(0.05)
	end

	-- Verification
	local result = nil
	local attempts = keySettings.MaxAttempts or 5

	local function verify()
		local entered = inputBox.Text
		for _, validKey in ipairs(keySettings.Keys or {}) do
			if entered == validKey then
				-- Save if requested
				if keySettings.SaveKey then
					self:_SaveKey(keySettings, entered)
				end
				result = true
				return
			end
		end
		attempts = attempts - 1

		-- Shake animation
		local origPos = card.Position
		for i = 1, 3 do
			card:TweenPosition(origPos + UDim2.fromOffset(8, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.05, true)
			task.wait(0.05)
			card:TweenPosition(origPos + UDim2.fromOffset(-8, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.05, true)
			task.wait(0.05)
		end
		card:TweenPosition(origPos, Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.05, true)

		inputBox.Text = ""

		if attempts <= 0 then
			result = false
		end
	end

	submit.MouseButton1Click:Connect(verify)
	inputBox.FocusLost:Connect(function(enter)
		if enter then verify() end
	end)
	cancel.MouseButton1Click:Connect(function() result = false end)

	-- Wait for result
	while result == nil do task.wait() end

	-- Fade out
	TweenService:Create(blur, TweenInfo.new(0.4), {Size = 0}):Play()
	TweenService:Create(overlay, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
	card:TweenSize(UDim2.new(0, 380, 0, 0), Enum.EasingDirection.In, Enum.EasingStyle.Quart, 0.4, true)
	task.wait(0.45)

	blur:Destroy()
	keyGui:Destroy()

	return result
end

