        -- Toggle
        function Tab:CreateToggle(o)
            local Toggle = { CurrentValue = o.CurrentValue and true or false, Type = "Toggle" }
            local tog = Elements.Template.Toggle:Clone()
            tog.Name = o.Name; tog.Title.Text = o.Name
            tog.Visible = true; tog.Parent = page
            tog.BackgroundTransparency = 1
            tog.UIStroke.Transparency = 1
            tog.Title.TextTransparency = 1
            tog.Switch.BackgroundColor3 = SelectedTheme.ToggleBackground

            tween(tog,         TWEEN_SLOW, { BackgroundTransparency = 0 })
            tween(tog.UIStroke,TWEEN_SLOW, { Transparency = 0 })
            tween(tog.Title,   TWEEN_SLOW, { TextTransparency = 0 })

            local function apply()
                if Toggle.CurrentValue then
                    tog.Switch.Indicator.Position = UDim2.new(1, -20, 0.5, 0)
                    tog.Switch.Indicator.UIStroke.Color = SelectedTheme.ToggleEnabledStroke
                    tog.Switch.Indicator.BackgroundColor3 = SelectedTheme.ToggleEnabled
                    tog.Switch.UIStroke.Color = SelectedTheme.ToggleEnabledOuterStroke
                else
                    tog.Switch.Indicator.Position = UDim2.new(1, -40, 0.5, 0)
                    tog.Switch.Indicator.UIStroke.Color = SelectedTheme.ToggleDisabledStroke
                    tog.Switch.Indicator.BackgroundColor3 = SelectedTheme.ToggleDisabled
                    tog.Switch.UIStroke.Color = SelectedTheme.ToggleDisabledOuterStroke
                end
            end
            apply()

            tog.MouseEnter:Connect(function() tween(tog, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackgroundHover }) end)
            tog.MouseLeave:Connect(function() tween(tog, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackground }) end)

            tog.Interact.MouseButton1Click:Connect(function()
                Toggle.CurrentValue = not Toggle.CurrentValue
                local pos = Toggle.CurrentValue and UDim2.new(1, -20, 0.5, 0) or UDim2.new(1, -40, 0.5, 0)
                tween(tog.Switch.Indicator, TWEEN_MED, { Position = pos })
                tween(tog.Switch.Indicator, TWEEN_MED, {
                    BackgroundColor3 = Toggle.CurrentValue and SelectedTheme.ToggleEnabled or SelectedTheme.ToggleDisabled,
                })
                tween(tog.Switch.Indicator.UIStroke, TWEEN_MED, {
                    Color = Toggle.CurrentValue and SelectedTheme.ToggleEnabledStroke or SelectedTheme.ToggleDisabledStroke,
                })
                tween(tog.Switch.UIStroke, TWEEN_MED, {
                    Color = Toggle.CurrentValue and SelectedTheme.ToggleEnabledOuterStroke or SelectedTheme.ToggleDisabledOuterStroke,
                })
                if o.Callback then task.spawn(o.Callback, Toggle.CurrentValue) end
            end)

            function Toggle:Set(v)
                self.CurrentValue = v and true or false
                apply()
                if o.Callback then task.spawn(o.Callback, self.CurrentValue) end
            end

            table.insert(themeListeners, function() apply() end)
            if o.Flag then Phantom.Flags[o.Flag] = Toggle end
            return Toggle
        end

        -- Slider
        function Tab:CreateSlider(o)
            local Slider = { Type = "Slider" }
            local range = o.Range or {0, 100}
            local inc   = o.Increment or 1
            local suf   = o.Suffix or ""
            Slider.CurrentValue = math.clamp(o.CurrentValue or range[1], range[1], range[2])

            local sld = Elements.Template.Slider:Clone()
            sld.Name = o.Name; sld.Title.Text = o.Name
            sld.Visible = true; sld.Parent = page
            sld.BackgroundTransparency = 1
            sld.UIStroke.Transparency = 1
            sld.Title.TextTransparency = 1

            sld.Main.BackgroundColor3       = SelectedTheme.SliderBackground
            sld.Main.UIStroke.Color         = SelectedTheme.SliderStroke
            sld.Main.Progress.UIStroke.Color= SelectedTheme.SliderStroke
            sld.Main.Progress.BackgroundColor3 = SelectedTheme.SliderProgress

            tween(sld,          TWEEN_SLOW, { BackgroundTransparency = 0 })
            tween(sld.UIStroke, TWEEN_SLOW, { Transparency = 0 })
            tween(sld.Title,    TWEEN_SLOW, { TextTransparency = 0 })

            local function applyVisual()
                local pct = (Slider.CurrentValue - range[1]) / (range[2] - range[1])
                local px  = sld.Main.AbsoluteSize.X * pct
                if px < 5 then px = 5 end
                sld.Main.Progress.Size = UDim2.new(0, px, 1, 0)
                sld.Main.Information.Text = tostring(Slider.CurrentValue) .. (suf ~= "" and " " .. suf or "")
            end
            task.wait()
            applyVisual()

            sld.MouseEnter:Connect(function() tween(sld, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackgroundHover }) end)
            sld.MouseLeave:Connect(function() tween(sld, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackground }) end)

            local dragging = false
            sld.Main.Interact.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    tween(sld.Main.UIStroke,          TWEEN_MED, { Transparency = 1 })
                    tween(sld.Main.Progress.UIStroke, TWEEN_MED, { Transparency = 1 })
                end
            end)
            sld.Main.Interact.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                    tween(sld.Main.UIStroke,          TWEEN_MED, { Transparency = 0.4 })
                    tween(sld.Main.Progress.UIStroke, TWEEN_MED, { Transparency = 0.3 })
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if not dragging then return end
                if input.UserInputType ~= Enum.UserInputType.MouseMovement
                and input.UserInputType ~= Enum.UserInputType.Touch then return end
                local x = input.Position.X
                local rel = math.clamp((x - sld.Main.AbsolutePosition.X) / math.max(1, sld.Main.AbsoluteSize.X), 0, 1)
                local val = range[1] + (range[2] - range[1]) * rel
                val = math.floor(val / inc + 0.5) * inc
                val = math.clamp(val, range[1], range[2])
                if val ~= Slider.CurrentValue then
                    Slider.CurrentValue = val
                    applyVisual()
                    if o.Callback then task.spawn(o.Callback, val) end
                end
            end)

            function Slider:Set(v)
                v = math.clamp(v, range[1], range[2])
                self.CurrentValue = v
                applyVisual()
                if o.Callback then task.spawn(o.Callback, v) end
            end

            if o.Flag then Phantom.Flags[o.Flag] = Slider end
            return Slider
        end

        -- Input
        function Tab:CreateInput(o)
            local Input = { CurrentValue = o.CurrentValue or "", Type = "Input" }
            local inp = Elements.Template.Input:Clone()
            inp.Name = o.Name; inp.Title.Text = o.Name
            inp.Visible = true; inp.Parent = page
            inp.BackgroundTransparency = 1
            inp.UIStroke.Transparency = 1
            inp.Title.TextTransparency = 1
            inp.InputFrame.InputBox.Text = Input.CurrentValue
            inp.InputFrame.BackgroundColor3 = SelectedTheme.InputBackground
            inp.InputFrame.UIStroke.Color = SelectedTheme.InputStroke
            inp.InputFrame.InputBox.PlaceholderText = o.PlaceholderText or ""
            inp.InputFrame.Size = UDim2.new(0, math.max(140, inp.InputFrame.InputBox.TextBounds.X + 24), 0, 30)

            tween(inp,          TWEEN_SLOW, { BackgroundTransparency = 0 })
            tween(inp.UIStroke, TWEEN_SLOW, { Transparency = 0 })
            tween(inp.Title,    TWEEN_SLOW, { TextTransparency = 0 })

            inp.MouseEnter:Connect(function() tween(inp, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackgroundHover }) end)
            inp.MouseLeave:Connect(function() tween(inp, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackground }) end)

            inp.InputFrame.InputBox:GetPropertyChangedSignal("Text"):Connect(function()
                tween(inp.InputFrame, TWEEN_MED, {
                    Size = UDim2.new(0, math.max(140, inp.InputFrame.InputBox.TextBounds.X + 24), 0, 30),
                })
            end)

            inp.InputFrame.InputBox.FocusLost:Connect(function()
                Input.CurrentValue = inp.InputFrame.InputBox.Text
                if o.Callback then task.spawn(o.Callback, Input.CurrentValue) end
                if o.RemoveTextAfterFocusLost then inp.InputFrame.InputBox.Text = "" end
            end)

            function Input:Set(v)
                inp.InputFrame.InputBox.Text = tostring(v)
                self.CurrentValue = inp.InputFrame.InputBox.Text
                if o.Callback then task.spawn(o.Callback, self.CurrentValue) end
            end

            if o.Flag then Phantom.Flags[o.Flag] = Input end
            return Input
        end

        -- Keybind
        function Tab:CreateKeybind(o)
            local Keybind = { CurrentKeybind = o.CurrentKeybind or "None", Type = "Keybind" }
            local kb = Elements.Template.Keybind:Clone()
            kb.Name = o.Name; kb.Title.Text = o.Name
            kb.Visible = true; kb.Parent = page
            kb.BackgroundTransparency = 1
            kb.UIStroke.Transparency = 1
            kb.Title.TextTransparency = 1
            kb.KeybindFrame.BackgroundColor3 = SelectedTheme.InputBackground
            kb.KeybindFrame.UIStroke.Color = SelectedTheme.InputStroke
            kb.KeybindFrame.KeybindBox.Text = Keybind.CurrentKeybind
            kb.KeybindFrame.Size = UDim2.new(0, math.max(60, kb.KeybindFrame.KeybindBox.TextBounds.X + 24), 0, 30)

            tween(kb,          TWEEN_SLOW, { BackgroundTransparency = 0 })
            tween(kb.UIStroke, TWEEN_SLOW, { Transparency = 0 })
            tween(kb.Title,    TWEEN_SLOW, { TextTransparency = 0 })

            local checking = false
            kb.KeybindFrame.KeybindBox.Focused:Connect(function() checking = true; kb.KeybindFrame.KeybindBox.Text = "" end)
            kb.KeybindFrame.KeybindBox.FocusLost:Connect(function()
                checking = false
                if kb.KeybindFrame.KeybindBox.Text == "" then
                    kb.KeybindFrame.KeybindBox.Text = Keybind.CurrentKeybind
                end
            end)
            kb.MouseEnter:Connect(function() tween(kb, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackgroundHover }) end)
            kb.MouseLeave:Connect(function() tween(kb, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackground }) end)
            kb.KeybindFrame.KeybindBox:GetPropertyChangedSignal("Text"):Connect(function()
                tween(kb.KeybindFrame, TWEEN_MED, {
                    Size = UDim2.new(0, math.max(60, kb.KeybindFrame.KeybindBox.TextBounds.X + 24), 0, 30),
                })
            end)

            UserInputService.InputBegan:Connect(function(input, gp)
                if checking then
                    if input.KeyCode ~= Enum.KeyCode.Unknown then
                        local key = input.KeyCode.Name
                        kb.KeybindFrame.KeybindBox.Text = key
                        Keybind.CurrentKeybind = key
                        kb.KeybindFrame.KeybindBox:ReleaseFocus()
                        if o.CallOnChange and o.Callback then task.spawn(o.Callback, key) end
                    end
                elseif not gp and not o.CallOnChange
                  and input.KeyCode.Name == Keybind.CurrentKeybind then
                    if o.Callback then task.spawn(o.Callback) end
                end
            end)

            function Keybind:Set(v)
                self.CurrentKeybind = tostring(v)
                kb.KeybindFrame.KeybindBox.Text = self.CurrentKeybind
                if o.CallOnChange and o.Callback then task.spawn(o.Callback, self.CurrentKeybind) end
            end

            if o.Flag then Phantom.Flags[o.Flag] = Keybind end
            return Keybind
        end

        -- Dropdown
        function Tab:CreateDropdown(o)
            local Dropdown = {
                Type = "Dropdown",
                Options = o.Options or {},
                MultipleOptions = o.MultipleOptions == true,
            }
            -- Normalize CurrentOption to a table
            if o.CurrentOption then
                if type(o.CurrentOption) == "string" then
                    Dropdown.CurrentOption = { o.CurrentOption }
                else
                    Dropdown.CurrentOption = {}
                    for _, v in ipairs(o.CurrentOption) do table.insert(Dropdown.CurrentOption, v) end
                end
                if not Dropdown.MultipleOptions then
                    Dropdown.CurrentOption = { Dropdown.CurrentOption[1] }
                end
            else
                Dropdown.CurrentOption = {}
            end

            local dd = Elements.Template.Dropdown:Clone()
            dd.Name = o.Name; dd.Title.Text = o.Name
            dd.Visible = true; dd.Parent = page
            dd.List.Visible = false

            if Dropdown.MultipleOptions then
                local n = #Dropdown.CurrentOption
                if n == 0 then dd.Selected.Text = "None"
                elseif n == 1 then dd.Selected.Text = Dropdown.CurrentOption[1]
                else dd.Selected.Text = "Various" end
            else
                dd.Selected.Text = Dropdown.CurrentOption[1] or "None"
            end

            dd.Toggle.ImageColor3 = SelectedTheme.TextColor
            dd.BackgroundColor3 = SelectedTheme.ElementBackground
            dd.BackgroundTransparency = 1
            dd.UIStroke.Transparency = 1
            dd.Title.TextTransparency = 1
            dd.Size = UDim2.new(1, -10, 0, 45)
            tween(dd,          TWEEN_SLOW, { BackgroundTransparency = 0 })
            tween(dd.UIStroke, TWEEN_SLOW, { Transparency = 0 })
            tween(dd.Title,    TWEEN_SLOW, { TextTransparency = 0 })

            for _, c in ipairs(dd.List:GetChildren()) do
                if c:IsA("Frame") and c.Name ~= "Placeholder" then c:Destroy() end
            end
            dd.Toggle.Rotation = 180

            local function isSelected(opt)
                for _, v in ipairs(Dropdown.CurrentOption) do
                    if v == opt then return true end
                end
                return false
            end

            local function buildOptions()
                for _, opt in ipairs(Dropdown.Options) do
                    local row = Elements.Template.Dropdown.List.Template:Clone()
                    row.Name = opt; row.Title.Text = opt
                    row.Parent = dd.List; row.Visible = true
                    row.BackgroundTransparency = 1
                    row.UIStroke.Transparency = 1
                    row.Title.TextTransparency = 1
                    row.BackgroundColor3 = isSelected(opt) and SelectedTheme.DropdownSelected or SelectedTheme.DropdownUnselected

                    row.Interact.ZIndex = 50
                    row.Interact.MouseButton1Click:Connect(function()
                        if Dropdown.MultipleOptions then
                            local idx
                            for i, v in ipairs(Dropdown.CurrentOption) do
                                if v == opt then idx = i; break end
                            end
                            if idx then
                                table.remove(Dropdown.CurrentOption, idx)
                            else
                                table.insert(Dropdown.CurrentOption, opt)
                            end
                        else
                            if isSelected(opt) then return end
                            Dropdown.CurrentOption = { opt }
                        end

                        if Dropdown.MultipleOptions then
                            local n = #Dropdown.CurrentOption
                            if n == 0 then dd.Selected.Text = "None"
                            elseif n == 1 then dd.Selected.Text = Dropdown.CurrentOption[1]
                            else dd.Selected.Text = "Various" end
                        else
                            dd.Selected.Text = Dropdown.CurrentOption[1]
                        end

                        for _, ch in ipairs(dd.List:GetChildren()) do
                            if ch:IsA("Frame") and ch.Name ~= "Placeholder" then
                                ch.BackgroundColor3 = isSelected(ch.Name)
                                    and SelectedTheme.DropdownSelected
                                    or  SelectedTheme.DropdownUnselected
                            end
                        end

                        if o.Callback then task.spawn(o.Callback, Dropdown.CurrentOption) end

                        if not Dropdown.MultipleOptions then
                            task.wait(0.1)
                            tween(dd, TWEEN_MED, { Size = UDim2.new(1, -10, 0, 45) })
                            for _, ch in ipairs(dd.List:GetChildren()) do
                                if ch:IsA("Frame") and ch.Name ~= "Placeholder" then
                                    tween(ch,          TWEEN_FAST, { BackgroundTransparency = 1 })
                                    tween(ch.UIStroke, TWEEN_FAST, { Transparency = 1 })
                                    tween(ch.Title,    TWEEN_FAST, { TextTransparency = 1 })
                                end
                            end
                            tween(dd.List, TWEEN_FAST, { ScrollBarImageTransparency = 1 })
                            tween(dd.Toggle, TWEEN_MED, { Rotation = 180 })
                            task.wait(0.35)
                            dd.List.Visible = false
                        end
                    end)
                end
            end
            buildOptions()

            local debounce = false
            dd.Interact.MouseButton1Click:Connect(function()
                if debounce then return end
                debounce = true
                if dd.List.Visible then
                    tween(dd, TWEEN_MED, { Size = UDim2.new(1, -10, 0, 45) })
                    for _, ch in ipairs(dd.List:GetChildren()) do
                        if ch:IsA("Frame") and ch.Name ~= "Placeholder" then
                            tween(ch,          TWEEN_FAST, { BackgroundTransparency = 1 })
                            tween(ch.UIStroke, TWEEN_FAST, { Transparency = 1 })
                            tween(ch.Title,    TWEEN_FAST, { TextTransparency = 1 })
                        end
                    end
                    tween(dd.List,   TWEEN_FAST, { ScrollBarImageTransparency = 1 })
                    tween(dd.Toggle, TWEEN_MED,  { Rotation = 180 })
                    task.wait(0.35)
                    dd.List.Visible = false
                else
                    tween(dd, TWEEN_MED, { Size = UDim2.new(1, -10, 0, 180) })
                    dd.List.Visible = true
                    tween(dd.List,   TWEEN_FAST, { ScrollBarImageTransparency = 0.7 })
                    tween(dd.Toggle, TWEEN_MED,  { Rotation = 0 })
                    for _, ch in ipairs(dd.List:GetChildren()) do
                        if ch:IsA("Frame") and ch.Name ~= "Placeholder" then
                            tween(ch, TWEEN_FAST, { BackgroundTransparency = 0 })
                            if ch.Name ~= dd.Selected.Text then
                                tween(ch.UIStroke, TWEEN_FAST, { Transparency = 0 })
                            end
                            tween(ch.Title, TWEEN_FAST, { TextTransparency = 0 })
                        end
                    end
                end
                debounce = false
            end)

            dd.MouseEnter:Connect(function() if not dd.List.Visible then tween(dd, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackgroundHover }) end end)
            dd.MouseLeave:Connect(function() tween(dd, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackground }) end)

            function Dropdown:Set(v)
                if type(v) == "string" then v = { v } end
                if not self.MultipleOptions then v = { v[1] } end
                self.CurrentOption = v
                if self.MultipleOptions then
                    local n = #self.CurrentOption
                    if n == 0 then dd.Selected.Text = "None"
                    elseif n == 1 then dd.Selected.Text = self.CurrentOption[1]
                    else dd.Selected.Text = "Various" end
                else
                    dd.Selected.Text = self.CurrentOption[1]
                end
                for _, ch in ipairs(dd.List:GetChildren()) do
                    if ch:IsA("Frame") and ch.Name ~= "Placeholder" then
                        ch.BackgroundColor3 = isSelected(ch.Name)
                            and SelectedTheme.DropdownSelected
                            or  SelectedTheme.DropdownUnselected
                    end
                end
                if o.Callback then task.spawn(o.Callback, self.CurrentOption) end
            end

            function Dropdown:Refresh(newOpts)
                self.Options = newOpts or {}
                for _, ch in ipairs(dd.List:GetChildren()) do
                    if ch:IsA("Frame") and ch.Name ~= "Placeholder" then ch:Destroy() end
                end
                buildOptions()
            end

            if o.Flag then Phantom.Flags[o.Flag] = Dropdown end
            return Dropdown
        end

        -- ColorPicker
        function Tab:CreateColorPicker(o)
            local Picker = { Type = "ColorPicker", Color = o.Color or Color3.fromRGB(255,255,255) }
            local cp = Elements.Template.ColorPicker:Clone()
            local Background = cp.CPBackground
            local Display = Background.Display
            local MainCP  = Background.MainCP
            local SliderCS = cp.ColorSlider

            cp.ClipsDescendants = true
            cp.Name = o.Name; cp.Title.Text = o.Name
            cp.Visible = true; cp.Parent = page
            cp.Size = UDim2.new(1, -10, 0, 45)
            Background.Size = UDim2.new(0, 39, 0, 22)
            Display.BackgroundTransparency = 0
            MainCP.MainPoint.ImageTransparency = 1
            cp.Interact.Size = UDim2.new(1, 0, 1, 0)
            cp.Interact.Position = UDim2.new(0.5, 0, 0.5, 0)
            cp.RGB.Position = UDim2.new(0, 17, 0, 70)
            cp.HexInput.Position = UDim2.new(0, 17, 0, 90)
            MainCP.ImageTransparency = 1
            Background.BackgroundTransparency = 1

            for _, ri in ipairs(cp.RGB:GetChildren()) do
                if ri:IsA("Frame") then
                    ri.BackgroundColor3 = SelectedTheme.InputBackground
                    ri.UIStroke.Color = SelectedTheme.InputStroke
                end
            end
            cp.HexInput.BackgroundColor3 = SelectedTheme.InputBackground
            cp.HexInput.UIStroke.Color = SelectedTheme.InputStroke

            local open = false
            local h, s, v = Picker.Color:ToHSV()
            local mouse = LocalPlayer:GetMouse()
            local dragMain, dragSlider = false, false

            local function setDisplay()
                MainCP.MainPoint.Position = UDim2.new(s, -MainCP.MainPoint.AbsoluteSize.X/2, 1-v, -MainCP.MainPoint.AbsoluteSize.Y/2)
                MainCP.MainPoint.ImageColor3 = Color3.fromHSV(h, s, v)
                Background.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                Display.BackgroundColor3 = Color3.fromHSV(h, s, v)
                local x = h * SliderCS.AbsoluteSize.X
                SliderCS.SliderPoint.Position = UDim2.new(0, x - SliderCS.SliderPoint.AbsoluteSize.X/2, 0.5, 0)
                SliderCS.SliderPoint.ImageColor3 = Color3.fromHSV(h, 1, 1)
                local c = Color3.fromHSV(h, s, v)
                local r,g,b = math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5)
                cp.RGB.RInput.InputBox.Text = tostring(r)
                cp.RGB.GInput.InputBox.Text = tostring(g)
                cp.RGB.BInput.InputBox.Text = tostring(b)
                cp.HexInput.InputBox.Text = string.format("#%02X%02X%02X", r, g, b)
                Picker.Color = c
            end
            setDisplay()

            cp.Interact.MouseButton1Down:Connect(function()
                tween(cp, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackgroundHover })
                task.wait(0.1)
                tween(cp, TWEEN_MED, { BackgroundColor3 = SelectedTheme.ElementBackground })

                if not open then
                    open = true
                    tween(Background, TWEEN_MED, { Size = UDim2.new(0, 173, 0, 86) })
                    tween(cp,         TWEEN_MED, { Size = UDim2.new(1, -10, 0, 120) })
                    tween(Display,    TWEEN_MED, { BackgroundTransparency = 1 })
                    tween(cp.Interact,TWEEN_MED, { Position = UDim2.new(0.289, 0, 0.5, 0), Size = UDim2.new(0.574, 0, 1, 0) })
                    tween(cp.RGB,     TWEEN_MED, { Position = UDim2.new(0, 17, 0, 40) })
                    tween(cp.HexInput,TWEEN_MED, { Position = UDim2.new(0, 17, 0, 73) })
                    tween(MainCP.MainPoint, TWEEN_FAST, { ImageTransparency = 0 })
                    tween(MainCP,           TWEEN_FAST, { ImageTransparency = 0.1 })
                    tween(Background,       TWEEN_MED,  { BackgroundTransparency = 0 })
                else
                    open = false
                    tween(cp,         TWEEN_MED, { Size = UDim2.new(1, -10, 0, 45) })
                    tween(Background, TWEEN_MED, { Size = UDim2.new(0, 39, 0, 22), BackgroundTransparency = 1 })
                    tween(cp.Interact,TWEEN_MED, { Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0.5, 0, 0.5, 0) })
                    tween(cp.RGB,     TWEEN_MED, { Position = UDim2.new(0, 17, 0, 70) })
                    tween(cp.HexInput,TWEEN_MED, { Position = UDim2.new(0, 17, 0, 90) })
                    tween(Display,    TWEEN_MED, { BackgroundTransparency = 0 })
                    tween(MainCP.MainPoint, TWEEN_FAST, { ImageTransparency = 1 })
                    tween(MainCP,           TWEEN_FAST, { ImageTransparency = 1 })
                end
            end)

            MainCP.MouseButton1Down:Connect(function() if open then dragMain = true end end)
            MainCP.MainPoint.MouseButton1Down:Connect(function() if open then dragMain = true end end)
            SliderCS.MouseButton1Down:Connect(function() dragSlider = true end)
            SliderCS.SliderPoint.MouseButton1Down:Connect(function() dragSlider = true end)

            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1
                or i.UserInputType == Enum.UserInputType.Touch then
                    dragMain, dragSlider = false, false
                end
            end)

            RunService.RenderStepped:Connect(function()
                if dragMain then
                    local lx = math.clamp(mouse.X - MainCP.AbsolutePosition.X, 0, MainCP.AbsoluteSize.X)
                    local ly = math.clamp(mouse.Y - MainCP.AbsolutePosition.Y, 0, MainCP.AbsoluteSize.Y)
                    s = lx / math.max(1, MainCP.AbsoluteSize.X)
                    v = 1 - (ly / math.max(1, MainCP.AbsoluteSize.Y))
                    setDisplay()
                    if o.Callback then task.spawn(o.Callback, Picker.Color) end
                end
                if dragSlider then
                    local lx = math.clamp(mouse.X - SliderCS.AbsolutePosition.X, 0, SliderCS.AbsoluteSize.X)
                    h = lx / math.max(1, SliderCS.AbsoluteSize.X)
                    setDisplay()
                    if o.Callback then task.spawn(o.Callback, Picker.Color) end
                end
            end)

            cp.HexInput.InputBox.FocusLost:Connect(function()
                local hex = cp.HexInput.InputBox.Text
                local r, g, b = string.match(hex, "^#?(%w%w)(%w%w)(%w%w)$")
                if r then
                    local col = Color3.fromRGB(tonumber(r, 16), tonumber(g, 16), tonumber(b, 16))
                    h, s, v = col:ToHSV()
                    setDisplay()
                    if o.Callback then task.spawn(o.Callback, Picker.Color) end
                end
            end)

            function Picker:Set(c)
                self.Color = c
                h, s, v = c:ToHSV()
                setDisplay()
                if o.Callback then task.spawn(o.Callback, c) end
            end

            if o.Flag then Phantom.Flags[o.Flag] = Picker end
            return Picker
        end

        return Tab
    end

    function Window:SetTheme(name) changeTheme(name) end

    function Window:Destroy()
        Rayfield.Enabled = false
        Rayfield:Destroy()
        if activeWindow == Window then activeWindow = nil end
    end

    return Window
end

return Phantom
