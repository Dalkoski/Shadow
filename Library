function Phantom:CreateWindow(opts)
    opts = opts or {}
    local Window = {}
    activeWindow = Window

    -- Theme
    if opts.Theme then
        local ok, _ = pcall(changeTheme, opts.Theme)
        if not ok then changeTheme("Default") end
    else
        changeTheme("Default")
    end

    -- Title / subtitle / loading
    Topbar.Title.Text = opts.Name or "Phantom"
    LoadingFrame.Title.Text    = opts.LoadingTitle or "Phantom"
    LoadingFrame.Subtitle.Text = opts.LoadingSubtitle or "by you"
    LoadingFrame.Version.Text  = "Phantom UI"

    -- Topbar icon
    if Topbar:FindFirstChild("Icon") then
        if opts.Icon and opts.Icon ~= 0 then
            Topbar.Icon.Visible = true
            Topbar.Title.Position = UDim2.new(0, 47, 0.5, 0)
            Topbar.Icon.Image = "rbxassetid://" .. tostring(opts.Icon)
        else
            Topbar.Icon.Visible = false
            Topbar.Title.Position = UDim2.new(0, 19, 0.5, 0)
        end
    end

    -- Hide drag bar (uncalled-for in our case)
    local dragBar = Rayfield:FindFirstChild("Drag")
    if dragBar then dragBar.Visible = false end

    -- Hide the settings cog (Rayfield's own settings tab)
    if Topbar:FindFirstChild("Settings") then Topbar.Settings.Visible = false end

    -- Setup initial main frame state for animations
    Main.Size = UDim2.new(0, 420, 0, 100)
    Main.Visible = true
    Main.BackgroundTransparency = 1
    if Main:FindFirstChild("Notice") then Main.Notice.Visible = false end
    Main.Shadow.Image.ImageTransparency = 1

    LoadingFrame.Title.TextTransparency = 1
    LoadingFrame.Subtitle.TextTransparency = 1
    LoadingFrame.Version.TextTransparency = 1

    Topbar.Visible = false
    Elements.Visible = false
    LoadingFrame.Visible = true

    Notifications.Template.Visible = false
    Notifications.Visible = true
    Rayfield.Enabled = true

    -- Drag
    makeDraggable(Main, Topbar)

    -- Reset tab buttons
    for _, tb in ipairs(TabList:GetChildren()) do
        if tb:IsA("Frame") and tb.Name ~= "Placeholder" then
            tb.BackgroundTransparency = 1
            tb.Title.TextTransparency = 1
            tb.Image.ImageTransparency = 1
            tb.UIStroke.Transparency = 1
        end
    end

    -- Loading animation
    task.spawn(function()
        task.wait(0.5)
        tween(Main, TWEEN_SLOW, { BackgroundTransparency = 0 })
        tween(Main.Shadow.Image, TWEEN_SLOW, { ImageTransparency = 0.6 })
        task.wait(0.1)
        tween(LoadingFrame.Title,    TWEEN_SLOW, { TextTransparency = 0 })
        task.wait(0.05)
        tween(LoadingFrame.Subtitle, TWEEN_SLOW, { TextTransparency = 0 })
        task.wait(0.05)
        tween(LoadingFrame.Version,  TWEEN_SLOW, { TextTransparency = 0 })
    end)

    -- Force search invisible (we don't use it)
    if Main:FindFirstChild("Search") then Main.Search.Visible = false end
    if Topbar:FindFirstChild("Search") then Topbar.Search.Visible = false end

    Elements.Template.LayoutOrder = 100000
    Elements.Template.Visible = false
    Elements.UIPageLayout.FillDirection = Enum.FillDirection.Horizontal
    Elements.UIPageLayout.ScrollWheelInputEnabled = false
    Elements.UIPageLayout.GamepadInputEnabled = false
    Elements.UIPageLayout.TouchInputEnabled = false
    TabList.Template.Visible = false

    -- Visibility / keybind
    local Minimized, Hidden, Debounce = false, false, false
    local keyName = opts.Keybind or "K"
    local toggleKeyCode = Enum.KeyCode[keyName] or Enum.KeyCode.K

    local function setElementsVisible(show)
        for _, tab in ipairs(Elements:GetChildren()) do
            if tab:IsA("ScrollingFrame") and tab.Name ~= "Template" and tab.Name ~= "Placeholder" then
                for _, el in ipairs(tab:GetChildren()) do
                    if el:IsA("Frame") and el.Name ~= "SectionSpacing" and el.Name ~= "Placeholder" then
                        if el.Name == "SectionTitle" then
                            tween(el.Title, TWEEN_MED, { TextTransparency = show and 0.4 or 1 })
                        elseif el.Name == "Divider" and el:FindFirstChild("Divider") then
                            tween(el.Divider, TWEEN_MED, { BackgroundTransparency = show and 0.85 or 1 })
                        else
                            tween(el, TWEEN_MED, { BackgroundTransparency = show and 0 or 1 })
                            if el:FindFirstChild("UIStroke") then
                                tween(el.UIStroke, TWEEN_MED, { Transparency = show and 0 or 1 })
                            end
                            if el:FindFirstChild("Title") then
                                tween(el.Title, TWEEN_MED, { TextTransparency = show and 0 or 1 })
                            end
                        end
                        for _, ch in ipairs(el:GetChildren()) do
                            if ch:IsA("Frame") or ch:IsA("TextLabel") or ch:IsA("TextBox")
                            or ch:IsA("ImageLabel") or ch:IsA("ImageButton") then
                                ch.Visible = show
                            end
                        end
                    end
                end
            end
        end
    end

    local function setTabButtons(show)
        for _, tb in ipairs(TabList:GetChildren()) do
            if tb:IsA("Frame") and tb.Name ~= "Placeholder" then
                if show then
                    local active = tostring(Elements.UIPageLayout.CurrentPage) == tb.Title.Text
                    tween(tb,          TWEEN_MED, { BackgroundTransparency = active and 0 or 0.7 })
                    tween(tb.Image,    TWEEN_MED, { ImageTransparency      = active and 0 or 0.2 })
                    tween(tb.Title,    TWEEN_MED, { TextTransparency       = active and 0 or 0.2 })
                    tween(tb.UIStroke, TWEEN_MED, { Transparency           = active and 1 or 0.5 })
                else
                    tween(tb,          TWEEN_MED, { BackgroundTransparency = 1 })
                    tween(tb.Image,    TWEEN_MED, { ImageTransparency = 1 })
                    tween(tb.Title,    TWEEN_MED, { TextTransparency = 1 })
                    tween(tb.UIStroke, TWEEN_MED, { Transparency = 1 })
                end
            end
        end
    end

    local function hide()
        if Debounce then return end
        Debounce = true
        Hidden = true

        if MPrompt then
            MPrompt.Title.TextColor3 = Color3.fromRGB(255,255,255)
            MPrompt.Position = UDim2.new(0.5, 0, 0, -50)
            MPrompt.Size = UDim2.new(0, 40, 0, 10)
