function VaenHub:_SaveConfig(window, profile)
	if not (writefile and makefolder) then return end
	local data = {}
	for _, elem in ipairs(window._elements) do
		if elem._flag then
			if elem._type == "ColorPicker" then
				local c = elem._current or Color3.new(1,1,1)
				data[elem._flag] = {c.R*255, c.G*255, c.B*255}
			else
				data[elem._flag] = elem._current
			end
		end
	end

	pcall(function()
		if not isfolder("VaenHub") then makefolder("VaenHub") end
		if not isfolder("VaenHub/Configs") then makefolder("VaenHub/Configs") end
		local folder = "VaenHub/Configs/" .. (window._configSave.FolderName or window._name)
		if not isfolder(folder) then makefolder(folder) end
		writefile(folder .. "/" .. profile .. ".vhc", HttpService:JSONEncode(data))
	end)
end

function VaenHub:_LoadConfig(window, profile)
	if not (readfile and isfile) then return end
	local folder = "VaenHub/Configs/" .. (window._configSave.FolderName or window._name)
	local path = folder .. "/" .. profile .. ".vhc"

	if not isfile(path) then return end

	local ok, data = pcall(function()
		return HttpService:JSONDecode(readfile(path))
	end)
	if not ok or not data then return end

	for _, elem in ipairs(window._elements) do
		if elem._flag and data[elem._flag] ~= nil then
			local value = data[elem._flag]
			if elem._type == "ColorPicker" and type(value) == "table" then
				value = Color3.fromRGB(value[1], value[2], value[3])
			end
			pcall(function() elem:Set(value) end)
		end
	end
end

function VaenHub:_ListProfiles(window)
	if not (listfiles and isfolder) then return {} end
	local folder = "VaenHub/Configs/" .. (window._configSave.FolderName or window._name)
	if not isfolder(folder) then return {} end

	local profiles = {}
	for _, file in ipairs(listfiles(folder)) do
		local name = file:match("([^/\\]+)%.vhc$")
		if name then table.insert(profiles, name) end
	end
	return profiles
end


