        ----------------------------------------------------------
        -- Slider
        ----------------------------------------------------------
        function Tab:CreateSlider(opts)
            opts = opts or {}
            local Slider = { Type = "Slider" }
            local min, max = opts.Min or 0, opts.Max or 100
            local inc = opts.Increment or 1
            local suffix = opts.Suffix or ""
            Slider.Value = math.clamp(opts.Default or min, min, max)

            local f = baseElement(50)
            local lbl = new("TextLabel", {
                Position = UDim2.new(0, 12, 0, 6),
                Size = UDim2.new(1, -24, 0, 16),
                BackgroundTransparency = 1,
                Font = FONT,
                Text = opts.Name or "Slider",
                TextSize = 13,
                TextColor3 = theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = f,
            })
            local valLbl = new("TextLabel", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, -12, 0, 6),
                Size = UDim2.new(0, 80, 0, 16),
                BackgroundTransparency = 1,
                Font = FONT,
                Text = tostring(Slider.Value) .. (suffix ~= "" and " " .. suffix or ""),
                TextSize = 12,
                TextColor3 = theme.SubText,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = f,
            })
            local bar = new("Frame", {
                Position = UDim2.new(0, 12, 1, -14),
                Size = UDim2.new(1, -24, 0, 6),
                BackgroundColor3 = theme.Stroke,
                BorderSizePixel = 0,
                Parent = f,
            })
            corner(bar, UDim.new(1, 0))
            local fill = new("Frame", {
                Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = theme.Accent,
                BorderSizePixel = 0,
                Parent = bar,
            })
            corner(fill, UDim.new(1, 0))

            local function setVal(v, fire)
                v = math.clamp(math.floor((v - min) / inc + 0.5) * inc + min, min, max)
                Slider.Value = v
                local pct = (v - min) / (max - min)
                tween(fill, TWEEN_FAST, { Size = UDim2.new(pct, 0, 1, 0) })
                valLbl.Text = tostring(v) .. (suffix ~= "" and " " .. suffix or "")
                if fire and opts.Callback then task.spawn(opts.Callback, v) end
            end

            local function fromX(x)
                local rel = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                return min + (max - min) * rel
            end

            local dragging = false
            bar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    setVal(fromX(input.Position.X), true)
                end
            end)
            track(UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                              or input.UserInputType == Enum.UserInputType.Touch) then
                    setVal(fromX(input.Position.X), true)
                end
            end))
            track(UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end))

            setVal(Slider.Value, false)

            function Slider:Set(v) setVal(v, true) end

            addListener(function(nt)
                lbl.TextColor3 = nt.Text
                valLbl.TextColor3 = nt.SubText
                bar.BackgroundColor3 = nt.Stroke
                fill.BackgroundColor3 = nt.Accent
            end)

            if opts.Flag then Phantom.Flags[opts.Flag] = Slider end
            return Slider
        end

