--==============================================================
-- 4. CHAINABLE BUILDERS
--==============================================================
function Elem:Default(v) self._default = v; self._current = v; return self end
function Elem:Range(a,b) self._min, self._max = a, b; return self end
function Elem:Increment(s) self._step = s; return self end
function Elem:Suffix(s) self._suffix = s; return self end
function Elem:Options(o) self._options = o; return self end
function Elem:Multi(e) self._multi = e ~= false; return self end
function Elem:Placeholder(p) self._placeholder = p; return self end
function Elem:Icon(i) self._icon = i; return self end
function Elem:Content(c)
	self._content = c
	if self._setContent then self._setContent(c) end
	return self
end

function Elem:Flag(f)
	self._flag = f
	VaenHub.Flags[f] = self
	return self
end

function Elem:OnChange(cb)
	self._callback = cb
	if not self._built then VaenHub:_MaterializeElement(self) end
	return self
end

Elem.OnClick = Elem.OnChange

function Elem:Build()
	if not self._built then VaenHub:_MaterializeElement(self) end
	return self
end

function Elem:Set(v)
	self._current = v
	if self._update then self._update(v) end
	if self._callback then task.spawn(pcall, self._callback, v) end
	return self
end

function Elem:Get() return self._current end

function Elem:Refresh(opts)
	self._options = opts
	if self._refreshOptions then self._refreshOptions() end
	return self
end

--==============================================================
-- 5. PROTECTION LAYER
--==============================================================
function VaenHub:_HideFromCoreGui(win)
	if not win._gui then return end
	win._gui.Name = HttpService:GenerateGUID(false):sub(1,8)
	local done = false
	if gethui then pcall(function() win._gui.Parent = gethui() done = true end) end
	if not done and syn and syn.protect_gui then
		pcall(function() syn.protect_gui(win._gui) win._gui.Parent = CoreGui done = true end)
	end
	if not done and protectgui then
		pcall(function() protectgui(win._gui) win._gui.Parent = CoreGui done = true end)
	end
	if not done then pcall(function() win._gui.Parent = CoreGui end) end
end

function VaenHub:_AntiAFK(win)
	pcall(function()
		local vu = svc("VirtualUser")
		local c = LocalPlayer.Idled:Connect(function()
			vu:CaptureController()
			vu:ClickButton2(Vector2.new())
		end)
		table.insert(win._connections, c)
	end)
end

function VaenHub:_AntiKick(win)
	if not hookmetamethod then return end
	pcall(function()
		local old; old = hookmetamethod(game, "__namecall", function(s, ...)
			local m = getnamecallmethod()
			if (m == "Kick" or m == "kick") and s == LocalPlayer then return nil end
			return old(s, ...)
		end)
	end)
end

function VaenHub:_AntiLag(win)
	pcall(function()
		settings().Rendering.QualityLevel = 1
		Lighting.GlobalShadows = false
		Lighting.FogEnd = 1e10
	end)
end

function VaenHub:_AutoRejoin(win)
	local pid, jid = game.PlaceId, game.JobId
	local c = GuiService.ErrorMessageChanged:Connect(function(msg)
		if msg and msg ~= "" then
			task.wait(2)
			pcall(function()
				TeleportService:TeleportToPlaceInstance(pid, jid, LocalPlayer)
			end)
		end
	end)
	table.insert(win._connections, c)
end

function VaenHub:_ServerHop(win, opts)
	win._serverHop = function()
		local req = (syn and syn.request) or http_request or request
		if not req then return false end
		local servers = {}
		local ok, resp = pcall(function()
			return req({Url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", game.PlaceId), Method = "GET"})
		end)
		if not ok or not resp then return false end
		local data = HttpService:JSONDecode(resp.Body)
		if not data or not data.data then return false end
		for _, s in ipairs(data.data) do
			if s.id ~= game.JobId and s.playing < s.maxPlayers then
				table.insert(servers, s)
			end
		end
		if #servers == 0 then return false end
		if opts.PreferLow then
			table.sort(servers, function(a,b) return a.playing < b.playing end)
		end
		TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[1].id, LocalPlayer)
		return true
	end
end

