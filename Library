-- DROPDOWN
VaenHub._Builders.Dropdown = function(self, elem)
	elem._options = elem._options or {}
	if type(elem._current) ~= "table" then
		elem._current = elem._default or {}
		if type(elem._current) == "string" then elem._current = {elem._current} end
	end

	local f = new("Frame", {
		Size = UDim2.new(1, 0, 0, ELEMENT_H),
		BackgroundColor3 = THEME.ElementBg,
		BorderSizePixel = 0,
		ClipsDescendants = true,
		LayoutOrder = elem._layoutOrder,
	}, elem._tab._page)
	corner(f, RADIUS)
	stroke(f, THEME.Border, 0.7)

	local hH = ELEMENT_H
	local icon, lblX = addIcon(f, elem._icon)

	new("TextLabel", {
		Size = UDim2.fromOffset(120, hH),
		Position = UDim2.fromOffset(lblX, 0),
		BackgroundTransparency = 1,
		Text = elem._name,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, f)

	local pill = new("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(120, 24),
		Position = UDim2.new(1, -18, 0, hH/2),
		BackgroundColor3 = THEME.ElementHover,
		BorderSizePixel = 0,
	}, f)
	corner(pill, 6)

	local pillText = new("TextLabel", {
		Size = UDim2.new(1, -24, 1, 0),
		Position = UDim2.fromOffset(8, 0),
		BackgroundTransparency = 1,
		Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current.." selected")) or "None",
		Font = Enum.Font.Gotham,
		TextSize = 11,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd,
	}, pill)

	-- Chevron from two rotated frames (no unicode square issue)
	local chevContainer = new("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(10, 10),
		Position = UDim2.new(1, -6, 0.5, 0),
		BackgroundTransparency = 1,
	}, pill)

	local chevLeft = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.fromOffset(7, 1.5),
		Position = UDim2.new(0.3, 0, 0.45, 0),
		BackgroundColor3 = THEME.TextDim,
		BorderSizePixel = 0,
		Rotation = 45,
	}, chevContainer)
	corner(chevLeft, 1)

	local chevRight = new("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.fromOffset(7, 1.5),
		Position = UDim2.new(0.7, 0, 0.45, 0),
		BackgroundColor3 = THEME.TextDim,
		BorderSizePixel = 0,
		Rotation = -45,
	}, chevContainer)
	corner(chevRight, 1)

	local opts = new("Frame", {
		Size = UDim2.new(1, -28, 0, 0),
		Position = UDim2.fromOffset(14, hH + 4),
		BackgroundTransparency = 1,
	}, f)
	list(opts, 4)

	local function refresh()
		for _, c in ipairs(opts:GetChildren()) do
			if c:IsA("TextButton") then c:Destroy() end
		end
		for _, opt in ipairs(elem._options) do
			local ob = new("TextButton", {
				Size = UDim2.new(1, 0, 0, 26),
				BackgroundColor3 = THEME.ElementHover,
				BorderSizePixel = 0,
				Text = "",
				AutoButtonColor = false,
			}, opts)
			corner(ob, 6)
			local olb = new("TextLabel", {
				Size = UDim2.new(1, -16, 1, 0),
				Position = UDim2.fromOffset(10, 0),
				BackgroundTransparency = 1,
				Text = opt,
				Font = Enum.Font.Gotham,
				TextSize = 11,
				TextColor3 = THEME.TextDim,
				TextXAlignment = Enum.TextXAlignment.Left,
			}, ob)

			local isSel = table.find(elem._current, opt) ~= nil
			if isSel then
				ob.BackgroundColor3 = THEME.AccentStart
				ob.BackgroundTransparency = 0.5
				olb.TextColor3 = THEME.Text
			end

			ob.MouseButton1Click:Connect(function()
				local idx = table.find(elem._current, opt)
				if elem._multi then
					if idx then table.remove(elem._current, idx) else table.insert(elem._current, opt) end
				else
					elem._current = {opt}
				end
				pillText.Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current.." selected")) or "None"
				for _, c in ipairs(opts:GetChildren()) do
					if c:IsA("TextButton") then
						local cl = c:FindFirstChildWhichIsA("TextLabel")
						if cl then
							local s = table.find(elem._current, cl.Text) ~= nil
							c.BackgroundColor3 = s and THEME.AccentStart or THEME.ElementHover
							c.BackgroundTransparency = s and 0.5 or 0
							cl.TextColor3 = s and THEME.Text or THEME.TextDim
						end
					end
				end
				if elem._callback then task.spawn(pcall, elem._callback, elem._current) end
				if elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
			end)
		end
	end
	refresh()

	local clickBtn = new("TextButton", {
		Size = UDim2.new(1, 0, 0, hH),
		BackgroundTransparency = 1,
		Text = "",
		AutoButtonColor = false,
	}, f)
	local open = false
	clickBtn.MouseButton1Click:Connect(function()
		open = not open
		local total = #elem._options * 30
		if open then
			tween(f, 0.25, {Size = UDim2.new(1, 0, 0, hH + total + 12)})
			tween(chevLeft, 0.25, {Rotation = -45, Position = UDim2.new(0.3, 0, 0.55, 0)})
			tween(chevRight, 0.25, {Rotation = 45, Position = UDim2.new(0.7, 0, 0.55, 0)})
		else
			tween(f, 0.25, {Size = UDim2.new(1, 0, 0, hH)})
			tween(chevLeft, 0.25, {Rotation = 45, Position = UDim2.new(0.3, 0, 0.45, 0)})
			tween(chevRight, 0.25, {Rotation = -45, Position = UDim2.new(0.7, 0, 0.45, 0)})
		end
	end)

	elem._frame = f
	elem._refresh = refresh
	elem._update = function(v)
		elem._current = type(v) == "table" and v or {v}
		pillText.Text = #elem._current > 0 and (#elem._current == 1 and elem._current[1] or (#elem._current.." selected")) or "None"
		refresh()
	end
end

