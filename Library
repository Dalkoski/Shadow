function Tab:CreateToggle(opts)
    local win = self._window
    local state = opts.CurrentValue or false
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local card = makeCard(self, 50)
    attachHover(card)
    makeIconSquare(card, 28, opts.Icon)
    makeCardLabels(card, opts.Name or "Toggle", opts.Description)
    local w, h = 34, 19
    local knobSize = h - 6
    local track = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(w, h), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0, ZIndex = 3,
    }, card)
    corner(track, math.floor(h/2))
    local trackStroke = stroke(track, Color3.fromRGB(255,255,255), wA(0.08), 1)
    local knob = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 2, 0.5, 0),
        Size = UDim2.fromOffset(knobSize, knobSize),
        BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, ZIndex = 4,
    }, track)
    corner(knob, math.floor(knobSize/2))
    local function apply(s, anim)
        state = s
        local d = anim and 0.2 or 0
        if s then
            tween(track, d, { BackgroundTransparency = wA(0.92) })
            tween(trackStroke, d, { Transparency = 1 })
            tween(knob, d, {
                Position = UDim2.new(1, -(knobSize + 2), 0.5, 0),
                BackgroundColor3 = COLOR.KnobOn, BackgroundTransparency = 0,
            }, Enum.EasingStyle.Quart)
        else
            tween(track, d, { BackgroundTransparency = wA(0.07) })
            tween(trackStroke, d, { Transparency = wA(0.08) })
            tween(knob, d, {
                Position = UDim2.new(0, 2, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BackgroundTransparency = wA(0.45),
            }, Enum.EasingStyle.Quart)
        end
    end
    apply(state, false)
    local hit = new("TextButton", {
        Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1,
        Text = "", AutoButtonColor = false, ZIndex = 5,
    }, card)
    hit.MouseButton1Click:Connect(function()
        state = not state
        apply(state, true)
        updateFlag(win, flag, state)
        win:SaveConfig()
        pcall(cb, state)
    end)
    local element = {
        Type = "Toggle", Value = state,
        Set = function(self2, v)
            state = v and true or false; self2.Value = state
            apply(state, true); updateFlag(win, flag, state); pcall(cb, state)
        end,
        Get = function() return state end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

function Tab:CreateSlider(opts)
    local win = self._window
    local range = opts.Range or {0, 100}
    local incr = opts.Increment or 1
    local value = opts.CurrentValue or range[1]
    local suffix = opts.Suffix or ""
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local card = makeCard(self, 50)
    attachHover(card)
    makeIconSquare(card, 28, opts.Icon)
    new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 51, 0.5, 0),
        Size = UDim2.fromOffset(80, 28), BackgroundTransparency = 1,
        Text = opts.Name or "Slider", Font = Enum.Font.GothamMedium, TextSize = 12,
        TextColor3 = COLOR.TextPrimary, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 3,
    }, card)
    local sliderArea = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 135, 0.5, 0),
        Size = UDim2.new(1, -(135 + 50 + 13 + 8), 0, 14),
        BackgroundTransparency = 1, ZIndex = 3,
    }, card)
    local track = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.new(1, 0, 0, 4), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.08), BorderSizePixel = 0, ZIndex = 3,
    }, sliderArea)
    corner(track, 2)
    local fill = new("Frame", {
        Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.85), BorderSizePixel = 0, ZIndex = 4,
    }, track)
    corner(fill, 2)
    local thumb = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.fromOffset(12, 12), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0, ZIndex = 5,
    }, track)
    corner(thumb, 6)
    stroke(thumb, Color3.fromRGB(0,0,0), 0.95, 1)
    local badge = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(46, 20), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.04), BorderSizePixel = 0, ZIndex = 3,
    }, card)
    corner(badge, 6)
    stroke(badge, Color3.fromRGB(255,255,255), wA(0.07), 1)
    local badgeText = new("TextLabel", {
        Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1,
        Text = tostring(value) .. (suffix ~= "" and (" " .. suffix) or ""),
        Font = Enum.Font.GothamMedium, TextSize = 11, TextColor3 = COLOR.TextPrimary, ZIndex = 4,
    }, badge)
    local function setVisual(v)
        local pct = math.clamp((v - range[1]) / (range[2] - range[1]), 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(pct, 0, 0.5, 0)
        badgeText.Text = tostring(v) .. (suffix ~= "" and (" " .. suffix) or "")
    end
    setVisual(value)
    local hit = new("TextButton", {
        Size = UDim2.new(1, 0, 1, 16), Position = UDim2.fromOffset(0, -8),
        BackgroundTransparency = 1, Text = "", AutoButtonColor = false, ZIndex = 6,
    }, sliderArea)
    local function updateFromX(x)
        local absX = track.AbsolutePosition.X
        local absW = track.AbsoluteSize.X
        local pct = math.clamp((x - absX) / absW, 0, 1)
        local raw = range[1] + pct * (range[2] - range[1])
        local v = math.floor(raw / incr + 0.5) * incr
        v = math.clamp(v, range[1], range[2])
        if v ~= value then
            value = v; setVisual(v); updateFlag(win, flag, v); pcall(cb, v)
        end
    end
    hit.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1
            and input.UserInputType ~= Enum.UserInputType.Touch then return end
        tween(thumb, 0.15, { Size = UDim2.fromOffset(14, 14) })
        updateFromX(input.Position.X)
        local moveConn, endConn
        moveConn = input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                if moveConn then moveConn:Disconnect() end
                tween(thumb, 0.15, { Size = UDim2.fromOffset(12, 12) })
                win:SaveConfig()
            end
        end)
        endConn = RunService.RenderStepped:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                endConn:Disconnect()
                return
            end
            updateFromX(input.Position.X)
        end)
    end)
    local element = {
        Type = "Slider", Value = value,
        Set = function(self2, v)
            value = math.clamp(v, range[1], range[2]); self2.Value = value
            setVisual(value); updateFlag(win, flag, value); pcall(cb, value)
        end,
        Get = function() return value end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

