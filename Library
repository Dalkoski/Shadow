--[[
    Phantom UI Library v2
    A clean Roblox UI library — same feel as Rayfield, less bloat.

    Quick API:
        local Phantom = loadstring(game:HttpGet("..."))()
        local Window = Phantom:CreateWindow({
            Name = "Title", Subtitle = "Desc", Theme = "Dark", Keybind = "K"
        })
        local Tab = Window:CreateTab("Main", nil)
        Tab:CreateSection("Stuff")
        Tab:CreateButton({ Name = "Go",      Callback = function() end })
        Tab:CreateToggle({ Name = "On",      Default = false, Flag = "t1", Callback = function(v) end })
        Tab:CreateSlider({ Name = "Spd",     Min = 0, Max = 100, Default = 50, Increment = 1, Suffix = "ms", Flag = "s1", Callback = function(v) end })
        Tab:CreateInput({  Name = "User",    Default = "", Placeholder = "...", ClearOnFocus = false, Flag = "i1", Callback = function(t) end })
        Tab:CreateKeybind({ Name = "Bind",   Default = "F", Flag = "k1", Callback = function() end })
        Tab:CreateDropdown({ Name = "Mode",  Options = {"A","B"}, Default = "A", Multi = false, Flag = "d1", Callback = function(v) end })
        Tab:CreateColorPicker({ Name="Tint", Default = Color3.new(1,1,1), Flag = "c1", Callback = function(c) end })
        Tab:CreateLabel("text")
        Tab:CreateParagraph({ Title = "T", Content = "C" })
        Tab:CreateDivider()
        Phantom:Notify({ Title = "...", Content = "...", Duration = 5 })
        Phantom.Flags["t1"]:Set(true)
        Window:SetTheme("Ocean")
        Window:Destroy()
]]

