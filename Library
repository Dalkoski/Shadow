--==============================================================
-- TAB BUILDER (with gradient pill on active)
--==============================================================
function VaenHub:_BuildTab(win, t)
	local theme = win._theme

	-- Pill button
	local btn = Instance.new("TextButton")
	btn.Name = t._name
	btn.AutomaticSize = Enum.AutomaticSize.X
	btn.Size = UDim2.new(0, 0, 0, 30)
	btn.BackgroundColor3 = theme.ElementBg
	btn.BackgroundTransparency = 1
	btn.BorderSizePixel = 0
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.Parent = win._tabBar
	corner(btn, 7)

	padding(btn, 0, 12, 0, 12)

	-- Gradient overlay (hidden when inactive)
	local pillGradient = Instance.new("UIGradient")
	pillGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, theme.Accent[1]),
		ColorSequenceKeypoint.new(1, theme.Accent[2]),
	}
	pillGradient.Rotation = 135
	pillGradient.Transparency = NumberSequence.new(1)
	pillGradient.Parent = btn

	-- Inner layout
	local innerLayout = Instance.new("UIListLayout")
	innerLayout.FillDirection = Enum.FillDirection.Horizontal
	innerLayout.Padding = UDim.new(0, 6)
	innerLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	innerLayout.Parent = btn

	-- Stroke (visible only when active)
	local btnStroke = Instance.new("UIStroke")
	btnStroke.Color = theme.AccentGlow
	btnStroke.Transparency = 1
	btnStroke.Thickness = 1
	btnStroke.Parent = btn

	-- Icon
	local iconImg
	if t._icon then
		local res = resolveIcon(t._icon)
		if res then
			iconImg = Instance.new("ImageLabel")
			iconImg.Size = UDim2.fromOffset(14, 14)
			iconImg.BackgroundTransparency = 1
			iconImg.Image = res.id
			iconImg.ImageRectOffset = res.rectOffset
			iconImg.ImageRectSize = res.rectSize
			iconImg.ImageColor3 = theme.TextDim
			iconImg.LayoutOrder = 1
			iconImg.Parent = btn
		end
	end

	-- Label
	local lbl = Instance.new("TextLabel")
	lbl.AutomaticSize = Enum.AutomaticSize.X
	lbl.Size = UDim2.new(0, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = t._name
	lbl.Font = Enum.Font.GothamMedium
	lbl.TextSize = 12
	lbl.TextColor3 = theme.TextDim
	lbl.LayoutOrder = 2
	lbl.Parent = btn

	t._button = btn
	t._buttonIcon = iconImg
	t._buttonLabel = lbl
	t._buttonStroke = btnStroke
	t._pillGradient = pillGradient

	-- Setting bg via gradient (we use a frame trick: the button's own bg shows gradient)
	-- Actually: when active we want it to look filled with gradient. We do this by
	-- setting BackgroundTransparency = 0 and applying the gradient on top.
	-- But UIGradient on a TextButton works on the BG fill.

	-- Click
	btn.MouseButton1Click:Connect(function()
		win:_SelectTab(t)
	end)

	-- Hover (only on inactive)
	btn.MouseEnter:Connect(function()
		if win._currentTab ~= t then
			tween(lbl, 0.2, {TextColor3 = theme.Text})
			if iconImg then tween(iconImg, 0.2, {ImageColor3 = theme.Text}) end
		end
	end)
	btn.MouseLeave:Connect(function()
		if win._currentTab ~= t then
			tween(lbl, 0.2, {TextColor3 = theme.TextDim})
			if iconImg then tween(iconImg, 0.2, {ImageColor3 = theme.TextDim}) end
		end
	end)

	-- Page
	local page = Instance.new("ScrollingFrame")
	page.Name = t._name
	page.Size = UDim2.fromScale(1, 1)
	page.BackgroundTransparency = 1
	page.BorderSizePixel = 0
	page.ScrollBarThickness = 2
	page.ScrollBarImageColor3 = theme.TextDim
	page.ScrollBarImageTransparency = 0.7
	page.CanvasSize = UDim2.new()
	page.AutomaticCanvasSize = Enum.AutomaticSize.Y
	page.Visible = false
	page.Parent = win._content

	listLayout(page, 8)
	padding(page, 10, 14, 12, 14)

	t._page = page
end

--==============================================================
-- ELEMENT FACTORY
--==============================================================
function VaenHub:_NewElement(tab, kind, name)
	local e = setmetatable({
		_type = kind, _name = name, _tab = tab, _window = tab._window,
		_built = false, _enabled = true,
	}, {__index = Elem})

	-- Auto-build elements that don't need a callback
	if kind == "Label" or kind == "Status" or kind == "Section"
		or kind == "Divider" or kind == "Paragraph" then
		task.defer(function() if not e._built then self:_MaterializeElement(e) end end)
	end
	return e
end

function VaenHub:_MaterializeElement(e)
	if e._built then return end
	e._built = true
	local b = self._ElementBuilders[e._type]
	if b then
		b(self, e)
		table.insert(e._window._elements, e)
	end
end

VaenHub._ElementBuilders = {}

--==============================================================
-- 11. ELEMENT BUILDERS — each one mockup-accurate
--==============================================================

-- Base row helper (consistent padding, icon, label)
local function elementRow(elem, height)
	local theme = elem._window._theme
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1, 0, 0, height or 40)
	frame.BackgroundColor3 = theme.ElementBg
	frame.BorderSizePixel = 0
	frame.Parent = elem._tab._page
	corner(frame, 8)
	local s = stroke(frame, Color3.fromRGB(255,255,255), 0.94)

	-- Subtle hover effect
	frame.MouseEnter:Connect(function()
		tween(frame, 0.2, {BackgroundColor3 = theme.ElementHover})
	end)
	frame.MouseLeave:Connect(function()
		tween(frame, 0.2, {BackgroundColor3 = theme.ElementBg})
	end)

	return frame, s
end

local function addRowIcon(frame, iconName, theme, color)
	local res = resolveIcon(iconName)
	if not res then return nil, 12 end -- x offset if no icon
	local img = Instance.new("ImageLabel")
	img.Size = UDim2.fromOffset(14, 14)
	img.Position = UDim2.fromOffset(14, 0)
	img.AnchorPoint = Vector2.new(0, 0.5)
	img.Position = UDim2.new(0, 14, 0.5, 0)
	img.BackgroundTransparency = 1
	img.Image = res.id
	img.ImageRectOffset = res.rectOffset
	img.ImageRectSize = res.rectSize
	img.ImageColor3 = color or theme.TextDim
	img.Parent = frame
	return img, 36 -- x offset for label
end

-- TOGGLE
VaenHub._ElementBuilders.Toggle = function(self, elem)
	local theme = elem._window._theme
	local frame = elementRow(elem, 40)

	-- Icon (optional)
	local iconImg, labelX = addRowIcon(frame, elem._icon, theme)

	-- Label
	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, -labelX - 60, 1, 0)
	lbl.Position = UDim2.fromOffset(labelX, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = elem._name
	lbl.Font = Enum.Font.Gotham
	lbl.TextSize = 13
	lbl.TextColor3 = theme.Text
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = frame

	-- Switch track
	local track = Instance.new("Frame")
	track.Size = UDim2.fromOffset(36, 18)
	track.AnchorPoint = Vector2.new(1, 0.5)
	track.Position = UDim2.new(1, -14, 0.5, 0)
	track.BackgroundColor3 = theme.ElementHover
	track.BorderSizePixel = 0
	track.Parent = frame
	corner(track, 9)

	-- Gradient fill (enabled when on)
	local fillGradient = gradient(track, theme.Accent, 135)
	fillGradient.Enabled = false

	-- Thumb
	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.fromOffset(14, 14)
	thumb.Position = UDim2.new(0, 2, 0.5, 0)
	thumb.AnchorPoint = Vector2.new(0, 0.5)
	thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	thumb.BorderSizePixel = 0
	thumb.Parent = track
	corner(thumb, 7)

	-- Glow when on
	local glow = Instance.new("UIStroke")
	glow.Color = theme.AccentGlow
	glow.Transparency = 1
	glow.Thickness = 1
	glow.Parent = thumb

	local clickBtn = Instance.new("TextButton")
	clickBtn.Size = UDim2.fromScale(1, 1)
	clickBtn.BackgroundTransparency = 1
	clickBtn.Text = ""
	clickBtn.AutoButtonColor = false
	clickBtn.Parent = frame

	local function update(v, animate)
		elem._current = v
		local pos = v and UDim2.new(1, -16, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
		local anchor = v and Vector2.new(1, 0.5) or Vector2.new(0, 0.5)
		if animate == false then
			thumb.Position = pos
			thumb.AnchorPoint = anchor
		else
			tween(thumb, 0.25, {Position = pos, AnchorPoint = anchor})
		end
		fillGradient.Enabled = v
		track.BackgroundColor3 = v and theme.Accent[1] or theme.ElementHover
		glow.Transparency = v and 0.4 or 1
	end

	clickBtn.MouseButton1Click:Connect(function()
		if not elem._enabled then return end
		update(not elem._current)
		if elem._callback then task.spawn(pcall, elem._callback, elem._current) end
		if elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
	end)

	elem._frame = frame
	elem._update = update
	update(elem._default == true, false)
end

-- SLIDER
VaenHub._ElementBuilders.Slider = function(self, elem)
	local theme = elem._window._theme
	elem._min = elem._min or 0
	elem._max = elem._max or 100
	elem._step = elem._step or 1
	elem._current = elem._default or elem._min

	local frame = elementRow(elem, 40)

	local iconImg, labelX = addRowIcon(frame, elem._icon, theme)

	-- Label
	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.fromOffset(80, 40)
	lbl.Position = UDim2.fromOffset(labelX, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = elem._name
	lbl.Font = Enum.Font.Gotham
	lbl.TextSize = 13
	lbl.TextColor3 = theme.Text
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = frame

	-- Value text
	local valText = Instance.new("TextLabel")
	valText.AnchorPoint = Vector2.new(1, 0.5)
	valText.Size = UDim2.fromOffset(60, 40)
	valText.Position = UDim2.new(1, -14, 0.5, 0)
	valText.BackgroundTransparency = 1
	valText.Text = tostring(elem._current) .. (elem._suffix and (" " .. elem._suffix) or "")
	valText.Font = Enum.Font.GothamMedium
	valText.TextSize = 12
	valText.TextColor3 = theme.TextDim
	valText.TextXAlignment = Enum.TextXAlignment.Right
	valText.Parent = frame

	-- Track
	local track = Instance.new("Frame")
	track.AnchorPoint = Vector2.new(0, 0.5)
	track.Size = UDim2.new(1, -(labelX + 80 + 80), 0, 4)
	track.Position = UDim2.new(0, labelX + 80, 0.5, 0)
	track.BackgroundColor3 = theme.ElementHover
	track.BorderSizePixel = 0
	track.Parent = frame
	corner(track, 2)

	-- Fill
	local fill = Instance.new("Frame")
	fill.Size = UDim2.fromScale(0, 1)
	fill.BackgroundColor3 = theme.Accent[1]
	fill.BorderSizePixel = 0
	fill.Parent = track
	corner(fill, 2)
	gradient(fill, theme.Accent, 0)

	-- Thumb with glow
	local thumb = Instance.new("Frame")
	thumb.AnchorPoint = Vector2.new(0.5, 0.5)
	thumb.Size = UDim2.fromOffset(11, 11)
	thumb.Position = UDim2.fromScale(0, 0.5)
	thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	thumb.BorderSizePixel = 0
	thumb.Parent = fill
	corner(thumb, 6)

	-- Thumb glow ring
	local thumbGlow = Instance.new("UIStroke")
	thumbGlow.Color = theme.AccentGlow
	thumbGlow.Transparency = 0.3
	thumbGlow.Thickness = 2
	thumbGlow.Parent = thumb

	-- Drag
	local dragging = false
	local function setFromX(x)
		local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local raw = elem._min + rel * (elem._max - elem._min)
		local snapped = math.floor(raw / elem._step + 0.5) * elem._step
		snapped = math.clamp(snapped, elem._min, elem._max)
		elem._current = snapped
		local percent = (snapped - elem._min) / (elem._max - elem._min)
		fill.Size = UDim2.fromScale(percent, 1)
		thumb.Position = UDim2.new(1, 0, 0.5, 0)
		valText.Text = tostring(snapped) .. (elem._suffix and (" " .. elem._suffix) or "")
		if elem._callback then task.spawn(pcall, elem._callback, snapped) end
	end

	track.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true; setFromX(i.Position.X)
		end
	end)
	-- Allow clicking on thumb/fill too
	thumb.InputBegan = nil -- (just in case)
	fill.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true; setFromX(i.Position.X)
		end
	end)

	local c1 = UserInputService.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
			setFromX(i.Position.X)
		end
	end)
	local c2 = UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			if dragging and elem._flag and elem._window._configSave.Enabled then
				elem._window:SaveConfig()
			end
			dragging = false
		end
	end)
	table.insert(elem._window._connections, c1)
	table.insert(elem._window._connections, c2)

	-- Init
	local p0 = (elem._current - elem._min) / (elem._max - elem._min)
	fill.Size = UDim2.fromScale(p0, 1)

	elem._frame = frame
	elem._update = function(v)
		elem._current = v
		local p = (v - elem._min) / (elem._max - elem._min)
		fill.Size = UDim2.fromScale(p, 1)
		valText.Text = tostring(v) .. (elem._suffix and (" " .. elem._suffix) or "")
	end
end

