-- Helpers
------------------------------------------------------------
local function tween(obj, info, props)
    local ok, t = pcall(TweenService.Create, TweenService, obj, info, props)
    if ok and t then t:Play(); return t end
end

local function fireThemeListeners()
    for _, fn in ipairs(themeListeners) do task.spawn(fn) end
end

local function applyThemeToAsset(theme)
    SelectedTheme = theme
    Main.BackgroundColor3                   = theme.Background
    Main.Topbar.BackgroundColor3            = theme.Topbar
    Main.Topbar.CornerRepair.BackgroundColor3 = theme.Topbar
    Main.Shadow.Image.ImageColor3           = theme.Shadow
    Main.Topbar.ChangeSize.ImageColor3      = theme.TextColor
    Main.Topbar.Hide.ImageColor3            = theme.TextColor
    if Topbar:FindFirstChild("Search")   then Topbar.Search.ImageColor3   = theme.TextColor end
    if Topbar:FindFirstChild("Settings") then
        Topbar.Settings.ImageColor3 = theme.TextColor
        Topbar.Divider.BackgroundColor3 = theme.ElementStroke
        Topbar.Settings.Visible = false  -- ukrywamy Rayfield settings tab button
    end
    if Main:FindFirstChild("Search") then
        Main.Search.BackgroundColor3 = theme.TextColor
        Main.Search.Shadow.ImageColor3 = theme.TextColor
        Main.Search.Search.ImageColor3 = theme.TextColor
        Main.Search.Input.PlaceholderColor3 = theme.TextColor
        Main.Search.UIStroke.Color = theme.SecondaryElementStroke
    end

    for _, descendant in ipairs(Rayfield:GetDescendants()) do
        if descendant.Parent and descendant.Parent.Parent ~= Notifications
        and (descendant:IsA("TextLabel") or descendant:IsA("TextBox")) then
            descendant.TextColor3 = theme.TextColor
        end
    end

    for _, tabPage in ipairs(Elements:GetChildren()) do
        for _, elem in ipairs(tabPage:GetChildren()) do
            if elem:IsA("Frame")
               and elem.Name ~= "Placeholder"
               and elem.Name ~= "SectionSpacing"
               and elem.Name ~= "Divider"
               and elem.Name ~= "SectionTitle"
               and elem.Name ~= "SearchTitle" then
                elem.BackgroundColor3 = theme.ElementBackground
                if elem:FindFirstChild("UIStroke") then
                    elem.UIStroke.Color = theme.ElementStroke
                end
            end
        end
    end

    fireThemeListeners()
end

local function changeTheme(name)
    local t = type(name) == "table" and name or Phantom.Theme[name]
    if t then applyThemeToAsset(t) end
end

------------------------------------------------------------
-- Drag (lightweight)
------------------------------------------------------------
local function makeDraggable(frame, handle)
    local dragging, startPos, startInput
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = frame.Position
            startInput = input.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local delta = input.Position - startInput
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end)
end

