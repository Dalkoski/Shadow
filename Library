        Font = Enum.Font.Gotham, TextSize = 10, TextColor3 = Color3.fromRGB(255,255,255),
        TextTransparency = whiteAlpha(0.4), TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true, ZIndex = 2,
    }, modal)
    local inputFrame = new("Frame", {
        Position = UDim2.fromOffset(20, 112), Size = UDim2.new(1, -40, 0, 32),
        BackgroundColor3 = Color3.fromRGB(255,255,255), BackgroundTransparency = whiteAlpha(0.05),
        BorderSizePixel = 0, ZIndex = 2,
    }, modal)
    corner(inputFrame, 7)
    local inputStroke = stroke(inputFrame, Color3.fromRGB(255,255,255), whiteAlpha(0.1), 1)
    local input = new("TextBox", {
        Position = UDim2.fromOffset(12, 0), Size = UDim2.new(1, -24, 1, 0),
        BackgroundTransparency = 1, Text = "", PlaceholderText = "Paste your key here",
        PlaceholderColor3 = Color3.fromRGB(140, 140, 140), Font = Enum.Font.Gotham,
        TextSize = 12, TextColor3 = COLOR.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false, ZIndex = 3,
    }, inputFrame)
    local submit = new("TextButton", {
        Position = UDim2.fromOffset(20, 156), Size = UDim2.new(0.5, -25, 0, 34),
        BackgroundColor3 = Color3.fromRGB(255,255,255), BackgroundTransparency = whiteAlpha(0.85),
        BorderSizePixel = 0, Text = "Submit", Font = Enum.Font.GothamMedium,
        TextSize = 12, TextColor3 = COLOR.KnobOn, AutoButtonColor = false, ZIndex = 2,
    }, modal)
    corner(submit, 8)
    submit.MouseEnter:Connect(function() tween(submit, 0.15, { BackgroundTransparency = whiteAlpha(0.7) }) end)
    submit.MouseLeave:Connect(function() tween(submit, 0.15, { BackgroundTransparency = whiteAlpha(0.85) }) end)
    local cancel = new("TextButton", {
        AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, -20, 0, 156),
        Size = UDim2.new(0.5, -25, 0, 34), BackgroundTransparency = whiteAlpha(0.05),
        BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0,
        Text = "Cancel", Font = Enum.Font.GothamMedium, TextSize = 12,
        TextColor3 = Color3.fromRGB(255,255,255), AutoButtonColor = false, ZIndex = 2,
    }, modal)
    corner(cancel, 8)
    stroke(cancel, Color3.fromRGB(255,255,255), whiteAlpha(0.1), 1)
    cancel.MouseButton1Click:Connect(function() gui:Destroy(); if onCancel then onCancel() end end)
    local function trySubmit()
        local text = input.Text
        for _, k in ipairs(keys) do
            if text == k then
                if opts.SaveKey then safeWrite(path, text) end
                gui:Destroy(); onSuccess(); return
            end
        end
        tween(inputStroke, 0.15, { Color = COLOR.Danger, Transparency = 0 })
        local origPos = modal.Position
        for i = 1, 3 do
            tween(modal, 0.05, { Position = origPos + UDim2.fromOffset(10, 0) }); task.wait(0.05)
            tween(modal, 0.05, { Position = origPos - UDim2.fromOffset(10, 0) }); task.wait(0.05)
        end
        tween(modal, 0.05, { Position = origPos })
        task.wait(0.4)
        tween(inputStroke, 0.3, { Color = Color3.fromRGB(255,255,255), Transparency = whiteAlpha(0.1) })
    end
    submit.MouseButton1Click:Connect(trySubmit)
    input.FocusLost:Connect(function(enter) if enter then trySubmit() end end)
end

