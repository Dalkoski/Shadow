-- Creates a new window. Returns a Window object.
function VaenHub:CreateWindow(config)
	config = config or {}
	local window = setmetatable({
		_config       = config,
		_tabs         = {},
		_elements     = {},
		_connections  = {},
		_unloadHooks  = {},
		_currentTab   = nil,
		_minimised    = false,
		_hidden       = false,
		_theme        = self:_ResolveTheme(config.Theme),
		_keybinds     = self:_ResolveKeybinds(config.Keybinds),
		_protect      = config.Protect or {},
		_keySystem    = config.KeySystem,
		_configSave   = config.Config or {},
		_name         = config.Name or "VaenHub",
		_loadingTitle = config.LoadingTitle or "VaenHub",
		_loadingSub   = config.LoadingSubtitle or "by Dalkoski",
	}, { __index = self._WindowMeta })

	-- Key system check before any UI shows
	if window._keySystem and window._keySystem.Enabled then
		local passed = self:_RunKeySystem(window)
		if not passed then
			window:Destroy()
			return nil
		end
	end

	-- Build the UI
	self:_BuildWindow(window)

	-- Run protection layer
	if window._protect then
		window:Protect(window._protect)
	end

	-- Load config if enabled
	if window._configSave.Enabled then
		task.delay(1, function()
			window:LoadConfig(window._configSave.Profile or "default")
		end)
	end

	table.insert(self.Windows, window)
	return window
end

-- Sends a notification to the user. Auto-stacks with limit.
function VaenHub:Notify(data)
	data = data or {}
	self:_QueueNotification({
		Title    = data.Title or "Notification",
		Content  = data.Content or "",
		Duration = data.Duration or 5,
		Icon     = data.Icon,
		Type     = data.Type or "default", -- default, success, warning, error
	})
end

-- Destroys all windows and disconnects everything.
function VaenHub:Destroy()
	self._destroyed = true
	for _, window in ipairs(self.Windows) do
		pcall(function() window:Destroy() end)
	end
	self.Windows = {}
	self.Flags = {}
end

-- Returns an element by flag name from any window.
function VaenHub:Get(flag)
	return self.Flags[flag]
end

-- Returns true if the UI is currently visible.
function VaenHub:IsVisible()
	for _, win in ipairs(self.Windows) do
		if not win._hidden then return true end
	end
	return false
end

-- Toggle UI visibility for all windows.
function VaenHub:SetVisibility(visible)
	for _, win in ipairs(self.Windows) do
		if visible then win:Show() else win:Hide() end
	end
end


--==============================================================
-- 2. WINDOW METHODS
--==============================================================
VaenHub._WindowMeta = {}
local Window = VaenHub._WindowMeta

-- Creates a new tab. Returns a Tab object for chaining elements.
function Window:Tab(name, icon)
	local tab = setmetatable({
		_name     = name,
		_icon     = icon,
		_window   = self,
		_elements = {},
		_button   = nil,
		_page     = nil,
	}, { __index = VaenHub._TabMeta })

	VaenHub:_BuildTab(self, tab)
	table.insert(self._tabs, tab)

	-- First tab is auto-selected
	if #self._tabs == 1 then
		self:_SelectTab(tab)
	end

	return tab
end

-- Enables protection features. Pass a table of booleans.
function Window:Protect(opts)
	opts = opts or {}
	if opts.HideUI       then VaenHub:_HideFromCoreGui(self) end
	if opts.AntiAFK      then VaenHub:_EnableAntiAFK(self) end
	if opts.AntiKick     then VaenHub:_EnableAntiKick(self) end
	if opts.AntiLag      then VaenHub:_EnableAntiLag(self) end
	if opts.AutoRejoin   then VaenHub:_EnableAutoRejoin(self) end
	if opts.ServerHop   and opts.ServerHop.Enabled then
		VaenHub:_SetupServerHop(self, opts.ServerHop)
	end
end

-- Registers a callback to run when the window is destroyed.
function Window:OnUnload(callback)
	table.insert(self._unloadHooks, callback)
end

-- Saves the current config to a named profile.
function Window:SaveConfig(profile)
	VaenHub:_SaveConfig(self, profile or "default")
end

-- Loads a named config profile.
function Window:LoadConfig(profile)
	VaenHub:_LoadConfig(self, profile or "default")
end

-- Lists all saved profiles for this window.
function Window:ListProfiles()
	return VaenHub:_ListProfiles(self)
end

-- Changes the theme at runtime. Accepts preset name or full theme table.
function Window:SetTheme(theme)
	self._theme = VaenHub:_ResolveTheme(theme)
	VaenHub:_ApplyTheme(self)
end

-- Hides the window.
function Window:Hide()
	if self._hidden then return end
	self._hidden = true
	VaenHub:_AnimateHide(self)
end

-- Shows the window.
function Window:Show()
	if not self._hidden then return end
	self._hidden = false
	VaenHub:_AnimateShow(self)
end

-- Toggles min/max state.
function Window:Minimise()
	self._minimised = not self._minimised
	VaenHub:_AnimateMinimise(self, self._minimised)
end

-- Destroys this window only.
function Window:Destroy()
	for _, hook in ipairs(self._unloadHooks) do
		pcall(hook)
	end
	for _, conn in ipairs(self._connections) do
		pcall(function() conn:Disconnect() end)
	end
	if self._gui then
		pcall(function() self._gui:Destroy() end)
	end
	if self._blurEffect then
		pcall(function() self._blurEffect:Destroy() end)
	end
end


