		PlaceholderColor3 = THEME.TextFaint,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
		ClearTextOnFocus = false,
	}, inputBg)

	box.Focused:Connect(function() tween(inputStrokeObj, 0.15, {Color = THEME.Accent, Transparency = 0.3}) end)
	box.FocusLost:Connect(function()
		tween(inputStrokeObj, 0.15, {Color = THEME.Border, Transparency = 0.6})
		elem._current = box.Text
		if elem._callback then task.spawn(pcall, elem._callback, box.Text) end
