            header.AutoButtonColor = false
            header.Parent = f

            local lbl = Instance.new("TextLabel")
            lbl.Position = UDim2.new(0, 12, 0, 0)
            lbl.Size = UDim2.new(1, -60, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Font = FONT
            lbl.Text = o.Name or "Color"
            lbl.TextSize = 13
            lbl.TextColor3 = Window._theme.Text
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.Parent = header

            local preview = Instance.new("Frame")
            preview.AnchorPoint = Vector2.new(1, 0.5)
            preview.Position = UDim2.new(1, -12, 0.5, 0)
            preview.Size = UDim2.new(0, 30, 0, 18)
            preview.BackgroundColor3 = Picker.Value
            preview.BorderSizePixel = 0
            preview.Parent = header
            corner(preview, UDim.new(0, 4))
            stroke(preview, Window._theme.ElementStroke, 1, 0.4)

            local body = Instance.new("Frame")
            body.Position = UDim2.new(0, 12, 0, 44)
            body.Size = UDim2.new(1, -24, 0, 100)
            body.BackgroundTransparency = 1
            body.Parent = f

            local satFrame = Instance.new("Frame")
            satFrame.Size = UDim2.new(1, -40, 1, 0)
            satFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            satFrame.BorderSizePixel = 0
            satFrame.Parent = body
            corner(satFrame, UDim.new(0, 4))

            local satWhite = Instance.new("Frame")
            satWhite.Size = UDim2.new(1, 0, 1, 0)
            satWhite.BackgroundColor3 = Color3.new(1, 1, 1)
            satWhite.BorderSizePixel = 0
            satWhite.Parent = satFrame
            corner(satWhite, UDim.new(0, 4))
            local whiteGrad = Instance.new("UIGradient")
            whiteGrad.Color = ColorSequence.new(Color3.new(1, 1, 1))
            whiteGrad.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 0),
                NumberSequenceKeypoint.new(1, 1),
            })
            whiteGrad.Parent = satWhite

            local satBlack = Instance.new("Frame")
            satBlack.Size = UDim2.new(1, 0, 1, 0)
            satBlack.BackgroundColor3 = Color3.new(0, 0, 0)
            satBlack.BorderSizePixel = 0
            satBlack.Parent = satFrame
            corner(satBlack, UDim.new(0, 4))
            local blackGrad = Instance.new("UIGradient")
            blackGrad.Color = ColorSequence.new(Color3.new(0, 0, 0))
            blackGrad.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(1, 0),
            })
            blackGrad.Rotation = 90
            blackGrad.Parent = satBlack

            local satKnob = Instance.new("Frame")
            satKnob.Size = UDim2.new(0, 8, 0, 8)
            satKnob.AnchorPoint = Vector2.new(0.5, 0.5)
            satKnob.Position = UDim2.new(sV, 0, 1 - v, 0)
            satKnob.BackgroundColor3 = Color3.new(1, 1, 1)
            satKnob.BorderSizePixel = 0
            satKnob.ZIndex = 5
            satKnob.Parent = satFrame
            corner(satKnob, UDim.new(1, 0))
            stroke(satKnob, Color3.new(0, 0, 0), 1, 0.5)

            local hueFrame = Instance.new("Frame")
            hueFrame.AnchorPoint = Vector2.new(1, 0)
            hueFrame.Position = UDim2.new(1, 0, 0, 0)
            hueFrame.Size = UDim2.new(0, 16, 1, 0)
            hueFrame.BackgroundColor3 = Color3.new(1, 1, 1)
            hueFrame.BorderSizePixel = 0
            hueFrame.Parent = body
            corner(hueFrame, UDim.new(0, 4))
            local hueGrad = Instance.new("UIGradient")
            hueGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0/6, Color3.fromRGB(255, 0, 0)),
                ColorSequenceKeypoint.new(1/6, Color3.fromRGB(255, 255, 0)),
                ColorSequenceKeypoint.new(2/6, Color3.fromRGB(0, 255, 0)),
                ColorSequenceKeypoint.new(3/6, Color3.fromRGB(0, 255, 255)),
                ColorSequenceKeypoint.new(4/6, Color3.fromRGB(0, 0, 255)),
                ColorSequenceKeypoint.new(5/6, Color3.fromRGB(255, 0, 255)),
                ColorSequenceKeypoint.new(6/6, Color3.fromRGB(255, 0, 0)),
            })
            hueGrad.Rotation = 90
            hueGrad.Parent = hueFrame

            local hueKnob = Instance.new("Frame")
            hueKnob.Size = UDim2.new(1, 4, 0, 4)
            hueKnob.Position = UDim2.new(0, -2, h, -2)
            hueKnob.BackgroundColor3 = Color3.new(1, 1, 1)
            hueKnob.BorderSizePixel = 0
            hueKnob.ZIndex = 5
            hueKnob.Parent = hueFrame
            corner(hueKnob, UDim.new(0, 2))

            local function updateColor(fire)
                Picker.Value = Color3.fromHSV(h, sV, v)
                preview.BackgroundColor3 = Picker.Value
                satFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                satKnob.Position = UDim2.new(sV, 0, 1 - v, 0)
                hueKnob.Position = UDim2.new(0, -2, h, -2)
                if fire and o.Callback then task.spawn(o.Callback, Picker.Value) end
            end

            local dragSat, dragHue = false, false
            track(satFrame.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1
                or i.UserInputType == Enum.UserInputType.Touch then
                    dragSat = true
                end
            end))
            track(hueFrame.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1
                or i.UserInputType == Enum.UserInputType.Touch then
                    dragHue = true
                end
            end))
            track(UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1
                or i.UserInputType == Enum.UserInputType.Touch then
                    dragSat, dragHue = false, false
                end
            end))
            track(UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType ~= Enum.UserInputType.MouseMovement
                and i.UserInputType ~= Enum.UserInputType.Touch then return end
                if dragSat then
                    sV = math.clamp((i.Position.X - satFrame.AbsolutePosition.X) / math.max(1, satFrame.AbsoluteSize.X), 0, 1)
                    v  = 1 - math.clamp((i.Position.Y - satFrame.AbsolutePosition.Y) / math.max(1, satFrame.AbsoluteSize.Y), 0, 1)
                    updateColor(true)
                elseif dragHue then
                    h = math.clamp((i.Position.Y - hueFrame.AbsolutePosition.Y) / math.max(1, hueFrame.AbsoluteSize.Y), 0, 1)
                    updateColor(true)
                end
            end))

            local open = false
            track(header.MouseButton1Click:Connect(function()
                open = not open
                tween(f, TWEEN_MED, { Size = UDim2.new(1, 0, 0, open and 156 or 38) })
            end))

            function Picker:Set(c)
                Picker.Value = c
                h, sV, v = c:ToHSV()
                updateColor(true)
            end

            onTheme(function(nt)
                f.BackgroundColor3 = nt.Element
                s.Color = nt.ElementStroke
                lbl.TextColor3 = nt.Text
            end)

            if o.Flag then Phantom.Flags[o.Flag] = Picker end
            return Picker
        end

        return Tab
    end

    --------------------------------------------------------
    -- Destroy
    --------------------------------------------------------
    function Window:Destroy()
        for _, c in ipairs(Window._connections) do
            pcall(function() c:Disconnect() end)
        end
        table.clear(Window._connections)
        table.clear(Window._themeListeners)
        if Window._gui then
            pcall(function() Window._gui:Destroy() end)
            Window._gui = nil
        end
        if Phantom._activeWindow == Window then
            Phantom._activeWindow = nil
        end
    end

    return Window
end

return Phantom
