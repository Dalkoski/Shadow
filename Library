-- 6. KEY SYSTEM (full-screen blur + glass card, gradient verify)
--==============================================================
function VaenHub:_RunKeySystem(win, ks)
	local theme = win._theme

	-- Check saved key
	if ks.SaveKey and isfile then
		local path = "VaenHub/Keys/" .. (ks.FileName or "key") .. ".key"
		if isfile(path) then
			local ok, saved = pcall(readfile, path)
			if ok then
				for _, k in ipairs(ks.Keys or {}) do
					if saved == k then return true end
				end
			end
		end
	end

	-- Build UI
	local gui = Instance.new("ScreenGui")
	gui.Name = HttpService:GenerateGUID(false):sub(1,8)
	gui.IgnoreGuiInset = true
	gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	gui.DisplayOrder = 999
	gui.ResetOnSpawn = false

	if gethui then gui.Parent = gethui()
	elseif syn and syn.protect_gui then syn.protect_gui(gui) gui.Parent = CoreGui
	else gui.Parent = CoreGui end

	-- Lighting blur
	local blur = Instance.new("BlurEffect")
	blur.Size = 0
	blur.Parent = Lighting
	tween(blur, 0.6, {Size = 24})

	-- Dim overlay
	local dim = Instance.new("Frame")
	dim.Size = UDim2.fromScale(1,1)
	dim.BackgroundColor3 = Color3.new(0,0,0)
	dim.BackgroundTransparency = 1
	dim.BorderSizePixel = 0
	dim.Parent = gui
	tween(dim, 0.5, {BackgroundTransparency = 0.55})

	-- Card
	local card = Instance.new("Frame")
	card.AnchorPoint = Vector2.new(0.5, 0.5)
	card.Position = UDim2.fromScale(0.5, 0.5)
	card.Size = UDim2.fromOffset(420, 0)
	card.BackgroundColor3 = theme.Background
	card.BackgroundTransparency = 0.05
	card.BorderSizePixel = 0
	card.ClipsDescendants = true
	card.Parent = gui
	corner(card, 14)
	stroke(card, Color3.fromRGB(255,255,255), 0.88)

	-- Top accent bar (gradient)
