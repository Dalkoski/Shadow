--==============================================================
-- 8. ICON RESOLVER (Lucide via icons.lua bundled file)
--==============================================================
-- Loads Lucide icons. Returns {id, rectOffset, rectSize} or nil
local Icons
local iconLoadTried = false

local function loadIcons()
	if iconLoadTried then return Icons end
	iconLoadTried = true
	local ok, result = pcall(function()
		return loadstring(game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/refs/heads/main/icons.lua"))()
	end)
	if ok then Icons = result end
	return Icons
end

local function resolveIcon(name)
	if not name or name == "" then return nil end
	loadIcons()
	if not Icons or not Icons["48px"] then return nil end
	local key = string.lower(tostring(name)):match("^%s*(.*)%s*$")
	local data = Icons["48px"][key]
	if not data then return nil end
	return {
		id = "rbxassetid://" .. data[1],
		rectOffset = Vector2.new(data[3][1], data[3][2]),
		rectSize = Vector2.new(data[2][1], data[2][2]),
	}
end

VaenHub._resolveIcon = resolveIcon

--==============================================================
-- UTILITY: tween, corner, stroke, gradient
--==============================================================
local function tween(obj, time, props, style, dir)
	local t = TweenService:Create(obj, TweenInfo.new(time, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out), props)
	t:Play()
	return t
end

local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function stroke(parent, color, transparency, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Transparency = transparency or 0.9
	s.Thickness = thickness or 1
	s.Parent = parent
	return s
end

local function gradient(parent, colors, rotation, transparency)
	local g = Instance.new("UIGradient")
	if typeof(colors) == "ColorSequence" then
		g.Color = colors
	else
		local kp = {}
		for i, c in ipairs(colors) do
			table.insert(kp, ColorSequenceKeypoint.new((i-1)/(#colors-1), c))
		end
		g.Color = ColorSequence.new(kp)
	end
	g.Rotation = rotation or 0
	if transparency then
		g.Transparency = NumberSequence.new(transparency)
	end
	g.Parent = parent
	return g
end

local function padding(parent, top, right, bottom, left)
	local p = Instance.new("UIPadding")
	p.PaddingTop    = UDim.new(0, top or 0)
	p.PaddingRight  = UDim.new(0, right or 0)
	p.PaddingBottom = UDim.new(0, bottom or 0)
	p.PaddingLeft   = UDim.new(0, left or 0)
	p.Parent = parent
	return p
end

local function listLayout(parent, padding, direction)
	local l = Instance.new("UIListLayout")
	l.Padding = UDim.new(0, padding or 0)
	l.FillDirection = direction or Enum.FillDirection.Vertical
	l.SortOrder = Enum.SortOrder.LayoutOrder
	l.Parent = parent
	return l
end

VaenHub._tween = tween
VaenHub._corner = corner
VaenHub._stroke = stroke
VaenHub._gradient = gradient

--==============================================================
-- 1. PUBLIC API
--==============================================================
function VaenHub:CreateWindow(config)
	config = config or {}
	local theme = self:_ResolveTheme(config.Theme)

	local win = setmetatable({
		_config      = config,
		_theme       = theme,
		_tabs        = {},
		_elements    = {},
		_connections = {},
		_unloadHooks = {},
		_hidden      = false,
		_minimised   = false,
		_keybinds    = config.Keybinds or {Toggle = "K"},
		_protect     = config.Protect or {},
		_configSave  = config.Config or {},
		_name        = config.Name or "VaenHub",
		_version     = config.Version or "v2.0",
	}, {__index = Window})

	-- Key system first
	if config.KeySystem and config.KeySystem.Enabled then
		local passed = self:_RunKeySystem(win, config.KeySystem)
		if not passed then return nil end
	end

	-- Build UI
	self:_BuildWindow(win)

	-- Protection
	if win._protect then win:Protect(win._protect) end

	-- Auto-load config
	if win._configSave.Enabled then
		task.delay(0.5, function() win:LoadConfig() end)
	end

	table.insert(self.Windows, win)
	return win
end

function VaenHub:Notify(data)
	data = data or {}
	self:_QueueNotif({
		Title    = data.Title or "Notification",
		Content  = data.Content or "",
		Duration = data.Duration or 5,
		Type     = data.Type or "default",
		Icon     = data.Icon,
	})
end

function VaenHub:Get(flag)
	return self.Flags[flag]
end

function VaenHub:Destroy()
	self._destroyed = true
	for _, w in ipairs(self.Windows) do pcall(function() w:Destroy() end) end
	self.Windows = {}
	self.Flags = {}
end

function VaenHub:_ResolveTheme(input)
	if type(input) == "string" then
		return self.Presets[input] or self.Presets.Phantom
	end
	if type(input) == "table" then
		local base = {}
		for k, v in pairs(self.Presets.Phantom) do base[k] = v end
		for k, v in pairs(input) do base[k] = v end
		return base
	end
	return self.Presets.Phantom
end

--==============================================================
-- 2. WINDOW METHODS
--==============================================================
function Window:Tab(name, iconName)
	local t = setmetatable({
		_name     = name,
		_icon     = iconName,
		_window   = self,
		_elements = {},
	}, {__index = Tab})

	VaenHub:_BuildTab(self, t)
	table.insert(self._tabs, t)

	if #self._tabs == 1 then
		self:_SelectTab(t)
	end
	return t
end

function Window:Protect(opts)
	opts = opts or {}
	if opts.HideUI     then VaenHub:_HideFromCoreGui(self) end
	if opts.AntiAFK    then VaenHub:_AntiAFK(self) end
	if opts.AntiKick   then VaenHub:_AntiKick(self) end
	if opts.AntiLag    then VaenHub:_AntiLag(self) end
	if opts.AutoRejoin then VaenHub:_AutoRejoin(self) end
	if opts.ServerHop and opts.ServerHop.Enabled then
		VaenHub:_ServerHop(self, opts.ServerHop)
	end
end

function Window:OnUnload(cb) table.insert(self._unloadHooks, cb) end

function Window:SaveConfig(profile) VaenHub:_SaveConfig(self, profile or "default") end
function Window:LoadConfig(profile) VaenHub:_LoadConfig(self, profile or "default") end

function Window:SetTheme(t)
	self._theme = VaenHub:_ResolveTheme(t)
	VaenHub:_ApplyTheme(self)
end

function Window:Hide()
	self._hidden = true
	VaenHub:_AnimateHide(self)
end

function Window:Show()
	self._hidden = false
	VaenHub:_AnimateShow(self)
end

function Window:Toggle()
	if self._hidden then self:Show() else self:Hide() end
end

function Window:Minimise()
	self._minimised = not self._minimised
	VaenHub:_AnimateMinimise(self)
end

function Window:Destroy()
	for _, h in ipairs(self._unloadHooks) do pcall(h) end
	for _, c in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
	if self._gui then pcall(function() self._gui:Destroy() end) end
end

function Window:_SelectTab(tab)
	local theme = self._theme
	for _, t in ipairs(self._tabs) do
		local selected = (t == tab)
		t._page.Visible = selected
		if t._pillGradient then
			t._pillGradient.Transparency = NumberSequence.new(selected and 0.7 or 1)
		end
		tween(t._buttonLabel, 0.25, {TextColor3 = selected and theme.Text or theme.TextDim})
		if t._buttonIcon then
			tween(t._buttonIcon, 0.25, {ImageColor3 = selected and theme.Text or theme.TextDim})
		end
		if t._buttonStroke then
			tween(t._buttonStroke, 0.25, {Transparency = selected and 0.65 or 1})
		end
	end
	self._currentTab = tab
end

