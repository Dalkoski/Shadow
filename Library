            AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 51, 0.5, 7),
            Size = UDim2.new(1, -150, 0, 12), BackgroundTransparency = 1, Text = desc,
            Font = Enum.Font.Gotham, TextSize = 10, TextColor3 = Color3.fromRGB(255,255,255),
            TextTransparency = whiteAlpha(0.4), TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Center, ZIndex = 3,
        }, card)
    end
    return titleLbl, descLbl
end

local function attachHover(card, base, hover)
    base = base or whiteAlpha(0.025)
    hover = hover or whiteAlpha(0.05)
    card.MouseEnter:Connect(function() tween(card, 0.15, { BackgroundTransparency = hover }) end)
    card.MouseLeave:Connect(function() tween(card, 0.15, { BackgroundTransparency = base }) end)
end

local function registerFlag(win, flag, element)
    if not flag then return end
    Library.Flags[flag] = element
    win.Flags[flag] = element.Value
end
local function updateFlag(win, flag, value) if flag then win.Flags[flag] = value end end

