        tween(Topbar.Divider,           TWEEN_MED, { BackgroundTransparency = 1 })
        tween(Main,   TWEEN_MED, { Size = UDim2.new(0, 495, 0, 45) })
        tween(Topbar, TWEEN_MED, { Size = UDim2.new(0, 495, 0, 45) })
