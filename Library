function Library:HttpRequest(data)
    if not exec.request then return nil, "no request function" end
    local ok, res = pcall(exec.request, data)
    if not ok then return nil, tostring(res) end
    return res
end

function Library:SendWebhook(url, content, opts)
    if type(url) ~= "string" or url == "" then return false end
    opts = opts or {}
    local data = {
        content = (not opts.Embed) and content or nil,
        username = opts.Username,
        avatar_url = opts.AvatarUrl,
    }
    if opts.Embed then
        local e = opts.Embed
        if type(e) == "string" then e = { description = e } end
        if content and not e.description then e.description = content end
        data.embeds = { e }
    end
    if not exec.request then return false end
    local ok, res = pcall(exec.request, {
        Url = url, Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = HttpService:JSONEncode(data),
    })
    if not ok then return false end
    local code = res and (res.StatusCode or res.Status or res.status_code)
    if not code then return true end
    return code >= 200 and code < 300
end

function Library:SetVisibility(v)
    for _, w in ipairs(self._windows) do
        if not w._destroyed then w:SetVisibility(v) end
    end
end

function Library:IsVisible()
    for _, w in ipairs(self._windows) do
        if not w._destroyed and w:IsVisible() then return true end
    end
    return false
end

function Library:Destroy()
    for _, w in ipairs(self._windows) do
        if not w._destroyed then w:Destroy() end
    end
end

