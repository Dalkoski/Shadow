-- TOGGLE (gradient track when on)
VaenHub._Builders.Toggle = function(self, elem)
	local f = row(elem)
	local icon, lblX = addIcon(f, elem._icon)

	local lbl = new("TextLabel", {
		Size = UDim2.new(1, -(lblX + 60), 1, 0),
		Position = UDim2.fromOffset(lblX, 0),
		BackgroundTransparency = 1,
		Text = elem._name,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, f)

	local track = new("Frame", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(36, 18),
		Position = UDim2.new(1, -14, 0.5, 0),
		BackgroundColor3 = THEME.ElementHover,
		BorderSizePixel = 0,
	}, f)
	corner(track, 9)

	-- Neon glow underneath the track (your spec — rbxassetid 4998051433)
	local trackGlow = new("ImageLabel", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Size = UDim2.new(1, 16, 1, 16),
		Position = UDim2.fromScale(0.5, 0.5),
		BackgroundTransparency = 1,
		Image = "rbxassetid://4998051433",
		ImageColor3 = THEME.AccentEnd,
		ImageTransparency = 1,
		ZIndex = 0,
	}, track)

	local trackGrad = gradient(track, THEME.AccentStart, THEME.AccentEnd, 90)
	trackGrad.Enabled = false

	local thumb = new("Frame", {
		Size = UDim2.fromOffset(13, 13),
		Position = UDim2.new(0, 3, 0.5, 0),
		AnchorPoint = Vector2.new(0, 0.5),
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BorderSizePixel = 0,
		ZIndex = 2,
	}, track)
	corner(thumb, 7)
	local glow = new("UIStroke", {Color = THEME.AccentGlow, Transparency = 1, Thickness = 2}, thumb)

	local btn = new("TextButton", {Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text="", AutoButtonColor=false}, f)

	local function upd(v, anim)
		elem._current = v
		local pos = v and UDim2.new(1, -3, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
		local anc = v and Vector2.new(1, 0.5) or Vector2.new(0, 0.5)
		if anim == false then
			thumb.Position = pos; thumb.AnchorPoint = anc
			track.BackgroundColor3 = v and THEME.AccentStart or THEME.ElementHover
			trackGrad.Enabled = v
			glow.Transparency = v and 0.5 or 1
			trackGlow.ImageTransparency = v and 0.6 or 1
		else
			-- 0.15s Quad easing per spec
			tween(thumb, 0.15, {Position = pos, AnchorPoint = anc}, Enum.EasingStyle.Quad)
			tween(track, 0.15, {BackgroundColor3 = v and THEME.AccentStart or THEME.ElementHover}, Enum.EasingStyle.Quad)
			trackGrad.Enabled = v
			tween(glow, 0.15, {Transparency = v and 0.5 or 1}, Enum.EasingStyle.Quad)
			tween(trackGlow, 0.15, {ImageTransparency = v and 0.6 or 1}, Enum.EasingStyle.Quad)
		end
	end

	btn.MouseButton1Click:Connect(function()
		if not elem._enabled then return end
		upd(not elem._current)
		if elem._callback then task.spawn(pcall, elem._callback, elem._current) end
		if elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
	end)

	elem._frame = f
	elem._update = function(v) upd(v) end
	upd(elem._default == true, false)
end

