VaenHub._ElementBuilders.Slider = function(self, elem)
	local window = elem._window
	local theme  = window._theme

	elem._min = elem._min or 0
	elem._max = elem._max or 100
	elem._step = elem._step or 1
	elem._current = elem._default or elem._min

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1, 0, 0, 36)
	frame.BackgroundColor3 = theme.ElementBg
	frame.BorderSizePixel = 0
	frame:SetAttribute("ThemeRole", "ElementBg")
	frame.Parent = elem._tab._page

	makeCorner(frame, 8)
	makeGradientStroke(frame, theme, 0.94)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromOffset(70, 36)
	label.Position = UDim2.fromOffset(12, 0)
	label.BackgroundTransparency = 1
	label.Text = elem._name
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.TextColor3 = theme.Text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = frame

	-- Value text
	local valueText = Instance.new("TextLabel")
	valueText.Size = UDim2.fromOffset(40, 36)
	valueText.Position = UDim2.new(1, -52, 0, 0)
	valueText.BackgroundTransparency = 1
	valueText.Text = tostring(elem._current)
	valueText.Font = Enum.Font.GothamMedium
	valueText.TextSize = 11
	valueText.TextColor3 = theme.TextDim
	valueText.TextXAlignment = Enum.TextXAlignment.Right
	valueText.Parent = frame

	-- Track
	local track = Instance.new("Frame")
	track.Size = UDim2.new(1, -136, 0, 3)
	track.Position = UDim2.new(0, 86, 0.5, -1)
	track.BackgroundColor3 = theme.ElementHover
	track.BorderSizePixel = 0
	track.Parent = frame

	makeCorner(track, 2)

	-- Fill
	local fill = Instance.new("Frame")
	fill.Size = UDim2.fromScale(0, 1)
	fill.BackgroundColor3 = theme.Accent[1]
	fill.BorderSizePixel = 0
	fill.Parent = track

	makeCorner(fill, 2)

	local fillGradient = Instance.new("UIGradient")
	fillGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, theme.Accent[1]),
		ColorSequenceKeypoint.new(1, theme.Accent[2]),
	}
	fillGradient.Parent = fill

	-- Thumb
	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.fromOffset(10, 10)
	thumb.AnchorPoint = Vector2.new(0.5, 0.5)
	thumb.Position = UDim2.fromScale(0, 0.5)
	thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	thumb.BorderSizePixel = 0
	thumb.Parent = fill

	makeCorner(thumb, 5)

	-- Drag logic
	local dragging = false
	local function setFromX(x)
		local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local raw = elem._min + rel * (elem._max - elem._min)
		local snapped = math.floor(raw / elem._step + 0.5) * elem._step
		snapped = math.clamp(snapped, elem._min, elem._max)
		elem._current = snapped

		local percent = (snapped - elem._min) / (elem._max - elem._min)
		fill.Size = UDim2.fromScale(percent, 1)
		thumb.Position = UDim2.new(1, 0, 0.5, 0)
		valueText.Text = tostring(snapped) .. (elem._suffix and (" " .. elem._suffix) or "")

		if elem._callback then
			task.spawn(pcall, elem._callback, snapped)
		end
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setFromX(input.Position.X)
		end
	end)

	local conn = UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			setFromX(input.Position.X)
		end
	end)

	local endConn = UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			if dragging and elem._flag and window._configSave.Enabled then
				window:SaveConfig()
			end
			dragging = false
		end
	end)
	table.insert(window._connections, conn)
	table.insert(window._connections, endConn)

	-- Init
	local initPercent = (elem._current - elem._min) / (elem._max - elem._min)
	fill.Size = UDim2.fromScale(initPercent, 1)

	elem._frame = frame
	elem._update = function(value)
		elem._current = value
		local p = (value - elem._min) / (elem._max - elem._min)
		fill.Size = UDim2.fromScale(p, 1)
		valueText.Text = tostring(value) .. (elem._suffix and (" " .. elem._suffix) or "")
	end
end

