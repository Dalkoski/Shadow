local function makeTab(name, active, layoutOrder)
	local t = new("TextButton", {
		Name = "Tab_" .. name,
		Size = UDim2.new(1, 0, 0, 32),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = active and whiteAlpha(0.06) or 1,
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = false,
		LayoutOrder = layoutOrder,
		ZIndex = 2,
	}, tabList)
	corner(t, 8)
	if active then
		stroke(t, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)
	end

	-- icon placeholder (14x14, 11px left padding, vertically centered)
	new("ImageLabel", {
		Name = "Icon",
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(0, 11, 0.5, 0),
		Size = UDim2.fromOffset(14, 14),
		BackgroundTransparency = 1,
		Image = "",  -- ← inject Tabler icon asset later
		ImageColor3 = Color3.fromRGB(255, 255, 255),
		ImageTransparency = active and 0 or whiteAlpha(0.5),
		ZIndex = 3,
	}, t)

	-- label (gap 10 between icon and text per HTML)
	new("TextLabel", {
		Name = "Label",
		AnchorPoint = Vector2.new(0, 0.5),
		Position = UDim2.new(0, 11 + 14 + 10, 0.5, 0),
		Size = UDim2.new(1, -(11 + 14 + 10 + 11), 1, 0),
		BackgroundTransparency = 1,
		Text = name,
		Font = Enum.Font.GothamMedium,
		TextSize = 12,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		TextTransparency = active and 0 or whiteAlpha(0.5),
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		ZIndex = 3,
	}, t)

	return t
end

