--==============================================================
-- PUBLIC API
--==============================================================
function VaenHub:CreateWindow(cfg)
	cfg = cfg or {}
	local win = setmetatable({
		_config = cfg,
		_tabs = {},
		_elements = {},
		_connections = {},
		_unloadHooks = {},
		_hidden = false,
		_minimised = false,
		_keybinds = cfg.Keybinds or {Toggle = "K"},
		_protect = cfg.Protect or {},
		_configSave = cfg.Config or {},
		_name = cfg.Name or "VaenHub",
		_version = cfg.Version or "v3.4",
		_currentTab = nil,
		_tabOrder = 0,
	}, {__index = Window})

	if cfg.KeySystem and cfg.KeySystem.Enabled then
		local ok = self:_RunKeySystem(win, cfg.KeySystem)
		if not ok then return nil end
	end

	self:_BuildWindow(win)
	if win._protect then win:Protect(win._protect) end
	if win._configSave.Enabled then
		task.delay(0.5, function() win:LoadConfig() end)
	end

	table.insert(self.Windows, win)
	return win
end

function VaenHub:Notify(d)
	d = d or {}
	self:_QueueNotif({
		Title = d.Title or "Notification",
		Content = d.Content or "",
		Duration = d.Duration or 5,
		Type = d.Type or "default",
	})
end

function VaenHub:Get(flag) return self.Flags[flag] end

function VaenHub:Destroy()
	for _, w in ipairs(self.Windows) do pcall(function() w:Destroy() end) end
	self.Windows = {}
	self.Flags = {}
end

--==============================================================
-- WINDOW METHODS
--==============================================================
function Window:Tab(name, iconName)
	local t = setmetatable({
		_name = name,
		_icon = iconName,
		_window = self,
		_elements = {},
		_elemOrder = 0,
	}, {__index = Tab})
	VaenHub:_BuildTab(self, t)
	table.insert(self._tabs, t)
	if #self._tabs == 1 then self:_SelectTab(t) end
	return t
end

function Window:Protect(opts)
	opts = opts or {}
	if opts.HideUI     then VaenHub:_HideFromCoreGui(self) end
	if opts.AntiAFK    then VaenHub:_AntiAFK(self) end
	if opts.AntiKick   then VaenHub:_AntiKick(self) end
	if opts.AntiLag    then VaenHub:_AntiLag(self) end
	if opts.AutoRejoin then VaenHub:_AutoRejoin(self) end
	if opts.ServerHop and opts.ServerHop.Enabled then VaenHub:_ServerHop(self, opts.ServerHop) end
end

function Window:OnUnload(cb) table.insert(self._unloadHooks, cb) end
function Window:SaveConfig(p) VaenHub:_SaveConfig(self, p or "default") end
function Window:LoadConfig(p) VaenHub:_LoadConfig(self, p or "default") end

function Window:Hide()
	self._hidden = true
	tween(self._main, 0.3, {Size = UDim2.fromOffset(WINDOW_W, 0)}, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
end
function Window:Show()
	self._hidden = false
	tween(self._main, 0.4, {Size = UDim2.fromOffset(WINDOW_W, WINDOW_H)})
end
function Window:Toggle() if self._hidden then self:Show() else self:Hide() end end

function Window:Minimise()
	self._minimised = not self._minimised
	if self._minimised then
		self._content.Visible = false
		self._tabBar.Visible = false
		tween(self._main, 0.3, {Size = UDim2.fromOffset(WINDOW_W, TOPBAR_H)})
	else
		tween(self._main, 0.3, {Size = UDim2.fromOffset(WINDOW_W, WINDOW_H)})
		task.wait(0.2)
		self._content.Visible = true
		self._tabBar.Visible = true
	end
end

function Window:Destroy()
	for _, h in ipairs(self._unloadHooks) do pcall(h) end
	for _, c in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
	if self._gui then pcall(function() self._gui:Destroy() end) end
end

function Window:_SelectTab(tab)
	local isInitial = (self._currentTab == nil)
	for _, t in ipairs(self._tabs) do
		local sel = (t == tab)
		t._page.Visible = sel
		if sel then
			t._button.BackgroundColor3 = Color3.fromRGB(38, 32, 64)
			if isInitial then
				-- First paint: instant, no race
				t._button.BackgroundTransparency = 0
				t._buttonLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
				if t._buttonIcon then
					if t._buttonIcon:IsA("ImageLabel") then
						t._buttonIcon.ImageColor3 = Color3.fromRGB(255, 255, 255)
					else
						t._buttonIcon.TextColor3 = Color3.fromRGB(255, 255, 255)
					end
				end
			else
				-- Subsequent switches: smooth tween
				tween(t._button, 0.15, {BackgroundTransparency = 0}, Enum.EasingStyle.Quad)
				tween(t._buttonLabel, 0.15, {TextColor3 = Color3.fromRGB(255, 255, 255)}, Enum.EasingStyle.Quad)
				if t._buttonIcon then
					if t._buttonIcon:IsA("ImageLabel") then
						tween(t._buttonIcon, 0.15, {ImageColor3 = Color3.fromRGB(255, 255, 255)}, Enum.EasingStyle.Quad)
					else
						tween(t._buttonIcon, 0.15, {TextColor3 = Color3.fromRGB(255, 255, 255)}, Enum.EasingStyle.Quad)
					end
				end
			end
		else
			if isInitial then
				t._button.BackgroundTransparency = 1
				t._buttonLabel.TextColor3 = Color3.fromRGB(140, 140, 155)
				if t._buttonIcon then
					if t._buttonIcon:IsA("ImageLabel") then
						t._buttonIcon.ImageColor3 = Color3.fromRGB(140, 140, 155)
					else
						t._buttonIcon.TextColor3 = Color3.fromRGB(140, 140, 155)
					end
				end
			else
				tween(t._button, 0.15, {BackgroundTransparency = 1}, Enum.EasingStyle.Quad)
				tween(t._buttonLabel, 0.15, {TextColor3 = Color3.fromRGB(140, 140, 155)}, Enum.EasingStyle.Quad)
				if t._buttonIcon then
					if t._buttonIcon:IsA("ImageLabel") then
						tween(t._buttonIcon, 0.15, {ImageColor3 = Color3.fromRGB(140, 140, 155)}, Enum.EasingStyle.Quad)
					else
						tween(t._buttonIcon, 0.15, {TextColor3 = Color3.fromRGB(140, 140, 155)}, Enum.EasingStyle.Quad)
					end
				end
			end
		end
	end
	self._currentTab = tab
end

