-- Notifications
------------------------------------------------------------
local NotifyHolder
local function ensureNotifyHolder()
    if NotifyHolder and NotifyHolder.Parent then return NotifyHolder end
    local gui = Instance.new("ScreenGui")
    gui.Name = "PhantomNotify"
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    gui.DisplayOrder = 1000
    safeParent(gui)

    NotifyHolder = Instance.new("Frame")
    NotifyHolder.Name = "Holder"
    NotifyHolder.BackgroundTransparency = 1
    NotifyHolder.AnchorPoint = Vector2.new(1, 1)
    NotifyHolder.Position = UDim2.new(1, -20, 1, -20)
    NotifyHolder.Size = UDim2.new(0, 320, 1, -40)
    NotifyHolder.Parent = gui

    local l = listLayout(NotifyHolder, Enum.FillDirection.Vertical, 8)
    l.VerticalAlignment = Enum.VerticalAlignment.Bottom
    l.HorizontalAlignment = Enum.HorizontalAlignment.Right

    return NotifyHolder
end

local function currentTheme()
    return (Phantom._activeWindow and Phantom._activeWindow._theme) or Phantom.Themes.Dark
end

function Phantom:Notify(opts)
    opts = opts or {}
    local theme = currentTheme()
    local holder = ensureNotifyHolder()

    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 0)
    f.AutomaticSize = Enum.AutomaticSize.Y
    f.BackgroundColor3 = theme.Notify
    f.BackgroundTransparency = 1
    f.BorderSizePixel = 0
    f.ClipsDescendants = true
    f.Parent = holder
    corner(f, UDim.new(0, 8))
    local s = stroke(f, theme.Stroke, 1, 1)
    padding(f, 12)

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 18)
    title.BackgroundTransparency = 1
    title.Font = FONT_BOLD
    title.Text = opts.Title or "Notification"
    title.TextSize = 14
    title.TextColor3 = theme.Text
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.TextTransparency = 1
    title.Parent = f

    local body = Instance.new("TextLabel")
    body.Position = UDim2.new(0, 0, 0, 22)
    body.Size = UDim2.new(1, 0, 0, 0)
    body.AutomaticSize = Enum.AutomaticSize.Y
    body.BackgroundTransparency = 1
    body.Font = FONT_REG
    body.Text = opts.Content or ""
    body.TextSize = 13
    body.TextColor3 = theme.SubText
    body.TextXAlignment = Enum.TextXAlignment.Left
    body.TextWrapped = true
    body.TextTransparency = 1
    body.Parent = f

    tween(f, TWEEN_MED, { BackgroundTransparency = 0.05 })
    tween(s, TWEEN_MED, { Transparency = 0 })
    tween(title, TWEEN_MED, { TextTransparency = 0 })
    tween(body, TWEEN_MED, { TextTransparency = 0.2 })

    task.delay(opts.Duration or 4, function()
        tween(f, TWEEN_MED, { BackgroundTransparency = 1 })
        tween(s, TWEEN_MED, { Transparency = 1 })
        tween(title, TWEEN_MED, { TextTransparency = 1 })
        tween(body, TWEEN_MED, { TextTransparency = 1 })
        task.wait(0.3)
        f:Destroy()
    end)
end

