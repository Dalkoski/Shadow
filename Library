--==============================================================
-- CONFIG SAVE/LOAD
--==============================================================
function VaenHub:_SaveConfig(win, profile)
	if not (writefile and makefolder) then return end
	local data = {}
	for _, e in ipairs(win._elements) do
		if e._flag then
			if e._type == "ColorPicker" then
				local c = e._current or Color3.new(1,1,1)
				data[e._flag] = {c.R*255, c.G*255, c.B*255}
			else
				data[e._flag] = e._current
			end
		end
	end
	pcall(function()
		if not isfolder("VaenHub") then makefolder("VaenHub") end
		if not isfolder("VaenHub/Configs") then makefolder("VaenHub/Configs") end
		local folder = "VaenHub/Configs/" .. (win._configSave.FolderName or win._name)
		if not isfolder(folder) then makefolder(folder) end
		writefile(folder .. "/" .. profile .. ".vhc", HttpService:JSONEncode(data))
	end)
end

function VaenHub:_LoadConfig(win, profile)
	if not (readfile and isfile) then return end
	local folder = "VaenHub/Configs/" .. (win._configSave.FolderName or win._name)
	local path = folder .. "/" .. profile .. ".vhc"
	if not isfile(path) then return end
	local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok or not data then return end
	for _, e in ipairs(win._elements) do
		if e._flag and data[e._flag] ~= nil then
			local v = data[e._flag]
			if e._type == "ColorPicker" and type(v) == "table" then
				v = Color3.fromRGB(v[1], v[2], v[3])
			end
			pcall(function() e:Set(v) end)
		end
	end
end

--==============================================================
-- NOTIFICATIONS
--==============================================================
VaenHub._notifContainer = nil
VaenHub._notifActive = 0
VaenHub._notifQueue = {}

function VaenHub:_QueueNotif(d)
	if not self._notifContainer then self:_CreateNotifContainer() end
	if self._notifActive >= 4 then table.insert(self._notifQueue, d); return end
	self:_ShowNotif(d)
end

function VaenHub:_CreateNotifContainer()
	local g = Instance.new("ScreenGui")
	g.Name = "VHNotif_" .. HttpService:GenerateGUID(false):sub(1,6)
	g.IgnoreGuiInset = true
	g.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	g.DisplayOrder = 200
	if gethui then g.Parent = gethui() else g.Parent = CoreGui end

	local c = Instance.new("Frame")
	c.AnchorPoint = Vector2.new(1, 1)
	c.Position = UDim2.new(1, -20, 1, -20)
	c.Size = UDim2.fromOffset(320, 400)
	c.BackgroundTransparency = 1
	c.Parent = g

	local l = listLayout(c, 8)
	l.VerticalAlignment = Enum.VerticalAlignment.Bottom
	l.HorizontalAlignment = Enum.HorizontalAlignment.Right

	self._notifContainer = c
end

function VaenHub:_ShowNotif(d)
	self._notifActive = self._notifActive + 1
	local theme = self.Presets.Phantom

	local n = Instance.new("Frame")
	n.Size = UDim2.new(1, 0, 0, 64)
	n.BackgroundColor3 = theme.ElementBg
	n.BorderSizePixel = 0
	n.Parent = self._notifContainer
	corner(n, 10)
	stroke(n, Color3.fromRGB(255,255,255), 0.86)

	-- Accent stripe
	local stripe = Instance.new("Frame")
	stripe.Size = UDim2.fromOffset(3, 32)
	stripe.Position = UDim2.fromOffset(0, 16)
	stripe.BorderSizePixel = 0
	if d.Type == "success" then stripe.BackgroundColor3 = theme.Success
	elseif d.Type == "warning" then stripe.BackgroundColor3 = theme.Warning
	elseif d.Type == "error" then stripe.BackgroundColor3 = theme.Danger
	else stripe.BackgroundColor3 = theme.Accent[1] end
	stripe.Parent = n
	corner(stripe, 2)

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -24, 0, 18)
	title.Position = UDim2.fromOffset(14, 10)
	title.BackgroundTransparency = 1
	title.Text = d.Title
	title.Font = Enum.Font.GothamMedium
	title.TextSize = 12
	title.TextColor3 = theme.Text
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = n

	local content = Instance.new("TextLabel")
	content.Size = UDim2.new(1, -24, 0, 32)
	content.Position = UDim2.fromOffset(14, 28)
	content.BackgroundTransparency = 1
	content.Text = d.Content
	content.Font = Enum.Font.Gotham
	content.TextSize = 11
	content.TextColor3 = theme.TextDim
	content.TextXAlignment = Enum.TextXAlignment.Left
	content.TextYAlignment = Enum.TextYAlignment.Top
	content.TextWrapped = true
	content.Parent = n

	n.Position = UDim2.new(1, 50, 0, 0)
	tween(n, 0.4, {Position = UDim2.fromOffset(0, 0)})

	task.delay(d.Duration, function()
		tween(n, 0.4, {BackgroundTransparency = 1})
		tween(title, 0.4, {TextTransparency = 1})
		tween(content, 0.4, {TextTransparency = 1})
		task.wait(0.4)
		n:Destroy()
		self._notifActive = self._notifActive - 1
		if #self._notifQueue > 0 then
			self:_ShowNotif(table.remove(self._notifQueue, 1))
		end
	end)
end

--==============================================================
-- ANIMATION HELPERS
--==============================================================
function VaenHub:_AnimateHide(win)
	if not win._main then return end
	tween(win._main, 0.4, {Size = UDim2.fromOffset(620, 0)}, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
end

function VaenHub:_AnimateShow(win)
	if not win._main then return end
	tween(win._main, 0.5, {Size = UDim2.fromOffset(620, 420)})
end

function VaenHub:_AnimateMinimise(win)
	if win._minimised then
		tween(win._main, 0.4, {Size = UDim2.fromOffset(620, 44)})
		win._content.Visible = false
		win._tabBar.Visible = false
	else
		win._content.Visible = true
		win._tabBar.Visible = true
		tween(win._main, 0.4, {Size = UDim2.fromOffset(620, 420)})
	end
end

--==============================================================
-- 12. UTILITIES
--==============================================================
function VaenHub:_MakeDraggable(frame, handle)
	local dragging, dragStart, startPos
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
		end
	end)
	handle.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

return VaenHub
