    local btnLabel = new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, 32, 0.5, 0),
        Size = UDim2.new(1, -42, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        TextTransparency = whiteAlpha(0.5),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
        ZIndex = 3,
    }, btn)

    -- PANEL (scrolling frame)
    local panel = new("ScrollingFrame", {
        Name = "Panel_" .. name,
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255),
        ScrollBarImageTransparency = 0.85,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        ZIndex = 2,
    }, self_win.PanelContainer)
    local panelLayout = listV(panel, 7)
    panelLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left

    local tab = setmetatable({
        _window  = self_win,
        _name    = name,
        Button   = btn,
        Panel    = panel,
        BtnIcon  = btnIcon,
        BtnLabel = btnLabel,
        BtnStroke= btnStroke,
    }, Tab)

    btn.MouseEnter:Connect(function()
        if self_win.ActiveTab ~= tab then
            tween(btn, 0.15, { BackgroundTransparency = whiteAlpha(0.04) })
        end
    end)
    btn.MouseLeave:Connect(function()
        if self_win.ActiveTab ~= tab then
            tween(btn, 0.15, { BackgroundTransparency = whiteAlpha(0.02) })
        end
    end)
    btn.MouseButton1Click:Connect(function()
        self_win:SetActiveTab(tab)
    end)

    table.insert(self_win.Tabs, tab)
    if #self_win.Tabs == 1 then
        self_win:SetActiveTab(tab)
    end
    return tab
end

function Window:SetActiveTab(tab)
    for _, t in ipairs(self.Tabs) do
        if t == tab then
            t.Panel.Visible = true
            tween(t.Button, 0.2, { BackgroundTransparency = whiteAlpha(0.06) })
            tween(t.BtnStroke, 0.2, { Transparency = whiteAlpha(0.08) })
            tween(t.BtnIcon, 0.2, { ImageTransparency = 0 })
            tween(t.BtnLabel, 0.2, { TextTransparency = 0 })
        else
            t.Panel.Visible = false
            tween(t.Button, 0.2, { BackgroundTransparency = whiteAlpha(0.02) })
            tween(t.BtnStroke, 0.2, { Transparency = whiteAlpha(0.04) })
            tween(t.BtnIcon, 0.2, { ImageTransparency = whiteAlpha(0.5) })
            tween(t.BtnLabel, 0.2, { TextTransparency = whiteAlpha(0.5) })
        end
    end
    self.ActiveTab = tab
    self:SetSectionTitle(tab._name)
end

