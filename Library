                Color = ColorSequence.new(Color3.new(1,1,1), Color3.new(1,1,1)),
                Transparency = NumberSequence.new(0, 1),
                Parent = satFrame,
            })
            -- Add value (darkness) overlay via second gradient
            local valOverlay = new("Frame", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundColor3 = Color3.new(0,0,0),
                BorderSizePixel = 0,
                BackgroundTransparency = 0,
                Parent = satFrame,
            })
            corner(valOverlay, UDim.new(0, 4))
            new("UIGradient", {
                Color = ColorSequence.new(Color3.new(0,0,0)),
                Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0),
                }),
                Rotation = 90,
                Parent = valOverlay,
            })

            local satKnob = new("Frame", {
                Size = UDim2.new(0, 8, 0, 8),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel = 0,
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(sV, 0, 1 - v, 0),
                ZIndex = 5,
                Parent = satFrame,
            })
            corner(satKnob, UDim.new(1, 0))
            stroke(satKnob, Color3.new(0,0,0), 1).Transparency = 0.5

            -- Hue strip
            local hueFrame = new("Frame", {
                AnchorPoint = Vector2.new(1, 0),
                Position = UDim2.new(1, 0, 0, 0),
                Size = UDim2.new(0, 16, 1, 0),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel = 0,
                Parent = body,
            })
            corner(hueFrame, UDim.new(0, 4))
            new("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0/6, Color3.fromRGB(255,0,0)),
                    ColorSequenceKeypoint.new(1/6, Color3.fromRGB(255,255,0)),
                    ColorSequenceKeypoint.new(2/6, Color3.fromRGB(0,255,0)),
                    ColorSequenceKeypoint.new(3/6, Color3.fromRGB(0,255,255)),
                    ColorSequenceKeypoint.new(4/6, Color3.fromRGB(0,0,255)),
                    ColorSequenceKeypoint.new(5/6, Color3.fromRGB(255,0,255)),
                    ColorSequenceKeypoint.new(6/6, Color3.fromRGB(255,0,0)),
                }),
                Rotation = 90,
                Parent = hueFrame,
            })
            local hueKnob = new("Frame", {
                Size = UDim2.new(1, 4, 0, 4),
                Position = UDim2.new(0, -2, h, -2),
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel = 0,
                ZIndex = 5,
                Parent = hueFrame,
            })
            corner(hueKnob, UDim.new(0, 2))

            local function updateColor(fire)
                Picker.Value = Color3.fromHSV(h, sV, v)
                preview.BackgroundColor3 = Picker.Value
                satFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                satKnob.Position = UDim2.new(sV, 0, 1 - v, 0)
                hueKnob.Position = UDim2.new(0, -2, h, -2)
                if fire and opts.Callback then task.spawn(opts.Callback, Picker.Value) end
            end

            local dragSat, dragHue = false, false
            satFrame.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    dragSat = true
                end
            end)
            hueFrame.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    dragHue = true
                end
            end)
            track(UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    dragSat, dragHue = false, false
                end
            end))
            track(UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType ~= Enum.UserInputType.MouseMovement and i.UserInputType ~= Enum.UserInputType.Touch then return end
                if dragSat then
                    sV = math.clamp((i.Position.X - satFrame.AbsolutePosition.X) / satFrame.AbsoluteSize.X, 0, 1)
                    v  = 1 - math.clamp((i.Position.Y - satFrame.AbsolutePosition.Y) / satFrame.AbsoluteSize.Y, 0, 1)
                    updateColor(true)
                elseif dragHue then
                    h = math.clamp((i.Position.Y - hueFrame.AbsolutePosition.Y) / hueFrame.AbsoluteSize.Y, 0, 1)
                    updateColor(true)
                end
            end))

            local open = false
            header.MouseButton1Click:Connect(function()
                open = not open
                tween(f, TWEEN_MED, { Size = UDim2.new(1, 0, 0, open and 156 or 38) })
            end)

            function Picker:Set(c)
                Picker.Value = c
                h, sV, v = c:ToHSV()
                updateColor(true)
            end

            addListener(function(nt)
                f.BackgroundColor3 = nt.Element
                s.Color = nt.ElementStroke
                lbl.TextColor3 = nt.Text
            end)

            if opts.Flag then Phantom.Flags[opts.Flag] = Picker end
            return Picker
        end

        return Tab
    end

    ----------------------------------------------------------
    -- Visibility helpers
    ----------------------------------------------------------
    function Window:SetVisible(state)
        setHidden(not state)
    end
    function Window:Toggle()
        setHidden(not hidden)
    end
    function Window:IsVisible()
        return not hidden
    end

    ----------------------------------------------------------
    -- Destroy
    ----------------------------------------------------------
    function Window:Destroy()
        for _, c in ipairs(Window._connections) do
            pcall(function() c:Disconnect() end)
        end
        table.clear(Window._connections)
        if Window._gui then
            Window._gui:Destroy()
            Window._gui = nil
        end
        if activeWindow == Window then
            activeWindow = nil
        end
        -- Remove this window's theme listeners
        for i = #themeListeners, 1, -1 do
            if themeListeners[i].window == Window then
                table.remove(themeListeners, i)
            end
        end
    end

    return Window
end

return Phantom
