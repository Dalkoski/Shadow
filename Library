--==============================================================
-- TOGGLE (iOS style)
-- HTML off: bg white 0.07, border white 0.08, 36x21
--   knob 15x15 at top 2 left 2, bg white 0.45
-- HTML on: bg white 0.92 (almost solid white), border transparent
--   knob 15x15 at left calc(100%-17px), bg #18181a
--==============================================================
local function makeToggle(parent, isOn, width, height)
	width = width or 36
	height = height or 21
	local knobSize = height - 6  -- HTML: 15 for 21, 13 for 17

	local t = new("Frame", {
		Name = "Toggle",
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -14, 0.5, 0),
		Size = UDim2.fromOffset(width, height),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = isOn and whiteAlpha(0.92) or whiteAlpha(0.07),
		BorderSizePixel = 0,
		ZIndex = 3,
	}, parent)
	corner(t, math.floor(height/2))
	if not isOn then
		stroke(t, Color3.fromRGB(255,255,255), whiteAlpha(0.08), 1)
	end

	local knob = new("Frame", {
		Name = "Knob",
		Size = UDim2.fromOffset(knobSize, knobSize),
		Position = isOn
			and UDim2.new(1, -(knobSize + 2), 0.5, 0)
			or  UDim2.new(0, 2, 0.5, 0),
		AnchorPoint = isOn and Vector2.new(1, 0.5) or Vector2.new(0, 0.5),
		BackgroundColor3 = isOn and COLOR.KnobOn or COLOR.KnobOff,
		BackgroundTransparency = isOn and 0 or whiteAlpha(0.45),
		BorderSizePixel = 0,
		ZIndex = 4,
	}, t)
	corner(knob, math.floor(knobSize/2))

	return t
end

