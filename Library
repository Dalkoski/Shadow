local function attachHover(card, baseAlpha, hoverAlpha)
    baseAlpha = baseAlpha or whiteAlpha(0.025)
    hoverAlpha = hoverAlpha or whiteAlpha(0.05)
    card.MouseEnter:Connect(function() tween(card, 0.15, { BackgroundTransparency = hoverAlpha }) end)
    card.MouseLeave:Connect(function() tween(card, 0.15, { BackgroundTransparency = baseAlpha }) end)
end

local function registerFlag(win, flag, element)
    if not flag then return end
    Library.Flags[flag] = element
    win.Flags[flag] = element.Value
end

local function updateFlag(win, flag, value)
    if not flag then return end
    win.Flags[flag] = value
end

