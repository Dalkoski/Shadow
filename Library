		Size = UDim2.new(1, -90, 1, 0),
		Position = UDim2.fromOffset(14, 0),
		BackgroundTransparency = 1,
		Text = elem._name,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextColor3 = THEME.Text,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, frame)

	local bindBox = newInst("TextButton", {
		AnchorPoint = Vector2.new(1, 0.5),
		Size = UDim2.fromOffset(60, 24),
		Position = UDim2.new(1, -14, 0.5, 0),
		BackgroundColor3 = THEME.ElementHover,
		BorderSizePixel = 0,
		Text = elem._current,
		Font = Enum.Font.GothamMedium,
		TextSize = 11,
		TextColor3 = THEME.Text,
		AutoButtonColor = false,
	}, frame)
	corner(bindBox, 6)
	stroke(bindBox, THEME.Border, 0.6)

	local capturing = false
	bindBox.MouseButton1Click:Connect(function()
		capturing = true
		bindBox.Text = "..."
	end)

	local c = UserInputService.InputBegan:Connect(function(input, processed)
		if capturing and input.KeyCode ~= Enum.KeyCode.Unknown then
			capturing = false
			elem._current = input.KeyCode.Name
			bindBox.Text = elem._current
			if elem._flag and elem._window._configSave.Enabled then elem._window:SaveConfig() end
		elseif not capturing and not processed and input.KeyCode.Name == elem._current then
			if elem._callback then task.spawn(pcall, elem._callback, elem._current) end
		end
	end)
	table.insert(elem._window._connections, c)

	elem._frame = frame
	elem._update = function(v) elem._current = v; bindBox.Text = tostring(v) end
end

