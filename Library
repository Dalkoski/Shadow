function Library:SetLoaderUrl(url) self._loaderUrl = url end

function Library:AutoExec(url)
    if type(url) ~= "string" or url == "" then return false end
    self._autoExecUrl = url
    if not exec.queue_on_teleport then return false end
    local payload = string.format(
        "repeat task.wait() until game:IsLoaded() and game.Players.LocalPlayer\n"..
        "local ok,err=pcall(function() loadstring(game:HttpGet(%q))() end)\n"..
        "if not ok then warn('[Library] auto-exec failed: '..tostring(err)) end",
        url
    )
    local ok = pcall(exec.queue_on_teleport, payload)
    return ok
end

function Library:_armTeleportPersistence()
    if not exec.queue_on_teleport then return end
    local url = self._autoExecUrl or self._loaderUrl
    local payload = string.format(
        "repeat task.wait() until game:IsLoaded() and game.Players.LocalPlayer\n"..
        "local ok,err=pcall(function() loadstring(game:HttpGet(%q))() end)\n"..
        "if not ok then warn('[Library] reload failed: '..tostring(err)) end",
        url
    )
    pcall(exec.queue_on_teleport, payload)
end

function Library:Rejoin()
    self:_armTeleportPersistence()
    pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer) end)
end

function Library:ServerHop()
    self:_armTeleportPersistence()
    local placeId = game.PlaceId
    local ok, response = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(
            "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
        ))
    end)
    if not ok or not response or not response.data then
        pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
        return
    end
    local best
    for _, srv in ipairs(response.data) do
        if srv.playing and srv.maxPlayers and srv.id ~= game.JobId and srv.playing < srv.maxPlayers then
            if not best or srv.playing > best.playing then best = srv end
        end
    end
    if best then
        pcall(function() TeleportService:TeleportToPlaceInstance(placeId, best.id, LocalPlayer) end)
    else
        pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
    end
end

function Library:SetVisibility(v)
    for _, w in ipairs(self._windows) do
        if not w._destroyed then w:SetVisibility(v) end
    end
end

function Library:IsVisible()
    for _, w in ipairs(self._windows) do
        if not w._destroyed and w:IsVisible() then return true end
    end
    return false
end

function Library:Destroy()
    for _, w in ipairs(self._windows) do
        if not w._destroyed then w:Destroy() end
    end
end

